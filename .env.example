# Bitrix24 Live Chat (виджет онлайн-чата — Открытые линии)
# Бесплатный тариф Bitrix24 Free поддерживает этот виджет.
# Как получить URL: CRM → Каналы → Виджет для сайта → Код для сайта
# Скопируйте URL из src загрузчика (строка вида loader_XX_HASH.js) и вставьте сюда.
PUBLIC_B24_CHAT_SCRIPT_URL=https://your-domain.bitrix24.ru/upload/crm/site_button/loader_XX_HASH.js

# Bitrix24 CRM webhook (required for order and consultation leads)
B24_WEBHOOK_URL=https://your-domain.bitrix24.ru/rest/1/your-webhook-token
B24_ORIGINATOR_ID=CRYPTORO_SITE          # служебный идентификатор источника лидов для идемпотентности
B24_CONSULT_DEDUP_MINUTES=30             # окно (в минутах) для антидубля консультаций
B24_CONTACT_SYNC=1                       # 1 = искать/создавать контакт и привязывать к лиду
B24_CONTACT_UPDATE_ON_MATCH=1            # 1 = обновлять ФИО/тел/email у найденного контакта
B24_TELEGRAM_FIELD_CODE=UF_CRM_TELEGRAM  # опционально: код кастомного поля Контакта для Telegram
B24_CURRENCY_ID=RUB
B24_DEAL_SYNC_ON_CONVERT=1               # 1 = после лида пробуем синхронизировать товары и в сделку (если лид автоконвертируется)
# B24_LEAD_DELIVERY_FIELD_CODE=UF_CRM_123456789   # опционально: код поля "Способ доставки" в лиде
# B24_DEAL_DELIVERY_FIELD_CODE=UF_CRM_987654321   # опционально: код поля "Способ доставки" в сделке
# B24_LEAD_DELIVERY_ENUM_JSON={"сдэк":123,"самовывоз":124}  # если поле доставки в лиде — тип Список
# B24_DEAL_DELIVERY_ENUM_JSON={"сдэк":223,"самовывоз":224}  # если поле доставки в сделке — тип Список
# B24_LEAD_FULL_NAME_FIELD_CODE=UF_CRM_111111111            # поле "ФИО" в лиде
# B24_LEAD_PHONE_FIELD_CODE=UF_CRM_222222222                # поле "Телефон" в лиде
# B24_LEAD_EMAIL_FIELD_CODE=UF_CRM_333333333                # поле "Email" в лиде
# B24_DEAL_FULL_NAME_FIELD_CODE=UF_CRM_444444444            # поле "ФИО" в сделке
# B24_DEAL_PHONE_FIELD_CODE=UF_CRM_555555555                # поле "Телефон" в сделке
# B24_DEAL_EMAIL_FIELD_CODE=UF_CRM_666666666                # поле "Email" в сделке
# Маппинг Bitrix PRODUCT_ID для товарных позиций в лидах:
# ключи:
# - "SKU" (фоллбек для любого цвета)
# - "SKU::цвет" (приоритет, цвет из корзины; например: черный, серебристый, starlight, cosmic_gray)
# Ниже готовый пример под текущие SKU проекта и ID с вашей таблицы.
# Временные fallback:
# - CR-400 (Plaud Note navy blue) -> 1846, пока не будет отдельного PRODUCT_ID синего цвета в Bitrix
# - CR-256/CR-258 (NotePin silver/purple) -> 2646
B24_PRODUCT_MAP_JSON={"CR-191::black":1846,"CR-191::черный":1846,"CR-191":1846,"CR-197::silver":1896,"CR-197::серебристый":1896,"CR-197":1896,"CR-209::starlight":2028,"CR-209::gold":2028,"CR-209::золотистый":2028,"CR-209":2028,"CR-400::blue":1846,"CR-400::navy_blue":1846,"CR-400::синий":1846,"CR-400":1846,"CR-327::black":3964,"CR-327::черный":3964,"CR-327":3964,"CR-217::cosmic_gray":2646,"CR-217::graphite":2646,"CR-217::графит":2646,"CR-217":2646,"CR-256::silver":2646,"CR-256::lunar_silver":2646,"CR-256::серебристый":2646,"CR-256":2646,"CR-258::purple":2646,"CR-258::sunset_purple":2646,"CR-258::фиолетовый":2646,"CR-258":2646,"AC-40":3204,"CR-228":3600}

# Ozon Delivery API (опционально; без ключей включится mock/fallback режим)
OZON_CLIENT_ID=your_ozon_client_id
OZON_API_KEY=your_ozon_api_key
OZON_API_BASE=https://api-seller.ozon.ru
OZON_MOCK=0
# OZON_CALCULATE_PATH=/v1/delivery/calculate

# СДЭК API (для расчёта доставки и создания заявок)
CDEK_CLIENT_ID=your_cdek_client_id
CDEK_CLIENT_SECRET=your_cdek_client_secret
CDEK_SENDER_CITY_CODE=44   # код города отправки (44 = Москва)
CDEK_API_BASE=https://api.edu.cdek.ru
CDEK_TEST_MODE=1
CDEK_MOCK=1
CDEK_CREATE_ORDER=1
# Бизнес-параметры расчета:
CDEK_MARKUP_MULTIPLIER=1.30
CDEK_COD_RATE=0.04
# Список тарифов через запятую (опционально): если пусто, выбираем автоматически по delivery_mode.
# CDEK_PICKUP_TARIFF_CODES=136,234
# CDEK_DOOR_TARIFF_CODES=137,233
# Данные отправителя для создания заказа в СДЭК:
CDEK_SENDER_NAME=CRYPTORO
CDEK_SENDER_PHONE=+74951918174
# CDEK_SENDER_ADDRESS=Москва, Нагатинская набережная, 42
# Габариты упаковки в мм (базово для текущих SKU):
CDEK_PACKAGE_LENGTH_MM=86
CDEK_PACKAGE_WIDTH_MM=54
CDEK_PACKAGE_HEIGHT_MM=3
# Вес единицы по умолчанию (г), если в payload товара нет поля weight
CDEK_ITEM_WEIGHT_G=80

# Платёжная система (раскомментируйте нужное)
# CloudPayments
# CP_PUBLIC_ID=your_cloudpayments_public_id
# CP_API_PASSWORD=your_cloudpayments_api_password
# PayKeeper
# PK_SERVER_URL=https://your-shop.server.paykeeper.ru
# PK_USER=your_paykeeper_user
# PK_PASSWORD=your_paykeeper_password
# PK_POST_SECRET=your_paykeeper_post_secret
# PK_TOKEN_PATH=/info/settings/token/
# PK_CREATE_INVOICE_PATH=/change/invoice/preview/
# PK_BILL_PATH_PREFIX=/bill/
# PK_IDEMPOTENCY_TTL_SEC=1209600
# PK_MOCK=1
# PK_IDEMPOTENCY_KV — только как Cloudflare KV binding (не через .env)
