---
interface Props {
  active?: 'home' | 'catalog' | 'about';
}
const { active } = Astro.props;
---
<style is:global>
  /* ── Smart Header ─────────────────────────────────── */
  #smart-header {
    position: fixed;
    left: 50%;
    z-index: 100;
    /* Привязка к viewport без зависимости от vw-дельты/скроллбара между страницами */
    width: min(var(--chrome-max-width, 1120px), calc(100% - (var(--chrome-edge-gap, 24px) * 2)));
    max-width: none;
    box-sizing: border-box;
    border-radius: 9999px;
    /* Transition only compositor-friendly props */
    transition:
      height          220ms ease,
      background-color 220ms ease,
      backdrop-filter  220ms ease,
      -webkit-backdrop-filter 220ms ease,
      border-color    220ms ease,
      box-shadow      220ms ease,
      transform       360ms cubic-bezier(0.2,0.8,0.2,1);
  }
  @media (prefers-reduced-motion: reduce) {
    #smart-header { transition: none !important; }
    .header-consult-cta { transition: none !important; }
  }

  /* ── Expanded: top of page, transparent ── */
  #smart-header[data-state="expanded"] {
    top: 16px;
    height: 68px;
    /* Видимое состояние: стеклянная пилюля без изменения логики скролла */
    background: rgba(255,255,255,.74) !important;
    backdrop-filter: blur(20px)       !important;
    -webkit-backdrop-filter: blur(20px) !important;
    border: 1px solid rgba(17,17,17,.08) !important;
    box-shadow: 0 12px 30px rgba(0,0,0,.05) !important;
    transform: translateX(-50%) translateY(0);
  }

  /* ── Compact: scrolled, pill visible ── */
  #smart-header[data-state="compact"] {
    top: 16px;
    height: 52px;
    background: rgba(255,255,255,.86) !important;
    backdrop-filter: blur(24px)       !important;
    -webkit-backdrop-filter: blur(24px) !important;
    border: 1px solid rgba(17,17,17,.09) !important;
    box-shadow: 0 12px 30px rgba(0,0,0,.06) !important;
    transform: translateX(-50%) translateY(0);
  }

  /* ── Hidden: scrolling down ── */
  #smart-header[data-state="hidden"] {
    top: 16px;
    height: 52px;
    background: rgba(255,255,255,.86) !important;
    backdrop-filter: blur(24px)       !important;
    -webkit-backdrop-filter: blur(24px) !important;
    border: 1px solid rgba(17,17,17,.09) !important;
    box-shadow: 0 12px 30px rgba(0,0,0,.06) !important;
    /* -100% = compact height (52px), -20px clears top:16px offset */
    transform: translateX(-50%) translateY(calc(-100% - 20px));
  }

  .header-inner {
    height: 100%;
    padding: 0 var(--chrome-pad-x, 24px);
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 12px;
    position: relative;
  }
  .header-logo {
    justify-self: start;
    min-width: 0;
    font-family:'Unbounded',sans-serif;
    font-size:14px;
    font-weight:900;
    letter-spacing:.06em;
    color:#111;
    text-decoration:none;
  }
  .header-nav-link{font-size:14px}
  .header-center {
    /* Жёстко центрируем nav относительно pill-header, а не соседних зон */
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
    width: clamp(320px, calc(100% - 360px), var(--chrome-nav-width, 420px));
  }
  .header-right {
    justify-self: end;
    display: inline-flex;
    align-items: center;
    min-width: 0;
    position: relative;
    gap: 6px;
  }
  #smart-header .chrome-nav {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    align-items: center;
    gap: 6px;
    width: 100%;
  }
  #smart-header .chrome-nav a {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    min-height: 36px;
    padding: 0 12px;
    margin-left: 0 !important;
    border-radius: 9999px;
    border: 1px solid transparent;
    color: rgba(17,17,17,.9) !important;
    font-weight: 500;
    text-decoration: none !important;
    box-shadow: none;
    transition: background-color 180ms ease, border-color 180ms ease, color 180ms ease, box-shadow 180ms ease;
  }
  #smart-header .chrome-nav a:hover {
    background: rgba(17,17,17,.04);
    border-color: rgba(17,17,17,.06);
    color: #111 !important;
    text-decoration: none !important;
    box-shadow: 0 6px 16px rgba(0,0,0,.03);
  }
  #smart-header .chrome-nav a[aria-current="page"] {
    background: rgba(17,17,17,.06);
    border-color: rgba(17,17,17,.10);
    color: #111 !important;
    font-weight: 500;
    text-decoration: none !important;
    box-shadow: 0 7px 18px rgba(0,0,0,.05);
  }

  .header-consult-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    height: 40px;
    gap: 6px;
    padding: 0 14px;
    border-radius: 9999px;
    border: 1px solid rgba(255,69,0,.18);
    background: linear-gradient(90deg, rgba(255,69,0,.08), rgba(255,215,0,.10));
    color: #111;
    font-size: 13px;
    font-weight: 600;
    line-height: 1;
    white-space: nowrap;
    cursor: pointer;
    box-shadow: 0 4px 14px rgba(0,0,0,.03);
    transition: background-color 180ms ease, border-color 180ms ease, box-shadow 180ms ease, transform 180ms ease;
  }
  .header-consult-cta__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 14px;
    height: 14px;
    font-size: 12px;
    line-height: 1;
    opacity: .9;
  }
  .header-consult-cta:hover {
    background: linear-gradient(90deg, rgba(255,69,0,.12), rgba(255,215,0,.14));
    border-color: rgba(255,69,0,.26);
    box-shadow: 0 8px 20px rgba(255,69,0,.10), 0 8px 18px rgba(0,0,0,.04);
    transform: translateY(-1px);
  }
  .header-consult-cta:focus-visible {
    outline: 2px solid rgba(17,17,17,.9);
    outline-offset: 2px;
  }
  .header-menu-toggle {
    display: none;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border-radius: 999px;
    border: 1px solid rgba(17,17,17,.14);
    background: rgba(255,255,255,.9);
    color: #111;
    cursor: pointer;
  }
  .header-menu-toggle svg {
    width: 18px;
    height: 18px;
  }
  .header-cart-button{
    background:none;
    border:none;
    cursor:pointer;
    margin-left:0;
    display:inline-flex;
    align-items:center;
    justify-content:center;
    width:44px;
    height:44px;
    color:#111;
    position:relative;
  }
  .header-cart-count{
    position:absolute;
    /* Русский комментарий: держим счётчик внутри кнопки, чтобы не выезжал за пределы pill-header. */
    top:6px;
    right:3px;
    background:linear-gradient(90deg,#ff4500,#ffd700);
    color:#111;
    font-size:10px;
    font-weight:700;
    min-width:18px;
    height:18px;
    padding:0 5px;
    border-radius:999px;
    display:none;
    align-items:center;
    justify-content:center;
    line-height:1;
  }
  .mobile-nav-sheet {
    position: fixed;
    inset: 0;
    z-index: 98;
    pointer-events: none;
    opacity: 0;
    transition: opacity 220ms ease;
  }
  .mobile-nav-sheet::before {
    content: '';
    position: absolute;
    inset: 0;
    background: rgba(17,17,17,.24);
  }
  .mobile-nav-panel {
    position: absolute;
    top: calc(16px + 68px + 10px);
    left: max(12px, env(safe-area-inset-left, 0px) + 12px);
    right: max(12px, env(safe-area-inset-right, 0px) + 12px);
    border-radius: 18px;
    border: 1px solid rgba(17,17,17,.1);
    background: rgba(255,255,255,.98);
    box-shadow: 0 18px 38px rgba(0,0,0,.14);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    padding: 16px;
    transform: translateY(-8px) scale(.985);
    transition: transform 240ms cubic-bezier(0.22,1,0.36,1);
  }
  .mobile-nav-links {
    display: grid;
    gap: 8px;
  }
  .mobile-nav-link {
    min-height: 48px;
    border-radius: 12px;
    border: 1px solid rgba(17,17,17,.08);
    background: #fff;
    color: #111;
    display: inline-flex;
    align-items: center;
    padding: 0 14px;
    font-size: 15px;
    font-weight: 600;
    text-decoration: none;
  }
  .mobile-nav-link[aria-current="page"] {
    border-color: rgba(17,17,17,.2);
    background: rgba(17,17,17,.05);
  }
  .mobile-nav-actions {
    margin-top: 10px;
    display: grid;
    gap: 8px;
  }
  .mobile-nav-consult,
  .mobile-nav-cart {
    min-height: 48px;
    border-radius: 12px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    font-size: 15px;
    font-weight: 600;
  }
  .mobile-nav-consult {
    border: 1px solid rgba(255,69,0,.2);
    background: linear-gradient(90deg, rgba(255,69,0,.1), rgba(255,215,0,.12));
    color: #111;
  }
  .mobile-nav-cart {
    border: 1px solid rgba(17,17,17,.12);
    background: #111;
    color: #fff;
  }
  #smart-header.mobile-menu-open + .mobile-nav-sheet {
    pointer-events: auto;
    opacity: 1;
  }
  #smart-header.mobile-menu-open + .mobile-nav-sheet .mobile-nav-panel {
    transform: translateY(0) scale(1);
  }

  @media (max-width: 768px) {
    .header-inner {
      grid-template-columns: minmax(0,1fr) auto auto;
      gap: 8px;
    }
    .header-center {
      display: none !important;
      position: static;
      transform: none;
      width: auto;
    }
    .chrome-nav { display: none !important; }
    .header-consult-cta { display: none !important; }
    .header-menu-toggle { display: inline-flex; }
  }
</style>

<header id="smart-header" data-state="expanded">
  <div class="header-inner">
    <a href="/" class="header-logo">CRYPTORO</a>
    <div class="header-center">
      <nav class="chrome-nav">
        <a class="header-nav-link" href="/" aria-current={active === 'home' ? 'page' : undefined}>Главная</a>
        <a class="header-nav-link" href="/catalog" aria-current={active === 'catalog' ? 'page' : undefined}>Каталог</a>
        <a class="header-nav-link" href="/#faq">Вопросы</a>
        <a class="header-nav-link" href="/about" aria-current={active === 'about' ? 'page' : undefined}>О нас</a>
      </nav>
    </div>
    <div class="header-right">
      <button
        type="button"
        class="header-menu-toggle"
        id="mobileMenuToggle"
        aria-expanded="false"
        aria-controls="mobileNavSheet"
        aria-label="Открыть меню"
      >
        <svg aria-hidden="true" viewBox="0 0 24 24" fill="none">
          <path d="M4 7h16M4 12h16M4 17h16" stroke="currentColor" stroke-width="1.9" stroke-linecap="round"/>
        </svg>
      </button>
      <button
        type="button"
        class="header-consult-cta"
        data-open-consult
        data-lead-entrypoint="header_consult_cta"
        data-lead-source-button="Подобрать модель (хедер)"
        aria-haspopup="dialog"
        aria-controls="consultModal"
      >
        <span class="header-consult-cta__icon" aria-hidden="true"><svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M2 6h8M7 3l3 3-3 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
        <span>Подобрать модель</span>
      </button>
      <button id="cartBtn" data-cart-btn aria-label="Корзина" class="header-cart-button">
        <svg aria-hidden="true" width="18" height="18" viewBox="0 0 24 24" fill="none">
          <path d="M4 5h2l2.1 9.2a2 2 0 0 0 2 1.6h6.8a2 2 0 0 0 2-1.6L21 8H8" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"></path>
          <circle cx="10.2" cy="19" r="1.5" fill="currentColor"></circle>
          <circle cx="17.2" cy="19" r="1.5" fill="currentColor"></circle>
        </svg>
        <span id="cartCount" class="cart-n header-cart-count">0</span>
      </button>
    </div>
  </div>
</header>
<div class="mobile-nav-sheet" id="mobileNavSheet" aria-hidden="true">
  <div class="mobile-nav-panel" role="dialog" aria-label="Мобильная навигация">
    <nav class="mobile-nav-links">
      <a class="mobile-nav-link" href="/" aria-current={active === 'home' ? 'page' : undefined}>Главная</a>
      <a class="mobile-nav-link" href="/catalog" aria-current={active === 'catalog' ? 'page' : undefined}>Каталог</a>
      <a class="mobile-nav-link" href="/#faq">Вопросы</a>
      <a class="mobile-nav-link" href="/about" aria-current={active === 'about' ? 'page' : undefined}>О нас</a>
    </nav>
    <div class="mobile-nav-actions">
      <a
        href="/#lead"
        class="mobile-nav-consult"
        data-open-consult
        data-lead-entrypoint="mobile_menu_consult_cta"
        data-lead-source-button="Подобрать модель (мобильное меню)"
      >
        Подобрать модель
      </a>
      <a href="/cart" class="mobile-nav-cart">Перейти в корзину</a>
    </div>
  </div>
</div>

<script>
  import { getCartCount } from '../utils/cart';

  function paintCartCount() {
    const count = getCartCount();
    document.querySelectorAll('#cartCount, .cart-n, [data-cart-count]').forEach((node) => {
      node.textContent = String(count);
      (node as HTMLElement).style.display = count > 0 ? 'flex' : 'none';
    });
  }

  document.addEventListener('DOMContentLoaded', paintCartCount);
  window.addEventListener('cart:updated', paintCartCount);

  // ── Smart Header ───────────────────────────────────
  (function () {
    const header = document.getElementById('smart-header');
    if (!header) return;
    const menuToggle = document.getElementById('mobileMenuToggle');
    const mobileNavSheet = document.getElementById('mobileNavSheet');
    const mobileNavLinks = mobileNavSheet ? Array.from(mobileNavSheet.querySelectorAll('a')) : [];

    // px from top of viewport: header bottom in each state
    // expanded: top 16 + height 68 = 84   compact: top 16 + height 52 = 68
    const CLEARANCE = { expanded: 84, compact: 68, hidden: 0 } as const;
    const HIDE_MIN_Y = 120;
    const HIDE_DELTA = 32;
    type State = keyof typeof CLEARANCE;

    let prevY = window.scrollY;
    let state: State = prevY < 10 ? 'expanded' : 'compact';
    let stateAnchorY = prevY;
    const isMobileViewport = () => window.matchMedia('(max-width: 768px)').matches;

    // Русский комментарий: мобильное меню в одном месте для всех страниц, без дублирования в legacy-шаблонах.
    function setMobileMenuOpen(nextOpen: boolean) {
      if (!menuToggle || !mobileNavSheet) return;
      header.classList.toggle('mobile-menu-open', nextOpen);
      menuToggle.setAttribute('aria-expanded', nextOpen ? 'true' : 'false');
      mobileNavSheet.setAttribute('aria-hidden', nextOpen ? 'false' : 'true');
      document.body.style.overflow = nextOpen ? 'hidden' : '';
    }

    function apply(next: State, y = window.scrollY) {
      if (next === state) return;
      state = next;
      // Запоминаем позицию скролла в момент смены состояния (для порога скрытия)
      stateAnchorY = y;
      header!.dataset.state = state;
      document.documentElement.style.setProperty('--sh-h', CLEARANCE[state] + 'px');
    }

    // Set immediately (before first scroll event)
    header.dataset.state = state;
    document.documentElement.style.setProperty('--sh-h', CLEARANCE[state] + 'px');

    if (menuToggle && mobileNavSheet) {
      menuToggle.addEventListener('click', () => {
        const next = !header.classList.contains('mobile-menu-open');
        setMobileMenuOpen(next);
      });
      mobileNavSheet.addEventListener('click', (event) => {
        if (event.target === mobileNavSheet) setMobileMenuOpen(false);
      });
      mobileNavLinks.forEach((link) => {
        link.addEventListener('click', () => setMobileMenuOpen(false));
      });
      window.addEventListener('keydown', (event) => {
        if (event.key === 'Escape') setMobileMenuOpen(false);
      });
      window.addEventListener('resize', () => {
        if (!isMobileViewport()) setMobileMenuOpen(false);
      });
    }

    let ticking = false;
    window.addEventListener('scroll', () => {
      if (header.classList.contains('mobile-menu-open')) return;
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(() => {
        const y = window.scrollY;
        if (y < 10) {
          apply('expanded', y);
        } else if (y > prevY) {
          if (y < HIDE_MIN_Y || y - stateAnchorY <= HIDE_DELTA) {
            if (state !== 'hidden') apply('compact', y);
          } else {
            apply('hidden', y);
          }
        } else {
          apply('compact', y);
        }
        prevY = y;
        ticking = false;
      });
    }, { passive: true });
  })();
</script>
