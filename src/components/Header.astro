---
interface Props {
  active?: 'home' | 'catalog' | 'about';
}
const { active } = Astro.props;
---
<style is:global>
  /* ── Smart Header ─────────────────────────────────── */
  #smart-header {
    position: fixed;
    left: 50%;
    z-index: 100;
    /* Привязка к viewport без зависимости от vw-дельты/скроллбара между страницами */
    width: min(var(--chrome-max-width, 1120px), calc(100% - (var(--chrome-edge-gap, 24px) * 2)));
    max-width: none;
    box-sizing: border-box;
    border-radius: 9999px;
    /* Transition only compositor-friendly props */
    transition:
      height          220ms ease,
      background-color 220ms ease,
      backdrop-filter  220ms ease,
      -webkit-backdrop-filter 220ms ease,
      border-color    220ms ease,
      box-shadow      220ms ease,
      transform       360ms cubic-bezier(0.2,0.8,0.2,1);
  }
  @media (prefers-reduced-motion: reduce) {
    #smart-header { transition: none !important; }
    .header-consult-cta { transition: none !important; }
  }

  /* ── Expanded: top of page, transparent ── */
  #smart-header[data-state="expanded"] {
    top: 16px;
    height: 68px;
    /* Видимое состояние: стеклянная пилюля без изменения логики скролла */
    background: rgba(255,255,255,.74) !important;
    backdrop-filter: blur(20px)       !important;
    -webkit-backdrop-filter: blur(20px) !important;
    border: 1px solid rgba(17,17,17,.08) !important;
    box-shadow: 0 12px 30px rgba(0,0,0,.05) !important;
    transform: translateX(-50%) translateY(0);
  }

  /* ── Compact: scrolled, pill visible ── */
  #smart-header[data-state="compact"] {
    top: 16px;
    height: 52px;
    background: rgba(255,255,255,.86) !important;
    backdrop-filter: blur(24px)       !important;
    -webkit-backdrop-filter: blur(24px) !important;
    border: 1px solid rgba(17,17,17,.09) !important;
    box-shadow: 0 12px 30px rgba(0,0,0,.06) !important;
    transform: translateX(-50%) translateY(0);
  }

  /* ── Hidden: scrolling down ── */
  #smart-header[data-state="hidden"] {
    top: 16px;
    height: 52px;
    background: rgba(255,255,255,.86) !important;
    backdrop-filter: blur(24px)       !important;
    -webkit-backdrop-filter: blur(24px) !important;
    border: 1px solid rgba(17,17,17,.09) !important;
    box-shadow: 0 12px 30px rgba(0,0,0,.06) !important;
    /* -100% = compact height (52px), -20px clears top:16px offset */
    transform: translateX(-50%) translateY(calc(-100% - 20px));
  }

  .header-inner {
    height: 100%;
    padding: 0 var(--chrome-pad-x, 24px);
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 12px;
    position: relative;
  }
  .header-logo {
    justify-self: start;
    min-width: 0;
  }
  .header-center {
    /* Жёстко центрируем nav относительно pill-header, а не соседних зон */
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
    width: clamp(320px, calc(100% - 360px), var(--chrome-nav-width, 420px));
  }
  .header-right {
    justify-self: end;
    display: inline-flex;
    align-items: center;
    min-width: 0;
    position: relative;
  }
  #smart-header .chrome-nav {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    align-items: center;
    gap: 6px;
    width: 100%;
  }
  #smart-header .chrome-nav a {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    min-height: 36px;
    padding: 0 12px;
    margin-left: 0 !important;
    border-radius: 9999px;
    border: 1px solid transparent;
    color: rgba(17,17,17,.9) !important;
    font-weight: 500;
    text-decoration: none !important;
    box-shadow: none;
    transition: background-color 180ms ease, border-color 180ms ease, color 180ms ease, box-shadow 180ms ease;
  }
  #smart-header .chrome-nav a:hover {
    background: rgba(17,17,17,.04);
    border-color: rgba(17,17,17,.06);
    color: #111 !important;
    text-decoration: none !important;
    box-shadow: 0 6px 16px rgba(0,0,0,.03);
  }
  #smart-header .chrome-nav a[aria-current="page"] {
    background: rgba(17,17,17,.06);
    border-color: rgba(17,17,17,.10);
    color: #111 !important;
    font-weight: 500;
    text-decoration: none !important;
    box-shadow: 0 7px 18px rgba(0,0,0,.05);
  }

  .header-consult-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    height: 40px;
    gap: 6px;
    padding: 0 14px;
    border-radius: 9999px;
    border: 1px solid rgba(255,69,0,.18);
    background: linear-gradient(90deg, rgba(255,69,0,.08), rgba(255,215,0,.10));
    color: #111;
    font-size: 13px;
    font-weight: 600;
    line-height: 1;
    white-space: nowrap;
    cursor: pointer;
    box-shadow: 0 4px 14px rgba(0,0,0,.03);
    transition: background-color 180ms ease, border-color 180ms ease, box-shadow 180ms ease, transform 180ms ease;
  }
  .header-consult-cta__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 14px;
    height: 14px;
    font-size: 12px;
    line-height: 1;
    opacity: .9;
  }
  .header-consult-cta:hover {
    background: linear-gradient(90deg, rgba(255,69,0,.12), rgba(255,215,0,.14));
    border-color: rgba(255,69,0,.26);
    box-shadow: 0 8px 20px rgba(255,69,0,.10), 0 8px 18px rgba(0,0,0,.04);
    transform: translateY(-1px);
  }
  .header-consult-cta:focus-visible {
    outline: 2px solid rgba(17,17,17,.9);
    outline-offset: 2px;
  }

  @media (max-width: 768px) {
    .header-inner {
      grid-template-columns: minmax(0,1fr) auto;
      gap: 8px;
    }
    .header-center {
      display: none !important;
      position: static;
      transform: none;
      width: auto;
    }
    .chrome-nav { display: none !important; }
    .header-consult-cta { display: none !important; }
  }
</style>

<header id="smart-header" data-state="expanded">
  <div class="header-inner">
    <a href="/" class="header-logo" style="font-family:'Unbounded',sans-serif;font-size:14px;font-weight:900;letter-spacing:.06em;color:#111;text-decoration:none">CRYPTORO</a>
    <div class="header-center">
      <nav class="chrome-nav">
        <a href="/" aria-current={active === 'home' ? 'page' : undefined} style="font-size:14px">Главная</a>
        <a href="/catalog" aria-current={active === 'catalog' ? 'page' : undefined} style="font-size:14px">Каталог</a>
        <a href="/about" aria-current={active === 'about' ? 'page' : undefined} style="font-size:14px">О нас</a>
      </nav>
    </div>
    <div class="header-right">
      <button
        type="button"
        class="header-consult-cta"
        data-open-consult
        data-lead-entrypoint="header_consult_cta"
        data-lead-source-button="Подобрать модель (хедер)"
        aria-haspopup="dialog"
        aria-controls="consultModal"
        style="margin-right:8px"
      >
        <span class="header-consult-cta__icon" aria-hidden="true">→</span>
        <span>Подобрать модель</span>
      </button>
      <button id="cartBtn" data-cart-btn aria-label="Корзина" style="background:none;border:none;cursor:pointer;position:relative;margin-left:0;display:inline-flex;align-items:center;justify-content:center;width:44px;height:44px;color:#111">
        <svg aria-hidden="true" width="18" height="18" viewBox="0 0 24 24" fill="none">
          <path d="M4 5h2l2.1 9.2a2 2 0 0 0 2 1.6h6.8a2 2 0 0 0 2-1.6L21 8H8" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"></path>
          <circle cx="10.2" cy="19" r="1.5" fill="currentColor"></circle>
          <circle cx="17.2" cy="19" r="1.5" fill="currentColor"></circle>
        </svg>
        <span id="cartCount" class="cart-n" style="position:absolute;top:-5px;right:-7px;background:linear-gradient(90deg,#ff4500,#ffd700);color:#111;font-size:9px;font-weight:700;min-width:16px;height:16px;padding:0 4px;border-radius:999px;display:none;align-items:center;justify-content:center">0</span>
      </button>
    </div>
  </div>
</header>

<script>
  import { getCartCount } from '../utils/cart';

  function paintCartCount() {
    const count = getCartCount();
    document.querySelectorAll('#cartCount, .cart-n, [data-cart-count]').forEach((node) => {
      node.textContent = String(count);
      (node as HTMLElement).style.display = count > 0 ? 'flex' : 'none';
    });
  }

  document.addEventListener('DOMContentLoaded', paintCartCount);
  window.addEventListener('cart:updated', paintCartCount);

  // ── Smart Header ───────────────────────────────────
  (function () {
    const header = document.getElementById('smart-header');
    if (!header) return;

    // px from top of viewport: header bottom in each state
    // expanded: top 16 + height 68 = 84   compact: top 16 + height 52 = 68
    const CLEARANCE = { expanded: 84, compact: 68, hidden: 0 } as const;
    const HIDE_MIN_Y = 120;
    const HIDE_DELTA = 32;
    type State = keyof typeof CLEARANCE;

    let prevY = window.scrollY;
    let state: State = prevY < 10 ? 'expanded' : 'compact';
    let stateAnchorY = prevY;

    function apply(next: State, y = window.scrollY) {
      if (next === state) return;
      state = next;
      // Запоминаем позицию скролла в момент смены состояния (для порога скрытия)
      stateAnchorY = y;
      header!.dataset.state = state;
      document.documentElement.style.setProperty('--sh-h', CLEARANCE[state] + 'px');
    }

    // Set immediately (before first scroll event)
    header.dataset.state = state;
    document.documentElement.style.setProperty('--sh-h', CLEARANCE[state] + 'px');

    let ticking = false;
    window.addEventListener('scroll', () => {
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(() => {
        const y = window.scrollY;
        if (y < 10) {
          apply('expanded', y);
        } else if (y > prevY) {
          if (y < HIDE_MIN_Y || y - stateAnchorY <= HIDE_DELTA) {
            if (state !== 'hidden') apply('compact', y);
          } else {
            apply('hidden', y);
          }
        } else {
          apply('compact', y);
        }
        prevY = y;
        ticking = false;
      });
    }, { passive: true });
  })();
</script>
