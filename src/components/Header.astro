---
interface Props {
  active?: 'home' | 'catalog' | 'about';
}
const { active } = Astro.props;
---
<style is:global>
  /* ── Smart Header ─────────────────────────────────── */
  #smart-header {
    position: fixed;
    left: 50%;
    z-index: 100;
    width: calc(100% - 32px);
    max-width: 1200px;
    border-radius: 28px;
    /* Transition only compositor-friendly props */
    transition:
      height          220ms ease,
      background-color 220ms ease,
      backdrop-filter  220ms ease,
      -webkit-backdrop-filter 220ms ease,
      border-color    220ms ease,
      box-shadow      220ms ease,
      transform       220ms ease;
  }
  @media (prefers-reduced-motion: reduce) {
    #smart-header { transition: none !important; }
  }

  /* ── Expanded: top of page, transparent ── */
  #smart-header[data-state="expanded"] {
    top: 16px;
    height: 68px;
    background: rgba(255,255,255,0)   !important;
    backdrop-filter: none             !important;
    -webkit-backdrop-filter: none     !important;
    border: 1px solid transparent     !important;
    box-shadow: none                  !important;
    transform: translateX(-50%) translateY(0);
  }

  /* ── Compact: scrolled, pill visible ── */
  #smart-header[data-state="compact"] {
    top: 16px;
    height: 52px;
    background: rgba(255,255,255,.88) !important;
    backdrop-filter: blur(24px)       !important;
    -webkit-backdrop-filter: blur(24px) !important;
    border: 1px solid rgba(0,0,0,.08) !important;
    box-shadow: 0 8px 32px rgba(0,0,0,.04) !important;
    transform: translateX(-50%) translateY(0);
  }

  /* ── Hidden: scrolling down ── */
  #smart-header[data-state="hidden"] {
    top: 16px;
    height: 52px;
    background: rgba(255,255,255,.88) !important;
    backdrop-filter: blur(24px)       !important;
    -webkit-backdrop-filter: blur(24px) !important;
    border: 1px solid rgba(0,0,0,.08) !important;
    box-shadow: 0 8px 32px rgba(0,0,0,.04) !important;
    /* -100% = compact height (52px), -20px clears top:16px offset */
    transform: translateX(-50%) translateY(calc(-100% - 20px));
  }

  @media (max-width: 768px) {
    .chrome-nav { display: none !important; }
  }
</style>

<header id="smart-header" data-state="expanded">
  <div style="padding:0 24px;height:100%;display:flex;align-items:center;justify-content:space-between;position:relative">
    <a href="/" style="font-family:'Unbounded',sans-serif;font-size:14px;font-weight:900;letter-spacing:.06em;color:#111;text-decoration:none">CRYPTORO</a>
    <nav class="chrome-nav">
      <a href="/" style={`font-size:14px;color:${active === 'home' ? '#111' : '#4b5563'};text-decoration:none;margin-left:28px`}>Главная</a>
      <a href="/catalog" style={`font-size:14px;color:${active === 'catalog' ? '#111' : '#4b5563'};text-decoration:none;margin-left:28px`}>Каталог</a>
      <a href="/about" style={`font-size:14px;color:${active === 'about' ? '#111' : '#4b5563'};text-decoration:none;margin-left:28px`}>О нас</a>
    </nav>
    <button id="cartBtn" data-cart-btn aria-label="Корзина" style="background:none;border:none;cursor:pointer;position:relative;margin-left:20px;display:inline-flex;align-items:center;justify-content:center;width:44px;height:44px;color:#111">
      <svg aria-hidden="true" width="18" height="18" viewBox="0 0 24 24" fill="none">
        <path d="M4 5h2l2.1 9.2a2 2 0 0 0 2 1.6h6.8a2 2 0 0 0 2-1.6L21 8H8" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"></path>
        <circle cx="10.2" cy="19" r="1.5" fill="currentColor"></circle>
        <circle cx="17.2" cy="19" r="1.5" fill="currentColor"></circle>
      </svg>
      <span id="cartCount" class="cart-n" style="position:absolute;top:-5px;right:-7px;background:linear-gradient(90deg,#ff4500,#ffd700);color:#111;font-size:9px;font-weight:700;min-width:16px;height:16px;padding:0 4px;border-radius:999px;display:none;align-items:center;justify-content:center">0</span>
    </button>
  </div>
</header>

<script>
  import { getCartCount } from '../utils/cart';

  function paintCartCount() {
    const count = getCartCount();
    document.querySelectorAll('#cartCount, .cart-n, [data-cart-count]').forEach((node) => {
      node.textContent = String(count);
      (node as HTMLElement).style.display = count > 0 ? 'flex' : 'none';
    });
  }

  document.addEventListener('DOMContentLoaded', paintCartCount);
  window.addEventListener('cart:updated', paintCartCount);

  // ── Smart Header ───────────────────────────────────
  (function () {
    const header = document.getElementById('smart-header');
    if (!header) return;

    // px from top of viewport: header bottom in each state
    // expanded: top 16 + height 68 = 84   compact: top 16 + height 52 = 68
    const CLEARANCE = { expanded: 84, compact: 68, hidden: 0 } as const;
    type State = keyof typeof CLEARANCE;

    let prevY = window.scrollY;
    let state: State = prevY < 10 ? 'expanded' : 'compact';

    function apply(next: State) {
      if (next === state) return;
      state = next;
      header!.dataset.state = state;
      document.documentElement.style.setProperty('--sh-h', CLEARANCE[state] + 'px');
    }

    // Set immediately (before first scroll event)
    header.dataset.state = state;
    document.documentElement.style.setProperty('--sh-h', CLEARANCE[state] + 'px');

    let ticking = false;
    window.addEventListener('scroll', () => {
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(() => {
        const y = window.scrollY;
        if (y < 10) {
          apply('expanded');
        } else if (y > prevY) {
          apply('hidden');
        } else {
          apply('compact');
        }
        prevY = y;
        ticking = false;
      });
    }, { passive: true });
  })();
</script>
