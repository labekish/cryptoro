---
/**
 * Bitrix24 Live Chat Widget
 *
 * Бесплатный виджет онлайн-чата Битрикс24 (Открытые линии).
 * Доступен на бесплатном тарифе Bitrix24 Free.
 *
 * Как получить код виджета:
 * 1. Войдите в ваш Bitrix24 (например, your-company.bitrix24.ru)
 * 2. Перейдите: CRM → Каналы → Виджет для сайта (или Открытые линии → Виджет)
 * 3. Нажмите «Создать виджет», настройте внешний вид
 * 4. На вкладке «Код для сайта» скопируйте URL из src загрузчика
 *    — это строка вида: https://your-domain.bitrix24.ru/upload/crm/site_button/loader_XX_HASH.js
 * 5. Запишите этот URL в переменную окружения PUBLIC_B24_CHAT_SCRIPT_URL
 *
 * Переменная окружения:
 *   PUBLIC_B24_CHAT_SCRIPT_URL=https://your-domain.bitrix24.ru/upload/crm/site_button/loader_XX_HASH.js
 */

const scriptUrl = import.meta.env.PUBLIC_B24_CHAT_SCRIPT_URL;
---

{scriptUrl && (
  <script is:inline define:vars={{ scriptUrl }}>
    (function (w, d, u) {
      var s = d.createElement('script');
      s.async = true;
      s.src = u + '?' + (Date.now() / 180000 | 0);
      var h = d.getElementsByTagName('script')[0];
      h.parentNode.insertBefore(s, h);
    })(window, document, scriptUrl);
  </script>
)}
