  <!-- WOW Animations JS -->
  <script is:inline>
  (function(){
    /* ── HERO STAGGERED ENTRANCE ── */
    var heroItems = [
      { sel:'.pdp-breadcrumbs',   delay:0.05, y:16 },
      { sel:'.pdp-hero__badges-row', delay:0.1, y:16 },
      { sel:'.pdp-hero__title',   delay:0.2, y:40 },
      { sel:'.pdp-hero__subtitle',delay:0.32, y:24 },
      { sel:'.pdp-hero__price-row',delay:0.4, y:20 },
      { sel:'.pdp-hero__media',   delay:0.35, y:32, s:0.97 },
      { sel:'.pdp-hero__colors',  delay:0.5, y:16 },
      { sel:'.pdp-hero__actions', delay:0.55, y:20 },
      { sel:'.pdp-hero__trust',   delay:0.62, y:12 }
    ];
    var heroEls = [];
    heroItems.forEach(function(item){
      var el = document.querySelector(item.sel);
      if(!el) return;
      el.classList.remove('reveal','vis');
      el.style.setProperty('--pdp-delay', item.delay+'s');
      el.style.setProperty('--pdp-y', item.y+'px');
      if(item.s) el.style.setProperty('--pdp-s', String(item.s));
      el.classList.add('pdp-anim-init');
      heroEls.push(el);
    });
    requestAnimationFrame(function(){
      requestAnimationFrame(function(){
        heroEls.forEach(function(el){
          el.classList.remove('pdp-anim-init');
          el.classList.add('pdp-anim-go');
        });
        setTimeout(function(){
          heroEls.forEach(function(el){
            el.classList.remove('pdp-anim-go');
            el.classList.add('pdp-anim-done');
          });
        }, 1400);
      });
    });

    /* ── AI DARK SECTION OBSERVER ── */
    var aiDark = document.querySelector('.pdp-ai-dark');
    if(aiDark && 'IntersectionObserver' in window){
      var aiObs = new IntersectionObserver(function(entries){
        entries.forEach(function(e){
          if(e.isIntersecting){
            e.target.classList.add('pdp-section-vis');
            aiObs.unobserve(e.target);
          }
        });
      }, { threshold:0.2 });
      aiObs.observe(aiDark);
    }

    /* ── KEY SPECS COUNT-UP ── */
    var specNums = document.querySelectorAll('.pdp-spec-card__num');
    if(specNums.length && 'IntersectionObserver' in window){
      var specsDone = false;
      var specsSection = document.querySelector('.pdp-key-specs') || document.querySelector('.parameters-panel');
      if(specsSection){
        var specsObs = new IntersectionObserver(function(entries){
          entries.forEach(function(e){
            if(e.isIntersecting && !specsDone){
              specsDone = true;
              specsObs.unobserve(e.target);
              /* Trigger spec card reveal */
              document.querySelectorAll('.pdp-spec-card').forEach(function(card){
                card.classList.add('pdp-spec-vis');
              });
              /* Count-up */
              specNums.forEach(function(el){
                var target = parseInt(el.textContent, 10);
                if(isNaN(target)) return;
                var duration = 1200;
                var startTime = null;
                function step(ts){
                  if(!startTime) startTime = ts;
                  var progress = Math.min((ts - startTime) / duration, 1);
                  var eased = 1 - Math.pow(1 - progress, 3);
                  el.textContent = String(Math.round(eased * target));
                  if(progress < 1) requestAnimationFrame(step);
                }
                el.textContent = '0';
                requestAnimationFrame(step);
              });
            }
          });
        }, { threshold:0.25 });
        specsObs.observe(specsSection);
      }
    }

    /* ── HERO PARALLAX ── */
    var heroSection = document.querySelector('.pdp-hero');
    var heroImg = document.querySelector('.pdp-hero__main-img img');
    if(heroSection && heroImg && !window.matchMedia('(prefers-reduced-motion: reduce)').matches){
      var ticking = false;
      window.addEventListener('scroll', function(){
        if(!ticking){
          ticking = true;
          requestAnimationFrame(function(){
            var rect = heroSection.getBoundingClientRect();
            if(rect.bottom > 0 && rect.top < window.innerHeight){
              var scrolled = -rect.top;
              heroImg.style.transform = 'translateY(' + (scrolled * 0.06) + 'px)';
            }
            ticking = false;
          });
        }
      }, { passive:true });
    }
  })();
  </script>

  <style is:global>
