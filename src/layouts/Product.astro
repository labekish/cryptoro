      .pdp-spec-card.pdp-spec-vis { animation:none !important; opacity:1 !important; transform:none !important }
      .pdp-cinematic__copy.reveal.vis,
      .pdp-cinematic__media.reveal.vis { animation:none !important }
      .pdp-btn--primary::after { animation:none !important; display:none !important }
    }
