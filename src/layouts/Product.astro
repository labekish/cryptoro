---
import Layout from './Layout.astro';

interface ProductData {
  title: string;
  slug: string;
  sku?: string;
  skus?: string[];
  price: number;
  badge?: string;
  image: string;
  inStock?: boolean;
  subtitle?: string;
  priceNote?: string;
  paramChips?: string[];
  seoTitle?: string;
  seoDescription?: string;
  features?: string[];
  specs?: {
    color?: string;
    dimensions?: string;
    weight?: string;
    memory?: string;
    battery?: string;
    languages?: string;
    format?: string;
    connection?: string;
    warranty?: string;
    [key: string]: string | undefined;
  };
  boxContents?: string[];
  gallery?: string[];
  colors?: string[];
}

interface RelatedItem {
  slug: string;
  title: string;
  price: number;
  image: string;
}

interface Props {
  product: ProductData;
  related?: RelatedItem[];
}

const { product, related = [] } = Astro.props;
const price = new Intl.NumberFormat('ru-RU').format(product.price);
const stockLabel = product.inStock === false ? 'Предзаказ' : 'Купить сейчас';
const allSkus = Array.from(new Set([...(Array.isArray(product.skus) ? product.skus : []), ...(product.sku ? [product.sku] : [])]));
const primarySku = allSkus[0] ?? '';
const allSkusCsv = allSkus.join(',');

const gallery = (product.gallery && product.gallery.length ? product.gallery : [product.image]).filter(Boolean);

const specsRows = [
  { label: 'Размеры', value: product.specs?.dimensions },
  { label: 'Вес', value: product.specs?.weight },
  { label: 'Память', value: product.specs?.memory },
  { label: 'Автономность', value: product.specs?.battery },
  { label: 'Языки', value: product.specs?.languages },
  { label: 'Форматы файлов', value: product.specs?.format },
  { label: 'Цвет', value: product.specs?.color },
  { label: 'Подключение', value: product.specs?.connection },
  { label: 'Гарантия', value: product.specs?.warranty }
].filter((row) => row.value);

const subtitle = product.subtitle ?? 'AI-устройство CRYPTORO';
const priceNote = product.priceNote ?? '';
const paramChips = product.paramChips ?? [];
const heroHighlights = product.features ?? [];
const colors = product.colors ?? [];
---
<Layout title={product.seoTitle ?? `${product.title} | CRYPTORO`} description={product.seoDescription ?? ''} withChrome={true} active="catalog">
  <main class="product-page">
    <section class="product-hero">
      <div class="hero-grid product-layout">
        <div class="gallery hero-media-col product-gallery">
          <nav class="breadcrumbs is-hidden" aria-label="Хлебные крошки">
            <a href="/">Главная</a>
            <span aria-hidden="true">→</span>
            <a href="/catalog">Каталог</a>
            <span aria-hidden="true">→</span>
            <span>{product.title}</span>
          </nav>
          <div class="main-img hero-media">
            <!-- Replace <img> with <video> tag when video is ready -->
            <img id="mainImg" src={gallery[0] ?? product.image} alt={`AI-диктофон ${product.title} в фирменном корпусе`} />
          </div>
          <div class="thumbs">
            {gallery.map((image, idx) => (
              <button class={`thumb ${idx === 0 ? 'active' : ''} ${idx === 1 ? 'thumb-alt' : ''}`} type="button" data-gallery-thumb data-src={image} aria-label={`Фото ${idx + 1}: ${product.title}`}>
                <img src={image} alt={`Фото ${idx + 1} продукта ${product.title}`} />
              </button>
            ))}
          </div>
          <div class="gallery-meta">
            <div class="gallery-meta-title">{product.title}</div>
            <div class="gallery-meta-sub">Официальный продукт CRYPTORO</div>
          </div>
        </div>
        <aside class="product-aside product-aside-sticky product-sidebar">
          <nav class="breadcrumbs" aria-label="Хлебные крошки">
            <a href="/">Главная</a>
            <span aria-hidden="true">→</span>
            <a href="/catalog">Каталог</a>
            <span aria-hidden="true">→</span>
            <span>{product.title}</span>
          </nav>
          <div class="badges-row">
            {product.badge && <span class="badge">{product.badge}</span>}
          </div>
          <h1 class="prod-name">{product.title}</h1>
          <p class="prod-sub">{subtitle}</p>
          {product.slug !== 'accessories' && (
            <div class="rating-row" aria-label="Рейтинг товара">
              <span class="stars">★★★★★</span>
              <span class="rating-num">4.9</span>
              <span class="rating-sep">•</span>
              <a class="rating-reviews" href="#reviews">отзывы покупателей</a>
            </div>
          )}
          <div class="price-main" data-ms-price={product.slug} data-ms-sku={primarySku} data-ms-skus={allSkusCsv}>{price} ₽</div>
          <div class="stock-pill" data-ms-stock={product.slug} data-ms-sku={primarySku} data-ms-skus={allSkusCsv}></div>
          <div class="variant-pill-list" data-ms-variants={product.slug} data-ms-sku={primarySku} data-ms-skus={allSkusCsv}></div>
          <p class="price-note">{priceNote}</p>
          <div class="param-chips">
            {paramChips.map((chip) => <span class="param-chip">{chip}</span>)}
          </div>
          {colors.length > 1 && (
            <div class="color-picker">
              <p class="color-picker-label">Цвет: <span id="selectedColorName">{colors[0]}</span></p>
              <div class="color-btns" id="colorBtns">
                {colors.map((c, i) => (
                  <button class={`color-btn${i === 0 ? ' active' : ''}`} type="button" data-color={c}>{c}</button>
                ))}
              </div>
            </div>
          )}
          <p class="prod-desc">{product.seoDescription}</p>
          <div class="trust-badges">
            <span class="tbadge">Гарантия 1 год</span>
            <span class="tbadge">Доставка по РФ</span>
            <span class="tbadge">Возврат 14 дней</span>
          </div>
          <div class="features-list">
            {heroHighlights.map((item, idx) => (
              <div class="feat-item" data-fade data-delay={String(idx)}>
                <span class="feat-check">✓</span><span>{item}</span>
              </div>
            ))}
          </div>
          <div class="actions-row">
            <button class="buy-btn buy-btn-primary" id="buyBtn" data-ms-buy-btn={product.slug} data-ms-sku={primarySku} data-ms-skus={allSkusCsv} aria-label={`Купить сейчас ${product.title}`}>{stockLabel}</button>
            <button class="buy-btn buy-btn-secondary" id="addBtn" aria-label={`Добавить в корзину ${product.title}`}>В корзину</button>
          </div>
        </aside>
      </div>
    </section>

    <section class="tabs-section">
      <div class="tabs-wrap">
        <div class="tab-content active reveal">
          <h3 class="tab-title">Описание</h3>
          <article class="md-body"><slot /></article>
        </div>
        <div class="tab-content active reveal">
          <h3 class="tab-title">Характеристики</h3>
          <table class="specs-table">
            <tbody>
              {specsRows.map((row) => (
                <tr>
                  <td>{row.label}</td>
                  <td>{row.value}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
        <div class="tab-content active reveal">
          <h3 class="tab-title">Что в коробке</h3>
          <ul class="box-list">
            {(product.boxContents ?? []).map((item) => <li>{item}</li>)}
          </ul>
        </div>
      </div>
    </section>
    <div id="reviews"></div>

    {!!related.length && (
      <section class="related-section">
        <div class="related-wrap">
          <h2 class="reveal">Похожие товары</h2>
          <div class="related-grid">
            {related.map((item, idx) => (
              <a class="rcard reveal" style={`--stagger:${idx}`} href={`/products/${item.slug}`}>
                <img src={item.image} alt={`AI-диктофон ${item.title}`} />
                <div class="rname">{item.title}</div>
                <div class="rprice" data-ms-price={item.slug}>{new Intl.NumberFormat('ru-RU').format(item.price)} ₽</div>
              </a>
            ))}
          </div>
        </div>
      </section>
    )}
  </main>

  <div class="lightbox" id="productLightbox" aria-hidden="true">
    <button type="button" class="lightbox-close" id="lightboxClose" aria-label="Закрыть просмотр">×</button>
    <img id="lightboxImg" src={gallery[0] ?? product.image} alt={`Увеличенное фото ${product.title}`} />
  </div>
  <div class="cart-toast" id="cartToast" role="status" aria-live="polite">Товар добавлен в корзину</div>

  <script define:vars={{ baseProduct: { id: product.slug, name: product.title, price: product.price, image: product.image }, hasColors: colors.length > 1 }} is:inline>
    function showToast() {
      const toast = document.getElementById('cartToast');
      if (!toast) return;
      toast.classList.add('show');
      window.setTimeout(() => toast.classList.remove('show'), 3000);
    }

    function getCartCountSafe() {
      if (window.cryptoroCart && typeof window.cryptoroCart.readItems === 'function') {
        const items = window.cryptoroCart.readItems();
        return items.reduce((sum, item) => sum + Math.max(1, Number(item?.qty) || 1), 0);
      }
      return 0;
    }

    function getSelectedColor() {
      if (!hasColors) return '';
      const btn = document.querySelector('#colorBtns .color-btn.active');
      return btn ? (btn.dataset.color || '') : '';
    }

    function buildCartItem() {
      const color = getSelectedColor();
      return {
        id: color ? baseProduct.id + '::' + color : baseProduct.id,
        name: baseProduct.name,
        price: baseProduct.price,
        image: baseProduct.image,
        qty: 1,
        color: color || undefined
      };
    }

    function addToCartItem() {
      if (window.cryptoroCart && typeof window.cryptoroCart.add === 'function') {
        window.cryptoroCart.add(buildCartItem());
      }
      const nextCount = getCartCountSafe();
      const c = document.querySelector('#cartCount, .cart-n');
      if (c) {
        c.textContent = String(nextCount);
        c.style.display = nextCount > 0 ? 'flex' : 'none';
      }
      window.dispatchEvent(new CustomEvent('cart:updated', { detail: { count: nextCount } }));
      showToast();
      const btn = document.getElementById('addBtn');
      if (!btn) return;
      const original = btn.textContent;
      btn.textContent = '✓ Добавлено';
      setTimeout(() => { btn.textContent = original ?? 'В корзину'; }, 2000);
    }

    function buyNowItem() {
      addToCartItem();
      window.location.href = '/cart';
    }

    document.addEventListener('DOMContentLoaded', () => {
      const addBtn = document.getElementById('addBtn');
      const buyBtn = document.getElementById('buyBtn');
      if (addBtn) addBtn.addEventListener('click', addToCartItem);
      if (buyBtn) buyBtn.addEventListener('click', buyNowItem);

      const colorBtns = document.getElementById('colorBtns');
      if (colorBtns) {
        colorBtns.addEventListener('click', (event) => {
          const btn = event.target.closest('.color-btn');
          if (!btn) return;
          colorBtns.querySelectorAll('.color-btn').forEach((b) => b.classList.remove('active'));
          btn.classList.add('active');
          const label = document.getElementById('selectedColorName');
          if (label) label.textContent = btn.dataset.color || '';
        });
      }
    });
  </script>

  <script>
    (function () {
      const mainImg = document.getElementById('mainImg');
      const lightbox = document.getElementById('productLightbox');
      const lightboxImg = document.getElementById('lightboxImg');
      const closeBtn = document.getElementById('lightboxClose');
      if (!mainImg || !lightbox || !lightboxImg || !closeBtn) return;

      function openLightbox(src) {
        if (src) lightboxImg.src = src;
        lightbox.style.display = 'flex';
        requestAnimationFrame(() => lightbox.classList.add('visible'));
        lightbox.setAttribute('aria-hidden', 'false');
      }

      function closeLightbox() {
        lightbox.classList.remove('visible');
        lightbox.setAttribute('aria-hidden', 'true');
        window.setTimeout(() => {
          lightbox.style.display = 'none';
        }, 200);
      }

      document.querySelectorAll('[data-gallery-thumb]').forEach((thumb) => {
        thumb.addEventListener('click', () => {
          const src = thumb.getAttribute('data-src');
          if (!src) return;
          mainImg.src = src;
          document.querySelectorAll('[data-gallery-thumb]').forEach((el) => el.classList.remove('active'));
          thumb.classList.add('active');
          openLightbox(src);
        });
      });

      mainImg.addEventListener('click', () => openLightbox(mainImg.src));
      closeBtn.addEventListener('click', closeLightbox);
      lightbox.addEventListener('click', (event) => {
        if (event.target === lightbox) closeLightbox();
      });
      document.addEventListener('keydown', (event) => {
        if (event.key === 'Escape') closeLightbox();
      });
    })();
  </script>

  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'Product',
    name: product.title,
    description: product.seoDescription,
    image: product.image,
    brand: { '@type': 'Brand', name: 'CRYPTORO' },
    offers: {
      '@type': 'Offer',
      priceCurrency: 'RUB',
      price: product.price,
      availability: product.inStock === false ? 'https://schema.org/PreOrder' : 'https://schema.org/InStock'
    }
  })} />
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Главная', item: 'https://cryptoro.ru/' },
      { '@type': 'ListItem', position: 2, name: 'Каталог', item: 'https://cryptoro.ru/catalog' },
      { '@type': 'ListItem', position: 3, name: product.title, item: `https://cryptoro.ru/products/${product.slug}` }
    ]
  })} />

  <style is:global>
    :root{
      --product-radius-lg:16px;
      --product-radius-xl:18px;
      --product-radius-2xl:20px;
      --product-shadow-sm:0 2px 12px rgba(0,0,0,.06);
      --product-shadow-md:0 4px 16px rgba(0,0,0,.06);
      --product-shadow-lg:0 8px 20px rgba(0,0,0,.14);
    }
    body{background:#f5f5f5;color:#111;font-family:'Inter',sans-serif}
    main{padding-top:56px}
    .product-page{background:#f5f5f5}
    .product-hero{padding:72px 24px 104px;background:#fff}
    .product-page .product-hero{background:#f5f5f5}
    .hero-grid{max-width:1240px;margin:0 auto;display:grid;grid-template-columns:minmax(0,1.45fr) minmax(360px,1fr);gap:32px;align-items:start}
    .product-layout{display:flex;gap:28px;align-items:flex-start}
    .product-gallery{flex:0 0 58%}
    .product-sidebar{flex:0 0 42%;min-width:0}
    .breadcrumbs{display:flex;align-items:center;gap:8px;margin-bottom:16px;font-size:13px;color:#6b7280;line-height:1.3;flex-wrap:wrap}
    .breadcrumbs.is-hidden{display:none}
    .breadcrumbs a{text-decoration:none;color:#374151}
    .breadcrumbs a:hover{color:#111}
    .main-img{width:100%;aspect-ratio:1;background:#f6f6f6;border-radius:var(--product-radius-xl);overflow:hidden;display:flex;align-items:center;justify-content:center;border:1px solid rgba(17,24,39,.08);box-shadow:var(--product-shadow-md);position:relative}
    .main-img img{width:100%;height:100%;object-fit:contain;padding:16px;cursor:zoom-in}
    .hero-media{aspect-ratio:1/1;min-height:680px}
    .hero-media img{width:78%;max-width:780px;padding:0;transition:transform .45s ease}
    .hero-media:hover img{transform:scale(1.04)}
    .thumbs{display:flex;gap:12px;margin-top:14px;flex-wrap:wrap;align-items:center}
    .thumb{border:1px solid rgba(0,0,0,.12);border-radius:12px;background:#fff;padding:8px;cursor:pointer;transition:all .2s ease;display:flex;align-items:center;justify-content:center}
    .thumb.active{border:2px solid #e88635;box-shadow:0 4px 14px rgba(0,0,0,.08)}
    .thumb img{width:60px;height:60px;object-fit:contain;display:block}
    .thumb-alt img{transform:scaleX(-1) rotate(-7deg)}
    .gallery-meta{margin-top:16px;border:1px solid rgba(17,24,39,.1);border-radius:var(--product-radius-lg);padding:14px 16px;background:#fff;box-shadow:var(--product-shadow-sm)}
    .gallery-meta-title{font-size:24px;font-family:'Unbounded',sans-serif;letter-spacing:-.02em;margin-bottom:4px}
    .gallery-meta-sub{font-size:14px;color:#6b7280}
    .badges-row{display:flex;gap:8px;margin-bottom:14px;flex-wrap:wrap}
    .badge{background:#e88635;color:#fff;border:1px solid #d57728;border-radius:20px;padding:6px 14px;font-size:11px;font-weight:700;letter-spacing:.08em;text-transform:uppercase}
    .prod-name{font-family:'Unbounded',sans-serif;font-size:clamp(34px,4.2vw,42px);line-height:1.06;letter-spacing:-.03em;margin:0 0 10px;word-break:break-word}
    .prod-sub{font-size:clamp(17px,1.8vw,22px);line-height:1.45;color:#4b5563;max-width:34ch;margin:0 0 8px;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden}
    .rating-row{display:flex;align-items:center;gap:8px;margin:8px 0 6px}
    .stars{font-size:14px;letter-spacing:.06em;color:#f59e0b}
    .rating-num{font-size:14px;font-weight:700;color:#111}
    .rating-sep{font-size:13px;color:#9ca3af}
    .rating-reviews{font-size:14px;color:#6b7280;text-decoration:none}
    .rating-reviews:hover{color:#111}
    .price-main{font-family:'Unbounded',sans-serif;font-size:clamp(38px,4.8vw,48px);line-height:1.08;letter-spacing:-.02em;margin:14px 0 6px}
    .stock-pill{
      display:none;
      align-items:center;
      justify-content:center;
      margin:-2px 0 10px;
      padding:6px 10px;
      width:max-content;
      font-size:12px;
      font-weight:700;
      color:#b45309;
      background:#fff7ed;
      border:1px solid #fdba74;
      border-radius:999px;
      letter-spacing:.02em;
      text-transform:uppercase;
    }
    .price-note{margin:-2px 0 12px;color:#6b7280;font-size:14px;line-height:1.45}
    .param-chips{display:flex;flex-wrap:wrap;gap:8px;margin:8px 0 14px}
    .param-chip{display:inline-flex;align-items:center;border:1px solid rgba(17,24,39,.1);background:#e8e8e8;border-radius:8px;padding:8px 16px;font-size:13px;font-weight:600;color:#374151}
    .color-picker{margin:0 0 16px}
    .color-picker-label{font-size:14px;font-weight:600;color:#111;margin:0 0 10px}
    .color-picker-label span{font-weight:400;color:#4b5563}
    .color-btns{display:flex;flex-wrap:wrap;gap:8px}
    .color-btn{height:36px;padding:0 14px;border-radius:20px;border:1.5px solid rgba(17,24,39,.15);background:#fff;color:#374151;font-size:13px;font-weight:500;cursor:pointer;transition:all .18s ease;line-height:1}
    .color-btn:hover:not([disabled]){border-color:rgba(17,24,39,.4);color:#111}
    .color-btn.active{border-color:#111;background:#111;color:#fff}
    .color-btn[disabled]{opacity:.38;cursor:not-allowed;text-decoration:line-through}
    .color-btn.is-preorder{opacity:.7;border-style:dashed}
    .color-btn.is-low{border-color:#f59e0b}
    .color-stock{font-size:10px;margin-left:5px;opacity:.65;font-weight:400}
    .prod-desc{margin:0 0 16px;color:#4b5563;line-height:1.65;font-size:16px}
    .trust-badges{display:block;white-space:nowrap;overflow-x:auto;overflow-y:hidden;margin-bottom:20px;padding-bottom:2px}
    .tbadge{display:inline;background:none;border:none;padding:0;margin:0;color:#4b5563;font-size:13px;font-weight:500}
    .tbadge::after{content:' · ';color:#9ca3af}
    .tbadge:last-child::after{content:''}
    .features-list{margin:18px 0 18px}
    .feat-item{display:flex;gap:10px;padding:10px 0;border-bottom:1px solid rgba(0,0,0,.12);font-size:15px;line-height:1.45;align-items:flex-start}
    .feat-item:last-child{border-bottom:none}
    .feat-check{color:#111}

    /* Stagger delays for feature items */
    .feat-item[data-delay="0"].fade-in{transition-delay:0s}
    .feat-item[data-delay="1"].fade-in{transition-delay:.08s}
    .feat-item[data-delay="2"].fade-in{transition-delay:.16s}
    .feat-item[data-delay="3"].fade-in{transition-delay:.24s}
    .feat-item[data-delay="4"].fade-in{transition-delay:.32s}

    /* Stagger delays for related cards */
    .rcard[style*="--stagger:0"].fade-in{transition-delay:0s}
    .rcard[style*="--stagger:1"].fade-in{transition-delay:.1s}
    .rcard[style*="--stagger:2"].fade-in{transition-delay:.2s}

    .actions-row{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:10px;margin-top:8px}

    /* Primary CTA: Купить сейчас */
    .buy-btn{display:flex;align-items:center;justify-content:center;width:100%;border:none;border-radius:14px;padding:11px 14px;min-height:48px;font-size:14px;font-weight:600;line-height:1.2;white-space:nowrap;cursor:pointer;margin-bottom:0;transition:all .2s ease-out;text-align:center}
    .buy-btn-primary{background:#111;color:#fff;box-shadow:0 2px 8px rgba(0,0,0,.12)}
    .buy-btn-primary:hover{transform:translateY(-2px);box-shadow:0 8px 22px rgba(0,0,0,.22)}
    .buy-btn-primary:active{transform:translateY(0) scale(.995);box-shadow:0 2px 8px rgba(0,0,0,.12)}
    .buy-btn-primary:focus-visible{outline:none;box-shadow:0 0 0 3px rgba(17,17,17,.18),0 8px 20px rgba(0,0,0,.14)}

    /* Secondary: В корзину */
    .buy-btn-secondary{background:#fff;color:#111;border:1.5px solid rgba(17,24,39,.18)}
    .buy-btn-secondary:hover{transform:translateY(-1px);box-shadow:0 4px 12px rgba(0,0,0,.1);border-color:rgba(17,24,39,.38)}
    .buy-btn-secondary:active{transform:translateY(0) scale(.995)}
    .buy-btn-secondary:focus-visible{outline:none;box-shadow:0 0 0 3px rgba(232,134,53,.22)}

    .buy-btn.is-disabled,[data-ms-buy-btn].is-disabled{opacity:.55!important;cursor:not-allowed!important;box-shadow:none!important;transform:none!important}

    .secondary-btn{display:block;width:100%;background:rgba(255,255,255,.9);color:#111;border:1.5px solid rgba(0,0,0,.2);border-radius:14px;padding:12px 15px;font-size:14px;font-weight:500;text-align:center;text-decoration:none;backdrop-filter:blur(20px);transition:all .2s ease-out}
    .secondary-btn:hover{background:#fff;box-shadow:0 6px 16px rgba(0,0,0,.08)}
