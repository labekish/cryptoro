    .pdp-benefits{background:var(--pdp-surface);padding:40px 0 0;border-top:1px solid rgba(0,0,0,.06)}
    .pdp-benefits__grid{display:flex;justify-content:center;gap:48px;max-width:700px;margin:0 auto}
    .pdp-benefit{background:none;border:none;border-radius:0;padding:0;text-align:center;box-shadow:none;transition:none;white-space:nowrap}
    .pdp-benefit__text{font-size:15px;font-weight:600;color:var(--pdp-text);line-height:1.4;letter-spacing:-.01em}

    /* ===== 3. Editorial ===== */
    .pdp-editorial{background:var(--pdp-surface);padding:88px 0 72px}
    .pdp-editorial__grid{display:grid;grid-template-columns:1fr 1fr;gap:48px;align-items:center}
    .pdp-editorial__lead{font-size:20px;line-height:1.65;color:#4b5563;margin:0 0 16px}
    .pdp-editorial__body{font-size:18px;color:#4b5563;line-height:1.72}
    .pdp-editorial__body p{margin:0 0 20px}
    .pdp-editorial__body p:last-child{margin-bottom:0}
    .pdp-editorial__image{border-radius:20px;overflow:hidden}
    .pdp-editorial__image img{width:100%;height:100%;object-fit:cover;display:block;border-radius:20px}

    /* ===== 4. Key Specs — typographic 3-col row ===== */
    .pdp-key-specs{background:transparent!important;padding:0!important}
    .pdp-key-specs--overlap{position:relative;z-index:2}
    .section-parameters-wrapper{max-width:1120px;margin:16px auto 0;padding:0 24px}
    .pdp-key-specs--overlap .section-parameters-wrapper{margin:-80px auto 120px;padding:0 24px}
    .parameters-panel{
      background:#fff;
      border-radius:18px;
      border:1px solid rgba(0,0,0,.06);
      padding:72px 64px;
      box-shadow:0 6px 18px rgba(0,0,0,.025)
    }
    .parameters-panel .pdp-section-title{margin-bottom:36px}
    .pdp-key-specs__grid{
      display:grid;
      grid-template-columns:repeat(3,minmax(0,1fr));
      gap:48px;
      align-items:center;
      justify-content:space-between;
      max-width:none;
      margin:0
    }
    .pdp-spec-card{background:none;border:none;border-radius:0;padding:0;text-align:center;box-shadow:none;transition:none;position:relative}
    /* no vertical dividers — spacing only */
    .pdp-spec-card__value{display:flex;align-items:flex-end;justify-content:center;gap:.08em .2em;flex-wrap:wrap;margin-bottom:8px;white-space:nowrap}
    .pdp-spec-card__num{font-family:'Unbounded',sans-serif;font-size:clamp(40px,4vw,56px);font-weight:700;line-height:1.02;letter-spacing:-.03em;color:var(--pdp-text)}
    .pdp-spec-card__unit{font-size:13px;font-weight:600;letter-spacing:-.01em;color:var(--pdp-muted);margin-left:0;line-height:1.15;padding-bottom:.32em}
    .pdp-spec-card__prefix{font-size:12px;font-weight:600;color:var(--pdp-muted);margin-right:0;line-height:1.05;padding-bottom:.42em}
    .pdp-spec-card__text{font-family:'Unbounded',sans-serif;font-size:clamp(15px,1.9vw,20px);font-weight:600;letter-spacing:-.015em;color:var(--pdp-text);line-height:1.2}
    .pdp-spec-card__label{display:block;font-size:13px;color:rgba(17,17,17,.8);font-weight:600;text-transform:none;letter-spacing:.01em;line-height:1.25;opacity:.6;margin-top:8px}

    /* ===== 5+6. Details — unified specs + box section ===== */
    .pdp-details{background:var(--pdp-surface);padding:64px 0 56px}
    /* Accordion — spacing only, no borders */
    .pdp-accordion{border:none;border-radius:0;overflow:hidden}
    .pdp-accordion__trigger{display:flex;align-items:center;justify-content:space-between;padding:24px 0;cursor:pointer;list-style:none;user-select:none}
    .pdp-accordion__trigger::-webkit-details-marker{display:none}
    .pdp-accordion__trigger .pdp-section-title{margin:0}
    .pdp-accordion__icon{font-size:24px;font-weight:300;color:var(--pdp-muted);transition:transform .2s ease;flex-shrink:0;width:32px;height:32px;display:flex;align-items:center;justify-content:center;border-radius:50%;background:none}
    .pdp-accordion__body{padding:0 0 24px}
    .pdp-specs-table{width:100%;border-collapse:collapse;border-spacing:0;overflow:hidden;border-radius:0;border:none;display:block}
    .pdp-specs-table tbody{display:block}
    .pdp-specs-table tr{display:grid;grid-template-columns:1fr auto;align-items:start;gap:20px;padding:24px 0}
    .pdp-specs-table td{border-bottom:none;padding:0;overflow-wrap:anywhere;background:none!important;display:block}
    .pdp-specs-table tr:last-child td{border-bottom:none}
    .pdp-specs-table td:first-child{color:var(--pdp-muted);width:auto;font-size:13px;font-weight:600;text-transform:none;letter-spacing:.01em;opacity:.6}
    .pdp-specs-table td:last-child{color:var(--pdp-text);font-size:15px;font-weight:700;text-align:right}
    /* Box contents inside accordion */
    /* Box / Комплект — таблица как у спек */
    .pdp-box-table{width:100%;border-collapse:collapse;border-spacing:0}
    .pdp-box-table td{border-bottom:1px solid rgba(0,0,0,.04);padding:16px 0;background:none!important;vertical-align:middle}
    .pdp-box-table tr:last-child td{border-bottom:none}
    .pdp-box-table td:first-child{width:32px;color:var(--pdp-muted)}
    .pdp-box-table td:last-child{padding-left:14px;font-size:15px;font-weight:400;color:var(--pdp-text)}

    /* ===== 7. Model Comparison — lighter ===== */
    .pdp-compare{background:var(--pdp-bg)!important;padding:96px 0}
    .pdp-compare__grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(250px,1fr));gap:20px}
    .pdp-compare-card{display:flex;flex-direction:column;align-items:center;text-align:center;background:var(--pdp-surface);border:1px solid rgba(0,0,0,.07);border-radius:20px;padding:34px 24px;text-decoration:none;color:inherit;transition:transform .3s ease,box-shadow .3s ease;box-shadow:0 2px 8px rgba(0,0,0,.04)}
    .pdp-compare-card--current{transform:scale(1.03);border-color:rgba(0,0,0,.1);box-shadow:0 8px 32px rgba(0,0,0,.1)}
    .pdp-compare-card__badge{display:inline-block;background:var(--pdp-text);color:#fff;border-radius:20px;padding:4px 12px;font-size:10px;font-weight:700;letter-spacing:.06em;text-transform:uppercase;margin-bottom:16px}
    .pdp-compare-card img{width:100%;max-width:196px;height:172px;object-fit:contain;margin-bottom:18px}
    .pdp-compare-card h3{font-family:'Unbounded',sans-serif;font-size:17px;font-weight:700;margin:0 0 6px;letter-spacing:-.01em}
    .pdp-compare-card__price{font-size:19px;font-weight:700;margin-bottom:12px;display:block}
    .pdp-compare-card__specs{list-style:none;padding:0;margin:0;font-size:13px;color:var(--pdp-muted);line-height:1.8}
    .pdp-compare-card__specs strong{color:var(--pdp-text);font-weight:600}
    .pdp-compare-card__cta{display:inline-flex;align-items:center;justify-content:center;margin-top:auto;padding:10px 24px;background:#111;color:#fff;border-radius:12px;font-size:14px;font-weight:600;transition:all .2s ease}

    /* ===== 8. Trust Bar ===== */
    .pdp-trust{background:var(--pdp-surface);padding:32px 0 48px;border-top:1px solid rgba(0,0,0,.06)}
    .pdp-trust__row{display:flex;align-items:center;justify-content:center;gap:16px;font-size:13px;color:var(--pdp-muted);font-weight:500}
    .pdp-trust__sep{color:rgba(0,0,0,.15)}

    /* ===== AI Capability Dark Section ===== */
    .pdp-ai-dark{background:#111!important;padding:80px 0}
    .pdp-ai-dark .pdp-container{max-width:720px;text-align:center}
    .pdp-ai-dark__kicker{font-size:11px;font-weight:600;letter-spacing:.14em;text-transform:uppercase;color:rgba(255,255,255,.35);margin:0 0 20px;font-family:'Inter',sans-serif}
    .pdp-ai-dark__headline{font-family:'Unbounded',sans-serif;font-size:clamp(28px,3.8vw,48px);font-weight:800;line-height:1.12;letter-spacing:-.035em;color:#fff;margin:0 0 40px}
    .pdp-ai-dark__list{list-style:none;padding:0;margin:0;display:flex;justify-content:center;align-items:center;flex-wrap:nowrap;gap:0}
    .pdp-ai-dark__item{padding:0 30px;font-size:clamp(16px,1.55vw,19px);font-weight:550;color:rgba(255,255,255,.82);line-height:1.4;letter-spacing:-.01em;white-space:nowrap}
    .pdp-ai-dark__item:not(:first-child){border-left:1px solid rgba(255,255,255,.2)}

    /* ===== Sticky Buy Bar ===== */
    .pdp-sticky-bar{display:none;position:fixed;bottom:0;left:0;right:0;z-index:90;background:rgba(255,255,255,.95);backdrop-filter:blur(20px);border-top:1px solid rgba(0,0,0,.08);transform:translateY(100%);transition:transform .3s ease;pointer-events:none;padding-bottom:env(safe-area-inset-bottom,0px)}
    .pdp-sticky-bar--visible{transform:translateY(0);pointer-events:auto}
    .pdp-sticky-bar__inner{max-width:980px;margin:0 auto;padding:12px 24px;display:flex;align-items:center;justify-content:space-between;gap:16px}
    /* Bottom padding so last section isn't hidden under sticky bar */
    .pdp { padding-bottom: 0 }
    .pdp-sticky-bar__info{display:flex;flex-direction:column;gap:2px;min-width:0}
    .pdp-sticky-bar__name{font-size:14px;font-weight:600;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
    .pdp-sticky-bar__meta{font-size:11px;font-weight:500;color:var(--pdp-muted);white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
    .pdp-sticky-bar__price{font-size:16px;font-weight:700}

    /* ===== Lightbox ===== */
    .lightbox{position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,.85);display:none;align-items:center;justify-content:center;z-index:1000;padding:20px;opacity:0;transition:opacity .2s ease}
    .lightbox.visible{opacity:1}
    .lightbox img{max-width:90vw;max-height:90vh;object-fit:contain;border-radius:16px;background:#fff;padding:10px}
    .lightbox-close{position:absolute;top:18px;right:18px;width:42px;height:42px;border-radius:999px;border:1px solid rgba(255,255,255,.4);background:rgba(0,0,0,.35);color:#fff;font-size:30px;line-height:1;cursor:pointer}

    /* ===== Cart Toast ===== */
    .cart-toast{position:fixed;right:18px;bottom:22px;background:#111;color:#fff;padding:12px 16px;border-radius:12px;font-size:14px;font-weight:600;box-shadow:0 10px 24px rgba(0,0,0,.22);opacity:0;transform:translateY(10px);pointer-events:none;transition:all .24s ease;z-index:310}
    .cart-toast.show{opacity:1;transform:translateY(0)}

    /* ===== Stagger Animations ===== */
    .pdp-benefit[style*="--stagger"]{transition-delay:calc(var(--stagger) * 60ms)}
    .pdp-spec-card[style*="--stagger"]{transition-delay:calc(var(--stagger) * 60ms)}
    .pdp-box-item[style*="--stagger"]{transition-delay:calc(var(--stagger) * 60ms)}
    .pdp-compare-card[style*="--stagger"]{transition-delay:calc(var(--stagger) * 80ms)}

    /* ===== Hover (desktop only) ===== */
    @media(hover:hover){
      .pdp-compare-card:not(.pdp-compare-card--current):hover{transform:translateY(-3px);box-shadow:0 8px 24px rgba(0,0,0,.08)}
    }

    /* ===== Responsive: Tablet ===== */
    @media(max-width:980px){
      .pdp-sticky-bar{display:block}
      .pdp { padding-bottom: calc(64px + env(safe-area-inset-bottom,0px)) }
      .pdp-editorial__grid{grid-template-columns:1fr;gap:32px}
      .pdp-editorial__image{max-height:400px}
      .pdp-compare__grid{grid-template-columns:repeat(2,1fr)}
    }

    /* ===== Responsive: Mobile ===== */
    @media(max-width:640px){
      .pdp-container{padding:0 18px}
      .pdp-hero{padding:84px 0 28px}
      .pdp-hero__keyspecs{max-width:100%;border-radius:12px}
      .pdp-hero__keyspec-item{padding:10px 6px}
      .pdp-hero__keyspec-num{font-size:12px}
      .pdp-hero__keyspec-text{font-size:9px}
      .pdp-hero__keyspec-label{font-size:8px}
      .pdp-hero__title{
        font-size:clamp(30px,9.6vw,42px);
        line-height:1.06;
        letter-spacing:-.025em;
        overflow-wrap:anywhere;
        word-break:break-word;
      }
      .pdp-hero__price{font-size:clamp(28px,7vw,36px)}
      .pdp-hero__colors{margin-top:10px}
      .pdp-hero__color-btns{gap:8px}
      .color-btn{min-height:38px;padding:6px 10px 6px 8px}
      .color-btn__swatch{width:14px;height:14px;flex-basis:14px}
      .pdp-hero__media{margin-top:12px}
      .pdp-hero__main-img img{width:92%;max-width:440px}
      .pdp-hero__thumbs{flex-wrap:nowrap;overflow-x:auto;justify-content:flex-start;padding:0 18px 4px}
      .pdp-hero__thumbs::-webkit-scrollbar{height:6px}
      .pdp-hero__thumbs::-webkit-scrollbar-thumb{background:rgba(17,24,39,.16);border-radius:999px}
      .pdp-thumb{flex:0 0 auto}
      .pdp-hero__actions{flex-direction:column;max-width:100%;padding:0 18px;margin-top:14px!important}
      .pdp-btn{width:100%;flex:initial}
      .pdp-section-title{font-size:clamp(22px,5.5vw,26px);margin-bottom:20px}
      .pdp-ai-dark{padding:64px 0}
      .pdp-ai-dark__headline{font-size:clamp(24px,7vw,34px);margin-bottom:32px}
      .pdp-ai-dark__list{
        flex-direction:column;
        align-items:stretch;
        gap:0;
        max-width:260px;
        margin:0 auto;
      }
      .pdp-ai-dark__item{
        font-size:14px;
        padding:12px 0;
        white-space:normal;
        text-align:center;
      }
      .pdp-ai-dark__item:not(:first-child){
        border-left:none;
        border-top:1px solid rgba(255,255,255,.14);
      }
      .pdp-benefits__grid{gap:24px}
      .section-parameters-wrapper{margin:20px auto 0;padding:0 24px}
      .pdp-key-specs--overlap .section-parameters-wrapper{margin:-56px auto 88px;padding:0 24px}
      .parameters-panel{padding:56px 40px;border-radius:18px}
      .parameters-panel .pdp-section-title{margin-bottom:30px}
      .pdp-key-specs__grid{max-width:100%;grid-template-columns:repeat(3,1fr)!important;gap:32px!important}
      .pdp-editorial{padding:56px 0 48px}
      .pdp-editorial__lead{font-size:17px}
      .pdp-editorial__body{font-size:16px}
      .section-parameters-wrapper{margin:12px auto 0;padding:0 24px}
      .pdp-key-specs--overlap .section-parameters-wrapper{margin:-8px auto 64px;padding:0 24px}
      .parameters-panel{padding:56px 24px 48px;border-radius:16px}
      .parameters-panel .pdp-section-title{margin-bottom:20px}
      .pdp-key-specs{padding:0!important}
      .pdp-key-specs__grid{grid-template-columns:1fr!important;gap:32px!important}
      .pdp-spec-card{padding:0!important}
      .pdp-spec-card__num{font-size:clamp(22px,6vw,30px)}
      .pdp-spec-card__text{font-size:clamp(13px,3.5vw,17px)}
      .pdp-details{padding:56px 0 48px}
      .pdp-full-specs{padding:40px 0}
      .pdp-box{padding:40px 0}
      .pdp-compare{padding:56px 0}
      .pdp-compare__grid{grid-template-columns:1fr}
      .pdp-compare-card--current{transform:none}
      .pdp-accordion__trigger{padding:18px 0}
      .pdp-accordion__body{padding:0 0 20px}
      .pdp-trust__row{flex-direction:column;gap:8px}
      .pdp-trust__sep{display:none}
    }

    /* ===== Responsive: Small phones ===== */
    @media(max-width:390px){
      .pdp-container{padding:0 16px}
      .pdp-hero{padding:76px 0 28px}
      .pdp-hero__keyspecs{grid-template-columns:repeat(2,1fr)}
      .pdp-hero__keyspec-item:nth-child(odd){border-right:1px solid rgba(0,0,0,.08)}
      .pdp-hero__keyspec-item:nth-child(even){border-right:none}
      .pdp-hero__keyspec-item:nth-child(-n+2){border-bottom:1px solid rgba(0,0,0,.08)}
      .pdp-hero__main-img img{width:94%;max-width:320px}
      .pdp-thumb img{width:44px;height:44px}
      .pdp-thumb{padding:5px}
      .pdp-benefits__grid{flex-direction:column;gap:16px}
      .pdp-key-specs__grid{grid-template-columns:1fr!important;gap:28px!important}
      .pdp-spec-card{padding:0!important;border-right:none!important;border-bottom:none!important}
    }

    /* ── PDP Fixes ── */

    /* A. Hero: remove fixed aspect-ratio — image sets its own height */
    .pdp-hero__media { margin: 8px auto 0 !important }
    .pdp-hero__main-img { aspect-ratio: auto !important }
    .pdp-hero__main-img img { object-position: center center }

    /* B. CTA: tighter gap to photo, wider buttons */
    .pdp-hero__actions { max-width: 500px !important; margin-top: 12px !important }

    /* C. Mini trust line in hero */
    .pdp-hero__trust {
      margin: 14px auto 0;
      font-size: 12px;
      color: var(--pdp-muted) !important;
      font-weight: 400;
      letter-spacing: .01em;
    }

    /* D. Thumbnails */
    .pdp-thumb img { width: 64px !important; height: 64px !important }

    /* E. Fix Layout.astro global colour overrides */
    .pdp-hero__price { color: #1d1d1f !important }
    .pdp-hero__currency { color: var(--pdp-muted) !important }
    .pdp-spec-card__num { color: var(--pdp-text) !important }
    .pdp-compare-card__price { color: var(--pdp-text) !important }
    .pdp-sticky-bar__price { color: var(--pdp-text) !important }
    /* Dark section: override global h2/p/li colour rules */
    .pdp-ai-dark__kicker { color: rgba(255,255,255,.35) !important }
    .pdp-ai-dark__headline { color: #fff !important }
    .pdp-ai-dark__item { color: rgba(255,255,255,.82) !important; font-weight: 550 !important }

    /* F. Spec card unit: allow multi-word units to wrap, cap width */
    .pdp-spec-card__value { flex-wrap: wrap !important; gap: .08em .2em !important; align-items: flex-end !important }
    .pdp-spec-card__prefix { font-size: 12px !important; line-height: 1.05 !important; padding-bottom: .42em !important; font-weight: 600 !important }
    .pdp-spec-card__unit { font-size: 13px !important; white-space: normal !important; max-width: 18ch; line-height: 1.15 !important; text-align: center; padding-bottom: .32em !important }

    /* ── 1. Key specs: floating premium panel ── */
    .pdp-key-specs { background: transparent !important; padding: 0 !important }
    .pdp-key-specs--overlap { position: relative !important; z-index: 2 !important }
    .section-parameters-wrapper { max-width: 1120px !important; margin: 16px auto 0 !important; padding: 0 24px !important }
    .pdp-key-specs--overlap .section-parameters-wrapper { margin: -80px auto 120px !important; padding: 0 24px !important }
    .parameters-panel {
      background: #fff !important;
      border-radius: 18px !important;
      border: 1px solid rgba(0,0,0,.06) !important;
      padding: 72px 64px !important;
      box-shadow: 0 6px 18px rgba(0,0,0,.025) !important;
    }
    .parameters-panel .pdp-section-title { margin-bottom: 36px !important }
    .pdp-key-specs__grid {
      max-width: none !important;
      gap: 48px !important;
      grid-template-columns: repeat(3, minmax(0,1fr)) !important;
      align-items: center !important;
      justify-content: space-between !important;
    }
    .pdp-spec-card {
      padding: 0 !important;
      border: none !important;
      display: flex !important;
      flex-direction: column !important;
      justify-content: center !important;
    }
    .pdp-spec-card__num { font-size: clamp(40px, 4vw, 56px) !important; font-weight: 700 !important; line-height: 1.02 !important; letter-spacing: -.03em !important }
    .pdp-spec-card__label { text-transform: none !important; letter-spacing: .01em !important; font-size: 13px !important; font-weight: 600 !important; color: rgba(17,17,17,.8) !important; line-height: 1.25 !important; opacity: .6 !important; margin-top: 8px !important }

    /* ── 2. Editorial: text-only, single column, generous width ── */
    .pdp-editorial { padding: 64px 0 56px !important }
    .pdp-editorial__copy { max-width: 680px }
    .pdp-editorial__lead { font-size: 19px !important; color: #4b5563 !important }
    .pdp-editorial__body { font-size: 17px !important; color: #5a5a5f !important }

    /* ── 3. Specs table: editorial feel, not spec-sheet ── */
    .pdp-details { padding: 64px 0 56px !important }
    .pdp-specs-table { display: block !important; border: none !important }
    .pdp-specs-table tbody { display: block !important }
    .pdp-specs-table tr {
      display: grid !important;
      grid-template-columns: 1fr auto !important;
      align-items: start !important;
      gap: 20px !important;
      padding: 24px 0 !important;
    }
    .pdp-specs-table td { padding: 0 !important; border-bottom: none !important; display: block !important }
    .pdp-specs-table td:first-child {
      color: rgba(0,0,0,.38) !important;
      font-size: 13px !important;
      font-weight: 600 !important;
      text-transform: none !important;
      letter-spacing: .01em !important;
      opacity: .6 !important;
      width: auto !important;
    }
    .pdp-specs-table td:last-child { font-size: 15px !important; font-weight: 700 !important; color: #111 !important; text-align: right !important }
    .pdp-accordion { border: none !important }

    /* ── 4. Box item icons ── */
    .pdp-box-table td { padding: 18px 0 !important; border-bottom: 1px solid rgba(0,0,0,.03) !important }
    .pdp-box-table tr:last-child td { border-bottom: none !important }
    .pdp-box-table td:last-child { font-size: 15px !important; font-weight: 400 !important }
    .pdp-compare-card__specs { display: none !important }

    /* ── 5. Compare: current dominant, secondary muted ── */
    .pdp-compare { background: var(--pdp-bg) !important; padding: 72px 0 !important }
    .pdp-compare__grid {
      grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)) !important;
      gap: 20px !important;
    }
    .pdp-compare-card--current {
      background: #fafaf8 !important;
      border: 2px solid #111 !important;
      transform: none !important;
