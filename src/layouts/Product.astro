    /* Actions */
    .pdp-hero__actions{display:flex;gap:12px;justify-content:center;margin-top:14px;max-width:520px;margin-left:auto;margin-right:auto}

    /* ===== Button System ===== */
    .pdp-btn{display:inline-flex;align-items:center;justify-content:center;border:none;border-radius:14px;padding:14px 32px;min-height:52px;font:600 15px/1.2 'Inter',sans-serif;cursor:pointer;transition:all .2s ease-out;text-align:center;white-space:nowrap;flex:1}
