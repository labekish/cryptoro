---
import Layout from './Layout.astro';

interface ProductData {
  title: string;
  slug: string;
  sku?: string;
  skus?: string[];
  price: number;
  badge?: string;
  image: string;
  inStock?: boolean;
  subtitle?: string;
  priceNote?: string;
  paramChips?: string[];
  seoTitle?: string;
  seoDescription?: string;
  features?: string[];
  specs?: {
    color?: string;
    dimensions?: string;
    weight?: string;
    memory?: string;
    battery?: string;
    languages?: string;
    format?: string;
    connection?: string;
    warranty?: string;
    [key: string]: string | undefined;
  };
  boxContents?: string[];
  gallery?: string[];
  colors?: string[];
  colorImages?: Record<string, string>;
  heroKeySpecs?: boolean;
  editorialLead?: string;
  editorialHeadline?: string;
  editorialSupportline?: string;
  editorialImage?: string;
  editorialImageAlt?: string;
  editorialCinematicHeadline?: string;
  editorialCinematicImage?: string;
  editorialCinematicImageAlt?: string;
  editorialSecondaryImage?: string;
  editorialSecondaryImageAlt?: string;
  editorialHighlights?: Array<{ title: string; text: string }>;
  editorialUseCases?: Array<{ title: string; text: string }>;
}

interface RelatedItem {
  slug: string;
  title: string;
  price: number;
  image: string;
}

interface Props {
  product: ProductData;
  related?: RelatedItem[];
}

const { product, related = [] } = Astro.props;
const price = new Intl.NumberFormat('ru-RU').format(product.price);
const stockLabel = product.inStock === false ? 'Предзаказ' : 'Купить сейчас';
const allSkus = Array.from(new Set([...(Array.isArray(product.skus) ? product.skus : []), ...(product.sku ? [product.sku] : [])]));
const primarySku = allSkus[0] ?? '';
const allSkusCsv = allSkus.join(',');

const gallery = (product.gallery && product.gallery.length ? product.gallery : [product.image]).filter(Boolean);

const specsRows = [
  { label: 'Размеры', value: product.specs?.dimensions },
  { label: 'Вес', value: product.specs?.weight },
  { label: 'Память', value: product.specs?.memory },
  { label: 'Автономность', value: product.specs?.battery },
  { label: 'Языки', value: product.specs?.languages },
  { label: 'Форматы файлов', value: product.specs?.format },
  { label: 'Цвет', value: product.specs?.color },
  { label: 'Подключение', value: product.specs?.connection },
  { label: 'Гарантия', value: product.specs?.warranty }
].filter((row) => row.value);

const keySpecs = [
  { label: 'Память', value: product.specs?.memory },
  { label: 'Автономность', value: product.specs?.battery },
  { label: 'Вес', value: product.specs?.weight },
  { label: 'Размеры', value: product.specs?.dimensions },
  { label: 'Языки', value: product.specs?.languages },
].filter((s): s is { label: string; value: string } => !!s.value).slice(0, 3);

function parseSpecDisplay(val: string): { prefix: string; num: string; unit: string } {
  const m = val.match(/^([^\d]*)(\d+(?:[.,]\d+)?)(.*)$/);
  if (m && m[2]) {
    return { prefix: (m[1] ?? '').trim(), num: m[2], unit: (m[3] ?? '').trim() };
  }
  return { prefix: '', num: '', unit: val };
}
const keySpecsParsed = keySpecs.map(s => ({ ...s, parsed: parseSpecDisplay(s.value) }));

const subtitle = product.subtitle ?? 'AI-устройство CRYPTORO';
const priceNote = product.priceNote ?? '';
const paramChips = product.paramChips ?? [];
const colors = product.colors ?? [];
const skus = product.skus ?? (product.sku ? [product.sku] : []);
// Маппинг цвет → SKU по порядку индексов (colors[i] → skus[i]).
const colorSkus: Record<string, string> = {};
colors.forEach((c, i) => { if (skus[i]) colorSkus[c] = skus[i]; });
const baseSku = product.sku ?? skus[0] ?? '';
const editorialHighlights = product.editorialHighlights ?? [];
const editorialUseCases = product.editorialUseCases ?? [];

function cleanLine(value: string): string {
  return String(value || '')
    .replace(/\s+/g, ' ')
    .trim()
    .replace(/[.!?…]+$/g, '');
}

function truncateLine(value: string, max = 110): string {
  const line = String(value || '').replace(/\s+/g, ' ').trim();
  if (line.length <= max) return line;
  return `${line.slice(0, max - 1).trimEnd()}…`;
}

const featureTitles = (product.features ?? []).map((item) => cleanLine(item)).filter(Boolean);
const headlineFeature = featureTitles[0] ?? '';
const cinematicFeatureA = featureTitles[0] ?? '';
const cinematicFeatureB = featureTitles[1] ?? '';
const fallbackEditorialHeadline = headlineFeature
  ? `${product.title}.\n${headlineFeature}.`
  : product.title;
const fallbackEditorialSupportline = truncateLine(
  product.seoDescription || subtitle || product.editorialLead || '',
  120
);
const fallbackCinematicHeadline = cinematicFeatureA && cinematicFeatureB
  ? `${cinematicFeatureA}.\n${cinematicFeatureB}.`
  : cinematicFeatureA
    ? `${product.title}.\n${cinematicFeatureA}.`
    : `${product.title}.\n${cleanLine(subtitle) || 'Для повседневного использования'}.`;

const editorialHeadline = product.editorialHeadline ?? product.editorialLead ?? fallbackEditorialHeadline;
const editorialSupportline = product.editorialSupportline ?? fallbackEditorialSupportline;
const editorialCinematicHeadline = product.editorialCinematicHeadline ?? fallbackCinematicHeadline;
const editorialCinematicImage = product.editorialCinematicImage ?? product.editorialSecondaryImage ?? product.editorialImage ?? gallery[0] ?? product.image;
const editorialCinematicImageAlt = product.editorialCinematicImageAlt ?? product.editorialSecondaryImageAlt ?? product.editorialImageAlt ?? `Фото ${product.title}`;
const editorialProofLabels = (
  editorialHighlights.length
    ? editorialHighlights.map((item) => item.title)
    : (product.features ?? []).length
      ? (product.features ?? [])
      : editorialUseCases.map((item) => item.title)
).slice(0, 3);
const hasEnhancedEditorial = Boolean(
  editorialHeadline ||
  editorialSupportline ||
  editorialProofLabels.length
);
const hasCinematicSection = Boolean(editorialCinematicHeadline && editorialCinematicImage);

function getColorToneKey(colorName: string): string {
  const name = colorName.toLowerCase();
  if (name.includes('чер')) return 'black';
  if (name.includes('сереб')) return 'silver';
  if (name.includes('графит')) return 'graphite';
  if (name.includes('фиолет')) return 'purple';
  if (name.includes('золот')) return 'gold';
  if (name.includes('син')) return 'blue';
  if (name.includes('бел')) return 'white';
  return 'neutral';
}

const BOX_ICONS = [
  `<svg width="26" height="26" viewBox="0 0 24 24" fill="none" aria-hidden="true"><rect x="9" y="2" width="6" height="12" rx="3" stroke="currentColor" stroke-width="2"/><path d="M5 10a7 7 0 0 0 14 0" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><line x1="12" y1="17" x2="12" y2="22" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>`,
  `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true"><rect x="3" y="6" width="18" height="14" rx="3" stroke="currentColor" stroke-width="2"/><path d="M8 6V5a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v1" stroke="currentColor" stroke-width="2"/></svg>`,
  `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true"><circle cx="12" cy="12" r="8" stroke="currentColor" stroke-width="2"/><circle cx="12" cy="12" r="3.5" stroke="currentColor" stroke-width="2"/></svg>`,
  `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 2v5m0 10v5" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><path d="M9 5h6M9 19h6" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><rect x="8" y="7" width="8" height="10" rx="2" stroke="currentColor" stroke-width="2"/></svg>`,
  `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" stroke="currentColor" stroke-width="2"/><polyline points="14 2 14 8 20 8" stroke="currentColor" stroke-width="2"/><line x1="8" y1="13" x2="16" y2="13" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><line x1="8" y1="17" x2="13" y2="17" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>`,
];
---
<Layout title={product.seoTitle ?? `${product.title} | CRYPTORO`} description={product.seoDescription ?? ''} withChrome={true} active="catalog">
  <main class="pdp" data-slug={product.slug}>

    <!-- 1. Hero -->
    <section class="pdp-hero">
      <div class="pdp-container">
        <nav class="pdp-breadcrumbs" aria-label="Хлебные крошки">
          <a href="/">Главная</a>
          <span aria-hidden="true">/</span>
          <a href="/catalog">Каталог</a>
          <span aria-hidden="true">/</span>
          <span>{product.title}</span>
        </nav>

        <div class={`pdp-hero__badges-row${product.badge ? ' has-badge' : ''}`}>
          {product.badge && <span class="pdp-badge">{product.badge}</span>}
          <span class="pdp-hero__stock" data-ms-stock={product.slug} data-ms-sku={primarySku} data-ms-skus={allSkusCsv}></span>
        </div>
        <h1 class="pdp-hero__title">{product.title}</h1>
        <p class="pdp-hero__subtitle">{subtitle}</p>

        <div class="pdp-hero__price-row">
          <span class="pdp-hero__price" data-ms-price={product.slug} data-ms-sku={primarySku} data-ms-skus={allSkusCsv}>{price}<span class="pdp-hero__currency">&nbsp;₽</span></span>
        </div>
        {priceNote && <p class="pdp-hero__price-note">{priceNote}</p>}

        {product.heroKeySpecs && keySpecsParsed.length > 0 && (
          <div class="pdp-hero__keyspecs">
            {keySpecsParsed.map((spec) => (
              <div class="pdp-hero__keyspec-item">
                <div class="pdp-hero__keyspec-val">
                  {spec.parsed.num ? (
                    <>
                      {spec.parsed.prefix && <span class="pdp-hero__keyspec-prefix">{spec.parsed.prefix}</span>}
                      <span class="pdp-hero__keyspec-num">{spec.parsed.num}</span>
                      {spec.parsed.unit && <span class="pdp-hero__keyspec-unit">{spec.parsed.unit}</span>}
                    </>
                  ) : (
                    <span class="pdp-hero__keyspec-text">{spec.parsed.unit}</span>
                  )}
                </div>
                <span class="pdp-hero__keyspec-label">{spec.label}</span>
              </div>
            ))}
          </div>
        )}

        <div class="pdp-hero__media">
          <div class="pdp-hero__main-img">
            <img id="mainImg" src={gallery[0] ?? product.image} alt={`AI-диктофон ${product.title}`} />
          </div>
        </div>

        {colors.length > 1 && (
          <div class="pdp-hero__colors">
            <div class="pdp-hero__color-btns" id="colorBtns">
              {colors.map((c, i) => (
                <button
                  class={`color-btn${i === 0 ? ' active' : ''}`}
                  type="button"
                  data-color={c}
                  data-color-key={getColorToneKey(c)}
                  data-color-img={product.colorImages?.[c] ?? ''}
                  aria-pressed={i === 0 ? 'true' : 'false'}
                >
                  <span class={`color-btn__swatch color-btn__swatch--${getColorToneKey(c)}`} aria-hidden="true"></span>
                  <span class="color-btn__text">{c}</span>
                </button>
              ))}
            </div>
          </div>
        )}

        <div class="pdp-hero__variants" data-ms-variants={product.slug} data-ms-sku={primarySku} data-ms-skus={allSkusCsv}></div>

        <div class="pdp-hero__actions" id="heroActions">
          <button class="pdp-btn pdp-btn--primary" id="buyBtn" data-ms-buy-btn={product.slug} data-ms-sku={primarySku} data-ms-skus={allSkusCsv} aria-label={`Купить сейчас ${product.title}`}>{stockLabel}</button>
          <button class="pdp-btn pdp-btn--secondary" id="addBtn" aria-label={`Добавить в корзину ${product.title}`}>В корзину</button>
        </div>
        <p class="pdp-hero__trust">Гарантия 1 год &middot; Доставка по РФ &middot; Возврат 14 дней</p>
      </div>
    </section>

    <!-- 2. AI Capability Dark Section -->
    {product.features && product.features.length > 0 && (
      <section class="pdp-ai-dark">
        <div class="pdp-container">
          <p class="pdp-ai-dark__kicker">Plaud Intelligence™</p>
          <h2 class="pdp-ai-dark__headline">{subtitle}</h2>
          <ul class="pdp-ai-dark__list">
            {product.features.map((feat) => (
              <li class="pdp-ai-dark__item">{feat}</li>
            ))}
          </ul>
        </div>
      </section>
    )}

    <!-- 3. Editorial Description -->
    <section class={`pdp-editorial${hasEnhancedEditorial ? ' pdp-editorial--enhanced' : ''}`}>
      <div class={`pdp-container${hasEnhancedEditorial ? ' pdp-container--narrow' : ''}`}>
        {hasEnhancedEditorial ? (
          <>
            <div class="pdp-editorial__showcase">
              <h2 class="pdp-editorial__headline reveal">{editorialHeadline}</h2>
              {editorialSupportline && <div class="pdp-editorial__subline reveal">{editorialSupportline}</div>}
              {editorialProofLabels.length > 0 && (
                <ul class="pdp-editorial__proof-row reveal" aria-label="Ключевые преимущества">
                  {editorialProofLabels.map((label) => <li>{label}</li>)}
                </ul>
              )}
              <div class="pdp-editorial__transition-divider reveal" aria-hidden="true"></div>
            </div>
          </>
        ) : (
          <div class="pdp-editorial__copy reveal">
            <h2 class="pdp-section-title">О продукте</h2>
            <div class="pdp-editorial__body">
              <slot />
            </div>
          </div>
        )}
      </div>
    </section>

    {hasEnhancedEditorial && hasCinematicSection && (
      <section class="pdp-cinematic">
        <div class="pdp-cinematic__inner">
          <div class="pdp-cinematic__copy reveal">
            <h2 class="pdp-cinematic__headline">{editorialCinematicHeadline}</h2>
          </div>
          <div class="pdp-cinematic__media reveal">
            <img src={editorialCinematicImage} alt={editorialCinematicImageAlt} />
          </div>
        </div>
      </section>
    )}

    <!-- 4. Key Specs -->
    {keySpecsParsed.length > 0 && !product.heroKeySpecs && (
      <section class={`pdp-key-specs${hasEnhancedEditorial && hasCinematicSection ? ' pdp-key-specs--overlap' : ''}`}>
        <div class="section-parameters-wrapper">
          <div class="parameters-panel">
            <h2 class="pdp-section-title reveal">Ключевые параметры</h2>
            <div class="pdp-key-specs__grid">
              {keySpecsParsed.map((spec, idx) => (
                <div class="pdp-spec-card reveal" style={`--stagger:${idx}`}>
                  <span class="pdp-spec-card__value">
                    {spec.parsed.num ? (
                      <>
                        {spec.parsed.prefix && <span class="pdp-spec-card__prefix">{spec.parsed.prefix}</span>}
                        <span class="pdp-spec-card__num">{spec.parsed.num}</span>
                        {spec.parsed.unit && <span class="pdp-spec-card__unit">{spec.parsed.unit}</span>}
                      </>
                    ) : (
                      <span class="pdp-spec-card__text">{spec.parsed.unit}</span>
                    )}
                  </span>
                  <span class="pdp-spec-card__label">{spec.label}</span>
                </div>
              ))}
            </div>
          </div>
        </div>
      </section>
    )}

    <!-- 5+6. Specs + Box — unified details section -->
    {(specsRows.length > 0 || (product.boxContents ?? []).length > 0) && (
      <section class="pdp-details">
        <div class="pdp-container pdp-container--default">
          {specsRows.length > 0 && (
            <details class="pdp-accordion reveal" open>
              <summary class="pdp-accordion__trigger">
                <h2 class="pdp-section-title">Характеристики</h2>
                <span class="pdp-accordion__icon" aria-hidden="true">−</span>
              </summary>
              <div class="pdp-accordion__body">
                <table class="pdp-specs-table">
                  <tbody>
                    {specsRows.map((row) => (
                      <tr>
                        <td>{row.label}</td>
                        <td>{row.value}</td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
            </details>
          )}
          {(product.boxContents ?? []).length > 0 && (
            <details class="pdp-accordion reveal">
              <summary class="pdp-accordion__trigger">
                <h2 class="pdp-section-title">Комплект</h2>
                <span class="pdp-accordion__icon" aria-hidden="true">+</span>
              </summary>
              <div class="pdp-accordion__body">
                <table class="pdp-box-table">
                  <tbody>
                    {(product.boxContents ?? []).map((item, idx) => (
                      <tr>
                        <td><span set:html={BOX_ICONS[idx] ?? BOX_ICONS[0]} /></td>
                        <td>{item}</td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
            </details>
          )}
        </div>
      </section>
    )}

    <!-- 7. Model Comparison -->
    {!!related.length && (
      <section class="pdp-compare">
        <div class="pdp-container pdp-container--wide">
          <h2 class="pdp-section-title reveal">Сравните модели</h2>
          <div class="pdp-compare__grid">
            <div class="pdp-compare-card pdp-compare-card--current reveal">
              <span class="pdp-compare-card__badge">Вы смотрите</span>
              <img src={product.image} alt={product.title} />
              <h3>{product.title}</h3>
              <span class="pdp-compare-card__price" data-ms-price={product.slug}>{price}&nbsp;₽</span>
              {keySpecs.length > 0 && (
                <ul class="pdp-compare-card__specs">
                  {keySpecs.slice(0, 3).map((s) => <li><strong>{s.value}</strong> {s.label}</li>)}
                </ul>
              )}
            </div>
            {related.map((item, idx) => (
              <a class="pdp-compare-card pdp-compare-card--alt reveal" style={`--stagger:${idx + 1}`} href={`/products/${item.slug}`}>
                <img src={item.image} alt={item.title} />
                <h3>{item.title}</h3>
                <span class="pdp-compare-card__price" data-ms-price={item.slug}>{new Intl.NumberFormat('ru-RU').format(item.price)}&nbsp;₽</span>
                <span class="pdp-compare-card__cta">Подробнее →</span>
              </a>
            ))}
          </div>
        </div>
      </section>
    )}

  </main>

  <!-- Sticky Mobile Buy Bar -->
  <div class="pdp-sticky-bar" id="stickyBar">
      <div class="pdp-sticky-bar__inner">
        <div class="pdp-sticky-bar__info">
          <span class="pdp-sticky-bar__name">{product.title}</span>
          {colors.length > 1 && <span class="pdp-sticky-bar__meta" id="stickySelectedColor">Цвет: {colors[0]}</span>}
          <span class="pdp-sticky-bar__price" data-ms-price={product.slug}>{price}&nbsp;₽</span>
        </div>
        <button class="pdp-btn pdp-btn--primary pdp-btn--sm" id="stickyBuyBtn">Купить</button>
    </div>
  </div>

  <!-- Lightbox -->
  <div class="lightbox" id="productLightbox" aria-hidden="true">
    <button type="button" class="lightbox-close" id="lightboxClose" aria-label="Закрыть просмотр">&times;</button>
    <img id="lightboxImg" src={gallery[0] ?? product.image} alt={`Увеличенное фото ${product.title}`} />
  </div>

  <!-- Cart Toast -->
  <div class="cart-toast" id="cartToast" role="status" aria-live="polite">Товар добавлен в корзину</div>

  <!-- Cart & Color JS (preserved) -->
  <script define:vars={{ baseProduct: { id: product.slug, name: product.title, price: product.price, image: product.image }, hasColors: colors.length > 1, colorSkus, baseSku }} is:inline>
    function showToast() {
      const toast = document.getElementById('cartToast');
      if (!toast) return;
      toast.classList.add('show');
      window.setTimeout(() => toast.classList.remove('show'), 3000);
    }

    function getCartCountSafe() {
      if (window.cryptoroCart && typeof window.cryptoroCart.readItems === 'function') {
        const items = window.cryptoroCart.readItems();
        return items.reduce((sum, item) => sum + Math.max(1, Number(item?.qty) || 1), 0);
      }
      return 0;
    }

    function getSelectedColor() {
      if (!hasColors) return '';
      const btn = document.querySelector('#colorBtns .color-btn.active') || document.querySelector('#colorBtns .color-btn');
      return btn ? (btn.dataset.color || '') : '';
    }

    function getSelectedColorButton() {
      if (!hasColors) return null;
      const btn = document.querySelector('#colorBtns .color-btn.active') || document.querySelector('#colorBtns .color-btn');
      return btn instanceof HTMLButtonElement ? btn : null;
    }

    function getSelectedColorState() {
      const btn = getSelectedColorButton();
      if (!btn) return { hasSelection: false, isHidden: false, isPreorder: false, color: '' };
      const isHidden = !!btn.disabled || btn.classList.contains('is-hidden-color');
      const isPreorder = !isHidden && btn.classList.contains('is-preorder');
      return {
        hasSelection: true,
        isHidden,
        isPreorder,
        color: btn.dataset.color || ''
      };
    }

    function buildCartItem() {
      const color = getSelectedColor();
      const sku = (color && colorSkus[color]) ? colorSkus[color] : (baseSku || undefined);
      return {
        id: color ? baseProduct.id + '::' + color : baseProduct.id,
        name: baseProduct.name,
        price: baseProduct.price,
        image: baseProduct.image,
        qty: 1,
        color: color || undefined,
        sku: sku || undefined
      };
    }

    function addToCartItem(options = {}) {
      const { allowPreorder = false, skipFeedback = false } = options;
      const state = getSelectedColorState();
      if (state.isHidden) return false;
      if (state.isPreorder && !allowPreorder) return false;

      if (window.cryptoroCart && typeof window.cryptoroCart.add === 'function') {
        window.cryptoroCart.add(buildCartItem());
      }
      const nextCount = getCartCountSafe();
      const c = document.querySelector('#cartCount, .cart-n');
      if (c) {
        c.textContent = String(nextCount);
        c.style.display = nextCount > 0 ? 'flex' : 'none';
      }
      window.dispatchEvent(new CustomEvent('cart:updated', { detail: { count: nextCount } }));
      if (skipFeedback) return true;
      showToast();
      const btn = document.getElementById('addBtn');
      if (!btn) return;
      const original = btn.textContent;
      btn.textContent = '\u2713 Добавлено';
      setTimeout(() => { btn.textContent = original ?? 'В корзину'; }, 2000);
      return true;
    }

    function buyNowItem() {
      const added = addToCartItem({ allowPreorder: true, skipFeedback: true });
      if (!added) return;
      window.location.href = '/cart';
    }

    document.addEventListener('DOMContentLoaded', () => {
      function swapMainImage(nextSrc) {
        if (!nextSrc) return;
        const mainImg = document.getElementById('mainImg');
        if (!(mainImg instanceof HTMLImageElement) || mainImg.src === nextSrc) return;

        // Плавная смена фото при выборе цвета без изменения логики товара.
        mainImg.classList.add('is-swapping');
        const clearSwapState = () => mainImg.classList.remove('is-swapping');
        mainImg.addEventListener('load', clearSwapState, { once: true });
        mainImg.addEventListener('error', clearSwapState, { once: true });
        mainImg.src = nextSrc;
      }

      function setButtonState(btn, { text, disabled }) {
        if (!(btn instanceof HTMLButtonElement)) return;
        if (typeof text === 'string') btn.textContent = text;
        btn.disabled = !!disabled;
        btn.classList.toggle('is-disabled', !!disabled);
        btn.setAttribute('aria-disabled', disabled ? 'true' : 'false');
      }

      function syncColorCtaState() {
        const state = getSelectedColorState();
        if (!state.hasSelection) return;

        const addBtn = document.getElementById('addBtn');
        const buyBtn = document.getElementById('buyBtn');
        const stickyBuyBtn = document.getElementById('stickyBuyBtn');
        const stickyColor = document.getElementById('stickySelectedColor');

        if (stickyColor && state.color) stickyColor.textContent = `Цвет: ${state.color}`;

        // Для недоступного цвета не даем добавить в корзину; для предзаказа оставляем основной CTA.
        if (state.isHidden) {
          setButtonState(addBtn, { text: 'В корзину', disabled: true });
          setButtonState(buyBtn, { text: 'Нет в наличии', disabled: true });
          setButtonState(stickyBuyBtn, { text: 'Нет в наличии', disabled: true });
          return;
        }

        if (state.isPreorder) {
          setButtonState(addBtn, { text: 'В корзину', disabled: true });
          setButtonState(buyBtn, { text: 'Предзаказ', disabled: false });
          setButtonState(stickyBuyBtn, { text: 'Предзаказ', disabled: false });
          return;
        }

        setButtonState(addBtn, { text: 'В корзину', disabled: false });
        setButtonState(buyBtn, { text: 'Купить сейчас', disabled: false });
        setButtonState(stickyBuyBtn, { text: 'Купить', disabled: false });
      }

      const addBtn = document.getElementById('addBtn');
      const buyBtn = document.getElementById('buyBtn');
      if (addBtn) addBtn.addEventListener('click', addToCartItem);
      if (buyBtn) buyBtn.addEventListener('click', buyNowItem);

      // Sticky buy bar
      const stickyBuyBtn = document.getElementById('stickyBuyBtn');
      if (stickyBuyBtn) stickyBuyBtn.addEventListener('click', buyNowItem);

      const heroActions = document.getElementById('heroActions');
      const stickyBar = document.getElementById('stickyBar');
      if (heroActions && stickyBar) {
        const obs = new IntersectionObserver(([entry]) => {
          stickyBar.classList.toggle('pdp-sticky-bar--visible', !entry.isIntersecting);
        }, { threshold: 0 });
        obs.observe(heroActions);

        // Hide sticky bar when footer enters viewport
        const footer = document.querySelector('footer');
        if (footer) {
          const footerObs = new IntersectionObserver(([entry]) => {
            if (entry.isIntersecting) stickyBar.classList.remove('pdp-sticky-bar--visible');
          }, { threshold: 0 });
          footerObs.observe(footer);
        }
      }

      // Stock badge fallback: show "Нет данных" if API doesn't respond
      const stockBadge = document.querySelector('[data-ms-stock]');
      if (stockBadge instanceof HTMLElement) {
        window.setTimeout(() => {
          if (stockBadge.style.display === 'none' || !stockBadge.textContent.trim()) {
            stockBadge.textContent = 'Нет данных';
            stockBadge.classList.add('ms-stock-badge');
            stockBadge.style.display = 'inline-flex';
          }
        }, 4500);
      }

      // Accordion icon
      document.querySelectorAll('.pdp-accordion').forEach((el) => {
        el.addEventListener('toggle', () => {
          const icon = el.querySelector('.pdp-accordion__icon');
          if (icon) icon.textContent = el.open ? '\u2212' : '+';
        });
      });

      // Color picker
      const colorBtns = document.getElementById('colorBtns');
      if (colorBtns) {
        // Set initial image from first active color
        const firstActive = colorBtns.querySelector('.color-btn.active');
        if (firstActive?.dataset.colorImg) {
          const mainImg = document.getElementById('mainImg');
          if (mainImg) mainImg.src = firstActive.dataset.colorImg;
        }
        syncColorCtaState();

        // МойСклад обновляет классы/disabled у цветов асинхронно; синхронизируем CTA после этих изменений.
        const colorStateObserver = new MutationObserver(() => syncColorCtaState());
        colorStateObserver.observe(colorBtns, {
          subtree: true,
          childList: true,
          attributes: true,
          attributeFilter: ['class', 'disabled']
        });

        colorBtns.addEventListener('click', (event) => {
          const btn = event.target.closest('.color-btn');
          if (!btn) return;
          colorBtns.querySelectorAll('.color-btn').forEach((b) => {
            b.classList.remove('active');
            b.setAttribute('aria-pressed', 'false');
          });
          btn.classList.add('active');
          btn.setAttribute('aria-pressed', 'true');
          const stickyColor = document.getElementById('stickySelectedColor');
          if (stickyColor) stickyColor.textContent = `Цвет: ${btn.dataset.color || ''}`;
          // Swap main image if color has a dedicated photo
          const colorImg = btn.dataset.colorImg;
          if (colorImg) swapMainImage(colorImg);
          syncColorCtaState();
        });
      }
    });
  </script>

  <!-- Gallery & Lightbox JS -->
  <script>
    (function () {
      const mainImg = document.getElementById('mainImg');
      const lightbox = document.getElementById('productLightbox');
      const lightboxImg = document.getElementById('lightboxImg');
      const closeBtn = document.getElementById('lightboxClose');
      if (!mainImg || !lightbox || !lightboxImg || !closeBtn) return;

      function openLightbox(src) {
        if (src) lightboxImg.src = src;
        lightbox.style.display = 'flex';
        requestAnimationFrame(() => lightbox.classList.add('visible'));
        lightbox.setAttribute('aria-hidden', 'false');
      }

      function closeLightbox() {
        lightbox.classList.remove('visible');
        lightbox.setAttribute('aria-hidden', 'true');
        window.setTimeout(() => {
          lightbox.style.display = 'none';
        }, 200);
      }

      document.querySelectorAll('[data-gallery-thumb]').forEach((thumb) => {
        thumb.addEventListener('click', () => {
          const src = thumb.getAttribute('data-src');
          if (!src) return;
          mainImg.src = src;
          document.querySelectorAll('[data-gallery-thumb]').forEach((el) => el.classList.remove('active'));
          thumb.classList.add('active');
        });
      });

      mainImg.addEventListener('click', () => openLightbox(mainImg.src));
      closeBtn.addEventListener('click', closeLightbox);
      lightbox.addEventListener('click', (event) => {
        if (event.target === lightbox) closeLightbox();
      });
      document.addEventListener('keydown', (event) => {
        if (event.key === 'Escape') closeLightbox();
      });
    })();
  </script>

