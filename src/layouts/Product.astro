    /* ── ACCORDION ICON ROTATION ── */
    .pdp-accordion__icon { transition:transform .3s cubic-bezier(.16,1,.3,1) !important }
    .pdp-accordion[open] .pdp-accordion__icon { transform:rotate(180deg) !important }

    /* ── CTA BUTTON SHIMMER ── */
    .pdp-btn--primary { position:relative !important; overflow:hidden !important }
    .pdp-btn--primary::after {
      content:'' !important;
      position:absolute !important;
      top:0 !important; left:-100% !important;
      width:60% !important; height:100% !important;
      background:linear-gradient(90deg, transparent, rgba(255,255,255,.12), transparent) !important;
      animation:pdpShimmer 3s ease-in-out infinite !important;
      pointer-events:none !important;
    }
    @keyframes pdpShimmer {
      0%   { left:-100% }
      40%  { left:160% }
      100% { left:160% }
    }

    /* ── REDUCED MOTION ── */
    @media (prefers-reduced-motion: reduce) {
      .pdp-hero::after { animation:none !important }
      .pdp-badge { animation:none !important }
