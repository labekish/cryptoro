    /* ═══════════ WOW ANIMATIONS FOR PDP ═══════════ */

    /* ── HERO STAGGERED ENTRANCE ── */
    @keyframes pdpHeroIn {
      from { opacity:0; transform:translateY(var(--pdp-y,28px)) scale(var(--pdp-s,1)) }
      to   { opacity:1; transform:translateY(0) scale(1) }
    }
    .pdp-anim-init { opacity:0 !important; transition:none !important }
    .pdp-anim-go { animation: pdpHeroIn .8s cubic-bezier(.16,1,.3,1) var(--pdp-delay,0s) both !important }
    .pdp-anim-done { opacity:1 !important; transform:translateY(0) scale(1) !important; animation:none !important }

    /* ── HERO GRADIENT BLOB ── */
    .pdp-hero::after {
      content:'' !important;
      display:block !important;
      position:absolute !important;
      top:-25% !important;
      right:-10% !important;
      width:55vw !important;
      height:55vw !important;
      max-width:600px !important;
      max-height:600px !important;
      border-radius:50% !important;
      background:radial-gradient(circle, rgba(232,134,53,.07) 0%, rgba(232,134,53,.02) 40%, transparent 70%) !important;
      pointer-events:none !important;
      z-index:0 !important;
      animation:pdpBlobFloat 9s ease-in-out infinite !important;
    }
    .pdp-hero { position:relative !important; overflow:hidden !important }
    .pdp-hero .pdp-container { position:relative !important; z-index:1 !important }
    @keyframes pdpBlobFloat {
      0%,100% { transform:translate(0,0) scale(1) }
      50%     { transform:translate(-3%,4%) scale(1.05) }
    }

    /* ── BADGE PULSE ── */
    @keyframes pdpBadgePulse {
      0%,100% { box-shadow:0 0 0 0 rgba(232,134,53,.25) }
      50%     { box-shadow:0 0 0 8px rgba(232,134,53,0) }
    }
    .pdp-badge { animation:pdpBadgePulse 2.5s ease-in-out infinite !important }

    /* ── HERO IMAGE HOVER ZOOM ── */
    .pdp-hero__main-img img { transition:transform .6s cubic-bezier(.16,1,.3,1), opacity .18s ease !important }

    /* ── AI DARK SECTION REVEAL ── */
    @keyframes pdpFadeUp {
      from { opacity:0; transform:translateY(24px) }
      to   { opacity:1; transform:translateY(0) }
    }
    .pdp-ai-dark .pdp-ai-dark__kicker,
    .pdp-ai-dark .pdp-ai-dark__headline,
    .pdp-ai-dark .pdp-ai-dark__item {
      opacity:0;
      transform:translateY(24px);
    }
    .pdp-ai-dark.pdp-section-vis .pdp-ai-dark__kicker { animation:pdpFadeUp .7s cubic-bezier(.16,1,.3,1) .1s both }
    .pdp-ai-dark.pdp-section-vis .pdp-ai-dark__headline { animation:pdpFadeUp .7s cubic-bezier(.16,1,.3,1) .25s both }
    .pdp-ai-dark.pdp-section-vis .pdp-ai-dark__item:nth-child(1) { animation:pdpFadeUp .6s cubic-bezier(.16,1,.3,1) .4s both }
    .pdp-ai-dark.pdp-section-vis .pdp-ai-dark__item:nth-child(2) { animation:pdpFadeUp .6s cubic-bezier(.16,1,.3,1) .5s both }
    .pdp-ai-dark.pdp-section-vis .pdp-ai-dark__item:nth-child(3) { animation:pdpFadeUp .6s cubic-bezier(.16,1,.3,1) .6s both }

    /* ── KEY SPECS COUNT-UP ── */
    .pdp-spec-card__num { font-variant-numeric:tabular-nums !important }

    /* ── SPEC CARDS STAGGER ── */
    .pdp-spec-card.pdp-spec-vis {
      animation:pdpFadeUp .6s cubic-bezier(.16,1,.3,1) calc(var(--stagger,0) * .12s) both !important;
    }

    /* ── CINEMATIC SLIDE-IN ── */
    @keyframes pdpSlideLeft {
      from { opacity:0; transform:translateX(-40px) }
      to   { opacity:1; transform:translateX(0) }
    }
    @keyframes pdpSlideRight {
      from { opacity:0; transform:translateX(40px) }
      to   { opacity:1; transform:translateX(0) }
    }
    .pdp-cinematic__copy.reveal.vis { animation:pdpSlideLeft .8s cubic-bezier(.16,1,.3,1) .15s both !important }
    .pdp-cinematic__media.reveal.vis { animation:pdpSlideRight .8s cubic-bezier(.16,1,.3,1) .3s both !important }

    /* ── COMPARE CARDS ── */
    .pdp-compare-card--alt { transition:opacity .3s ease, box-shadow .3s ease, transform .3s cubic-bezier(.16,1,.3,1) !important }
    @media(hover:hover){
