    <script is:inline define:vars={{ msSyncPricesEnabled }}>
      (function () {
        const KEY = 'cryptoro_cart_count';
        const ITEMS_KEY = 'cryptoro_cart';
        const LEGACY_ITEMS_KEY = 'cryptoro_cart_items';

        function readItems() {
          try {
            const raw = window.localStorage.getItem(ITEMS_KEY) ?? window.localStorage.getItem(LEGACY_ITEMS_KEY);
            const parsed = raw ? JSON.parse(raw) : [];
            if (!Array.isArray(parsed)) return [];
            return parsed.map((item) => ({
              ...item,
              qty: Math.max(1, Number(item?.qty) || 1)
            }));
          } catch {
            return [];
          }
        }

        function writeItems(items) {
          window.localStorage.setItem(ITEMS_KEY, JSON.stringify(items));
          window.localStorage.removeItem(LEGACY_ITEMS_KEY);
        }

        function read() {
          const value = Number(window.localStorage.getItem(KEY) || '0');
          return Number.isFinite(value) && value > 0 ? Math.floor(value) : 0;
        }

        function write(value) {
          window.localStorage.setItem(KEY, String(Math.max(0, Math.floor(value))));
        }

        function paint(value) {
          document.querySelectorAll('#cartCount, .cart-n, [data-cart-count]').forEach((node) => {
            node.textContent = String(value);
            node.style.display = value > 0 ? 'flex' : 'none';
          });
        }

        function getItemsCount(items) {
          return items.reduce((sum, item) => sum + Math.max(1, Number(item?.qty) || 1), 0);
        }

        function sync() {
          const items = readItems();
          if (items.length > 0) {
            const count = getItemsCount(items);
            write(count);
            paint(count);
            return;
          }
          const fallbackCount = read();
          paint(fallbackCount);
        }

        function add(payloadOrStep) {
          const items = readItems();
          if (payloadOrStep && typeof payloadOrStep === 'object') {
            const idx = items.findIndex((item) => item.id === payloadOrStep.id);
            if (idx >= 0) {
              const nextQty = Math.max(1, Number(items[idx].qty) || 1) + Math.max(1, Number(payloadOrStep.qty) || 1);
              // Русский комментарий: обновляем цену/sku/название в существующей позиции, чтобы при смене цены МС не оставался старый прайс.
              items[idx] = {
                ...items[idx],
                ...payloadOrStep,
                qty: nextQty,
                addedAt: Date.now()
              };
            } else {
              items.push({
                ...payloadOrStep,
                qty: Math.max(1, Number(payloadOrStep.qty) || 1),
                addedAt: Date.now()
              });
            }
          } else {
            const step = Math.max(1, Math.floor(payloadOrStep || 1));
            for (let i = 0; i < step; i += 1) {
              items.push({ qty: 1, addedAt: Date.now(), source: 'quick-add' });
            }
          }
          writeItems(items);
          const count = getItemsCount(items);
          write(count);
          paint(count);
          window.dispatchEvent(new CustomEvent('cart:updated', { detail: { count } }));
          return count;
        }

        function clear() {
          writeItems([]);
          write(0);
          paint(0);
          window.dispatchEvent(new CustomEvent('cart:updated', { detail: { count: 0 } }));
        }

        window.cryptoroCart = { read, write, readItems, writeItems, sync, add, clear };

        function bindCartButtons() {
          document.querySelectorAll('#cartBtn, [data-cart-btn], button.cart, .cart, button[aria-label="Корзина"]').forEach((button) => {
            if (button.dataset.cartBound === '1') return;
            button.dataset.cartBound = '1';
            button.addEventListener('click', () => {
              window.location.href = '/cart';
            });
          });
        }

        function setupMobileNav() {
          const isMobile = window.matchMedia('(max-width: 768px)').matches;
          document.querySelectorAll('header').forEach((header) => {
            const existingToggle = header.querySelector('.mobile-menu-toggle');
            const existingPanel = header.querySelector('.mobile-nav-panel');
            if (!isMobile) {
              if (existingToggle) existingToggle.remove();
              if (existingPanel) existingPanel.remove();
              header.classList.remove('mobile-nav-open');
              header.dataset.mobileNavReady = '1';
              return;
            }
            if (existingToggle && existingPanel) {
              header.dataset.mobileNavReady = '1';
              return;
            }
            // На legacy-страницах уже есть собственное мобильное меню.
            // Не дублируем его, чтобы избежать конфликтов кликов/состояний.
            // Русский комментарий: проверяем меню только внутри текущего header,
            // чтобы скрытые legacy-узлы в другом месте DOM не блокировали smart-header.
            if (header.id === 'smart-header' && header.querySelector('#mobileMenuToggle')) {
              header.dataset.mobileNavReady = '1';
              return;
            }
            if (header.querySelector('#menuToggle') || header.querySelector('#mobileNav')) {
              header.dataset.mobileNavReady = '1';
              return;
            }
            const nav = header.querySelector('nav');
            if (!nav) return;
            const toggleParent = (
              isMobile && header.id === 'smart-header'
                // Для smart-header toggle остается в правой зоне.
                ? header.querySelector('.header-right')
                : nav.parentElement
            );
            if (!toggleParent) return;
            // Русский комментарий: сам dropdown крепим к header, иначе при монтировании в .header-right панель сжимается по ширине.
            const panelParent = header;

            const links = Array.from(nav.querySelectorAll('a'))
              .map((a) => ({ href: a.getAttribute('href') || '#', text: (a.textContent || '').trim() }))
              .filter((x) => x.text);
            if (!links.length) return;

            const toggle = document.createElement('button');
            toggle.type = 'button';
            toggle.className = 'mobile-menu-toggle';
            toggle.setAttribute('aria-label', 'Открыть меню');
            toggle.innerHTML = '<svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M4 7h16M4 12h16M4 17h16" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>';

            const panel = document.createElement('div');
            panel.className = 'mobile-nav-panel';
            panel.innerHTML = `<button type="button" class="mobile-nav-close" aria-label="Закрыть меню">×</button>${links.map((item) => `<a href="${item.href}">${item.text}</a>`).join('')}`;

            toggle.addEventListener('click', () => {
              header.classList.toggle('mobile-nav-open');
            });
            const closeBtn = panel.querySelector('.mobile-nav-close');
            if (closeBtn) {
              closeBtn.addEventListener('click', () => header.classList.remove('mobile-nav-open'));
            }
            panel.querySelectorAll('a').forEach((link) => {
              link.addEventListener('click', () => header.classList.remove('mobile-nav-open'));
            });
            document.addEventListener('click', (event) => {
              if (!header.contains(event.target)) header.classList.remove('mobile-nav-open');
            });

            toggleParent.appendChild(toggle);
            toggleParent.style.position = 'relative';
            panelParent.appendChild(panel);
            header.dataset.mobileNavReady = '1';
          });
        }

        function setupConsultModal() {
          if (document.getElementById('consultModal')) return;
          const modal = document.createElement('div');
          modal.id = 'consultModal';
          modal.className = 'consult-modal';
          modal.setAttribute('aria-hidden', 'true');
          modal.innerHTML = `
            <div class="consult-modal-card" role="dialog" aria-modal="true" aria-labelledby="consultTitle">
              <div class="consult-modal-head">
                <h3 id="consultTitle" class="consult-modal-title">Получить консультацию</h3>
                <button type="button" class="consult-close" data-consult-close aria-label="Закрыть окно">×</button>
              </div>
              <p class="consult-modal-sub">Подберем модель под ваши задачи и бюджет.</p>
              <form name="consult" method="POST" class="consult-grid" novalidate>
                <input type="hidden" name="form-name" value="consult" />
                <input type="hidden" name="bot-field" />
                <input class="consult-input" type="text" name="name" placeholder="Имя (необязательно)" autocomplete="name" />
                <input class="consult-input" type="text" name="contact" placeholder="Телефон или Telegram *" autocomplete="tel" required />
                <p class="consult-help">Укажите телефон или @telegram для связи.</p>
                <textarea class="consult-input" name="comment" rows="4" placeholder="Комментарий (необязательно)"></textarea>
                <div class="consult-status" data-consult-status aria-live="polite"></div>
                <div class="consult-actions">
                  <button type="button" class="consult-btn" data-consult-close>Отмена</button>
                  <button type="submit" class="consult-btn primary" data-consult-submit>Получить консультацию</button>
                </div>
              </form>
            </div>
          `;
          document.body.appendChild(modal);

          const form = modal.querySelector('form');
          const contactInput = modal.querySelector('input[name="contact"]');
          const submitBtn = modal.querySelector('[data-consult-submit]');
          const statusNode = modal.querySelector('[data-consult-status]');
          let isSubmitting = false;
          const pagePath = window.location.pathname || '/';
          let pendingLeadSource = {
            entryPoint: 'consult_modal_direct',
            sourcePage: pagePath,
            sourceButton: 'Прямой вызов модалки',
          };

          const setStatus = (text, mode = '') => {
            if (!statusNode) return;
            statusNode.textContent = text || '';
            statusNode.className = `consult-status${mode ? ` ${mode}` : ''}`;
          };

          const normalizeToken = (value) => String(value || '')
            .toLowerCase()
            .replace(/[^a-z0-9а-яё]+/gi, '_')
            .replace(/^_+|_+$/g, '')
            .slice(0, 60);

          const resolveLeadSourceFromLink = (link, index) => {
            const href = String(link.getAttribute('href') || '').trim();
            const text = String((link.textContent || '').trim() || link.getAttribute('aria-label') || 'Кнопка').slice(0, 120);
            const explicitEntryPoint = String(link.dataset.leadEntrypoint || '').trim();
            const explicitSourcePage = String(link.dataset.leadSourcePage || '').trim();
            const explicitSourceButton = String(link.dataset.leadSourceButton || '').trim();

            if (explicitEntryPoint) {
              return {
                entryPoint: explicitEntryPoint,
                sourcePage: explicitSourcePage || pagePath,
                sourceButton: explicitSourceButton || text,
              };
            }

            const pageToken = normalizeToken(pagePath) || 'home';
            const hrefToken = normalizeToken(href) || 'consult';
            const textToken = normalizeToken(text) || 'button';
            const base = link.hasAttribute('data-open-consult') ? 'consult_cta' : 'consult_link';
            const entryPoint = `${base}_${pageToken}_${hrefToken}_${textToken}_${index + 1}`.slice(0, 80);

            return {
              entryPoint,
              sourcePage: pagePath,
              sourceButton: text,
            };
          };

          const openModal = () => {
            modal.classList.add('open');
            modal.setAttribute('aria-hidden', 'false');
            document.body.classList.add('consult-open');
            setStatus('');
            setTimeout(() => {
              if (contactInput instanceof HTMLElement) contactInput.focus();
            }, 10);
          };
          const closeModal = () => {
            if (isSubmitting) return;
            modal.classList.remove('open');
            modal.setAttribute('aria-hidden', 'true');
            document.body.classList.remove('consult-open');
          };

          modal.addEventListener('click', (event) => {
            if (event.target === modal) closeModal();
          });
          modal.querySelectorAll('[data-consult-close]').forEach((btn) => btn.addEventListener('click', closeModal));
          document.addEventListener('keydown', (event) => {
            if (event.key === 'Escape') closeModal();
          });

          if (form instanceof HTMLFormElement && submitBtn instanceof HTMLButtonElement) {
            form.addEventListener('submit', async (event) => {
              event.preventDefault();
              if (isSubmitting) return;

              const fd = new FormData(form);
              const name = String(fd.get('name') || '').trim();
              const contact = String(fd.get('contact') || '').trim();
              const comment = String(fd.get('comment') || '').trim();

              if (!contact) {
                setStatus('Укажите телефон или Telegram для связи.', 'is-error');
                if (contactInput instanceof HTMLElement) contactInput.focus();
                return;
              }

              isSubmitting = true;
              submitBtn.disabled = true;
              submitBtn.textContent = 'Отправляем...';
              form.setAttribute('aria-busy', 'true');
              setStatus('Отправляем заявку...', 'is-loading');

              try {
                const response = await fetch('/api/b24/lead', {
                  method: 'POST',
                  headers: { 'Content-Type': 'application/json' },
                  body: JSON.stringify({
                    type: 'consult',
                    name: name || 'Без имени',
                    phone: contact,
                    email: '',
                    comment,
                    // Русский комментарий: метки источника нужны для раздельной аналитики лидов в CRM.
                    entryPoint: pendingLeadSource.entryPoint,
                    sourcePage: pendingLeadSource.sourcePage,
                    sourceButton: pendingLeadSource.sourceButton,
                  })
                });

                if (!response.ok) throw new Error('request_failed');

                form.reset();
                setStatus('Спасибо! Мы свяжемся с вами в ближайшее время.', 'is-success');
              } catch {
                setStatus('Ошибка отправки. Попробуйте ещё раз.', 'is-error');
              } finally {
                isSubmitting = false;
                submitBtn.disabled = false;
                submitBtn.textContent = 'Получить консультацию';
                form.removeAttribute('aria-busy');
              }
            });
          }

          const isHome = window.location.pathname === '/';
          document.querySelectorAll('a[href="/#lead"], a[href="#lead"], [data-open-consult]').forEach((link, index) => {
            if (isHome && link.getAttribute('href') === '#lead') return;
            link.addEventListener('click', (event) => {
              event.preventDefault();
              pendingLeadSource = resolveLeadSourceFromLink(link, index);
              openModal();
            });
          });
        }

        function setupFadeIn() {
          if (!('IntersectionObserver' in window)) return;
          const nodes = document.querySelectorAll('.reveal, [data-fade]');
          if (!nodes.length) return;
          const observer = new IntersectionObserver((entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add('in-view', 'vis');
                if (entry.target.classList.contains('opacity-0')) {
                  entry.target.classList.remove('opacity-0');
                  entry.target.classList.add('opacity-100');
                }
                if (entry.target.classList.contains('translate-y-5')) {
                  entry.target.classList.remove('translate-y-5');
                  entry.target.classList.add('translate-y-0');
                }
                observer.unobserve(entry.target);
              }
            });
          }, { threshold: 0.08 });

          nodes.forEach((node) => {
            node.classList.add('fade-in');
            observer.observe(node);
          });
        }

        function setupAccessibilityLabels() {
          document.querySelectorAll('a, button').forEach((node) => {
            if (node.getAttribute('aria-label')) return;
            const text = (node.textContent || '').trim().replace(/\s+/g, ' ');
            if (text) node.setAttribute('aria-label', text.slice(0, 100));
          });
        }

        function normalizeExternalLinks() {
          // Гарантируем безопасные rel-атрибуты у внешних ссылок с target=_blank.
          document.querySelectorAll('a[target="_blank"]').forEach((link) => {
            const rel = (link.getAttribute('rel') || '').toLowerCase();
            const tokens = new Set(rel.split(/\s+/).filter(Boolean));
            tokens.add('noopener');
            tokens.add('noreferrer');
            link.setAttribute('rel', Array.from(tokens).join(' '));
          });
        }

        function dedupeCatalogTabs() {
          if (window.location.pathname.indexOf('/catalog') !== 0) return;
          const rows = Array.from(document.querySelectorAll('.catalog-chips'));
          rows.slice(1).forEach((row) => row.remove());
        }

        function syncMoysklad() {
          const selectors = msSyncPricesEnabled
            ? '[data-ms-price], [data-ms-stock], [data-ms-buy-btn], [data-ms-variants]'
            : '[data-ms-stock], [data-ms-buy-btn], [data-ms-variants]';
          const targets = Array.from(document.querySelectorAll(selectors));
          if (!targets.length) return;
          const priceNodes = targets.filter((node) => node.hasAttribute('data-ms-price'));
          let firstSyncResolved = false;

          const hidePendingPrices = () => {
            if (firstSyncResolved) return;
            priceNodes.forEach((node) => node.classList.add('ms-price-pending'));
          };

          const revealPrices = () => {
            firstSyncResolved = true;
            priceNodes.forEach((node) => node.classList.remove('ms-price-pending'));
          };

          // Русский комментарий: в локальном astro dev endpoints из functions/* недоступны, поэтому не дергаем API и не засоряем консоль 404.
          const isLocalHost = window.location.hostname === '127.0.0.1' || window.location.hostname === 'localhost';
          if (isLocalHost) {
            revealPrices();
            return;
          }

          const slugs = Array.from(
            new Set(
              targets
                .map((node) => node.getAttribute('data-ms-price') || node.getAttribute('data-ms-stock') || node.getAttribute('data-ms-buy-btn') || node.getAttribute('data-ms-variants'))
                .filter(Boolean)
            )
          );

          if (!slugs.length) return;

          const slugToSkus = {};
          slugs.forEach((slug) => {
            const exact = document.querySelector(
              `[data-ms-price="${slug}"][data-ms-skus], [data-ms-stock="${slug}"][data-ms-skus], [data-ms-buy-btn="${slug}"][data-ms-skus], [data-ms-variants="${slug}"][data-ms-skus]`
            );
            const fallbackExact = document.querySelector(
              `[data-ms-price="${slug}"][data-ms-sku], [data-ms-stock="${slug}"][data-ms-sku], [data-ms-buy-btn="${slug}"][data-ms-sku], [data-ms-variants="${slug}"][data-ms-sku]`
            );
            const scoped = document.querySelector(`[data-ms-price="${slug}"], [data-ms-stock="${slug}"], [data-ms-buy-btn="${slug}"], [data-ms-variants="${slug}"]`);
            const source =
              exact ||
              fallbackExact ||
              (scoped && scoped.closest && (scoped.closest('[data-ms-skus]') || scoped.closest('[data-ms-sku]')));

            const fromList = source
              ? String(source.getAttribute('data-ms-skus') || '')
                  .split(',')
                  .map((item) => item.trim())
                  .filter(Boolean)
              : [];
            const fromSingle = source ? String(source.getAttribute('data-ms-sku') || '').trim() : '';
            const skus = Array.from(new Set([...fromList, ...(fromSingle ? [fromSingle] : [])]));

            if (skus.length) slugToSkus[slug] = skus;
          });

          const skuPairs = Object.entries(slugToSkus)
            .map(([slug, skuList]) => `${slug}:${skuList.join('|')}`)
            .join(',');

          const formatRub = (value) => `${Math.round(Number(value || 0)).toLocaleString('ru-RU')} ₽`;

          const applyItems = (items) => {
            Object.entries(items || {}).forEach(([slug, item]) => {
              if (msSyncPricesEnabled) {
                document.querySelectorAll(`[data-ms-price="${slug}"]`).forEach((node) => {
                  node.textContent = formatRub(item.price);
                  node.setAttribute('data-ms-price-value', String(Math.round(Number(item.price || 0))));
                  node.classList.remove('ms-price-pending');
                });
              }

              document.querySelectorAll(`[data-ms-stock="${slug}"]`).forEach((node) => {
                const qty = Math.max(0, Number(item.stock || 0));
                node.classList.remove('ms-stock-badge', 'ms-in-stock', 'ms-low-stock', 'ms-preorder');
                node.style.display = 'none';
                node.textContent = '';

                if (item.status === 'hidden') return;

                node.classList.add('ms-stock-badge');
                if (item.status === 'preorder') {
                  node.classList.add('ms-preorder');
                  node.textContent = 'Предзаказ';
                } else if (item.status === 'low_stock') {
                  node.classList.add('ms-low-stock');
                  node.textContent = `Мало: ${qty} шт`;
                } else {
                  node.classList.add('ms-in-stock');
                  node.textContent = `В наличии: ${qty} шт`;
                }
                node.style.display = 'inline-flex';
              });

              document.querySelectorAll(`[data-ms-buy-btn="${slug}"]`).forEach((node) => {
                if (item.status === 'preorder') {
                  node.textContent = 'Предзаказ';
                  node.classList.remove('is-disabled');
                  node.removeAttribute('disabled');
                  node.setAttribute('aria-disabled', 'false');
                  return;
                }
                if (item.status === 'hidden') {
                  node.textContent = 'Нет в наличии';
                  node.classList.add('is-disabled');
                  node.setAttribute('disabled', 'disabled');
                  node.setAttribute('aria-disabled', 'true');
                  return;
                }
                node.textContent = 'Купить сейчас';
                node.classList.remove('is-disabled');
                node.removeAttribute('disabled');
                node.setAttribute('aria-disabled', 'false');
              });

              document.querySelectorAll(`[data-ms-variants="${slug}"]`).forEach((node) => {
                const variants = Array.isArray(item.variants) ? item.variants : [];
                const skuOrder = (slugToSkus[slug] || []).map((sku) => String(sku).trim());
                const orderMap = new Map(skuOrder.map((sku, idx) => [sku, idx]));

                const colorMap = {
                  Black: 'Черный',
                  'Navy Blue': 'Синий',
                  Silver: 'Серебристый',
                  Starlight: 'Золотистый',
                  Graphite: 'Графит',
                  'Cosmic Gray': 'Графит',
                  'Lunar Silver': 'Серебристый',
                  'Sunset Purple': 'Фиолетовый',
                  Violet: 'Фиолетовый'
                };

                const normalized = variants
                  .filter((variant) => variant && variant.sku && String(variant.status || '') !== 'hidden')
                  .sort((a, b) => {
                    const aOrder = orderMap.has(String(a.sku)) ? orderMap.get(String(a.sku)) : Number.MAX_SAFE_INTEGER;
                    const bOrder = orderMap.has(String(b.sku)) ? orderMap.get(String(b.sku)) : Number.MAX_SAFE_INTEGER;
                    if (aOrder !== bOrder) return aOrder - bOrder;
                    return String(a.color || a.sku).localeCompare(String(b.color || b.sku), 'ru');
                  });

                if (!normalized.length) {
                  node.innerHTML = '';
                  node.style.display = 'none';
                  return;
                }

                const html = normalized
                  .map((variant) => {
                    const qty = Math.max(0, Number(variant.stock || 0));
                    const status = String(variant.status || '');
                    const isPreorder = status === 'preorder' || qty <= 0;
                    const isLow = status === 'low_stock' && !isPreorder;
                    const statusClass = isPreorder ? ' is-preorder' : isLow ? ' is-low' : '';
                    const statusText = isPreorder ? 'предзаказ' : isLow ? `мало: ${qty} шт` : `${qty} шт`;
                    const rawLabel = String(variant.color || variant.sku || '').trim();
                    const label = colorMap[rawLabel] || rawLabel;
                    const dotClass = isPreorder ? 'ms-dot dot-preorder' : isLow ? 'ms-dot dot-low' : 'ms-dot dot-instock';
                    return `<div class="ms-variant-item"><span class="${dotClass}"></span><b>${label}</b><span class="ms-variant-value${statusClass}">${statusText}</span></div>`;
                  })
                  .join('');

                node.classList.add('ms-variant-list');
                node.innerHTML = html;
                node.style.display = 'grid';

                // Синхронизация с color picker на странице товара
                const colorBtnsEl = document.getElementById('colorBtns');
                if (colorBtnsEl) {
                  const variantByColor = {};
                  normalized.forEach((v) => {
                    const key = colorMap[String(v.color || '').trim()] || String(v.color || '').trim();
                    variantByColor[key] = v;
                  });

                  colorBtnsEl.querySelectorAll('.color-btn').forEach((btn) => {
                    const colorName = btn.dataset.color || '';
                    const v = variantByColor[colorName];
                    if (!v) {
                      // Цвет есть в пикере, но нет в МойСклад — показываем как предзаказ
                      btn.querySelector('.color-stock')?.remove();
                      btn.classList.add('is-preorder');
                      const span = document.createElement('span');
                      span.className = 'color-stock';
                      span.textContent = 'предзаказ';
                      btn.appendChild(span);
                      return;
                    }
                    const qty = Math.max(0, Number(v.stock || 0));
                    const status = String(v.status || '');
                    const isHidden = status === 'hidden';
                    const isPreorder = !isHidden && (status === 'preorder' || qty <= 0);
                    const isLow = status === 'low_stock' && qty > 0;

                    btn.disabled = isHidden;
                    btn.classList.toggle('is-hidden-color', isHidden);
                    btn.classList.toggle('is-preorder', isPreorder);
                    btn.classList.toggle('is-low', isLow);

                    btn.querySelector('.color-stock')?.remove();
                    if (!isHidden) {
                      const span = document.createElement('span');
                      span.className = 'color-stock';
                      if (isPreorder) span.textContent = 'предзаказ';
                      else span.textContent = qty + ' шт';
                      btn.appendChild(span);
                    }
                  });

                  // Если активная кнопка недоступна — выбираем первую доступную
                  const activeBtn = colorBtnsEl.querySelector('.color-btn.active');
                  if (activeBtn && activeBtn.disabled) {
                    activeBtn.classList.remove('active');
                    const firstAvail = colorBtnsEl.querySelector('.color-btn:not([disabled])');
                    if (firstAvail) {
                      firstAvail.classList.add('active');
                      const label = document.getElementById('selectedColorName');
                      if (label) label.textContent = firstAvail.dataset.color || '';
                    }
                  }

                  // Скрываем список вариантов — color picker его заменяет
                  node.style.display = 'none';
                }
              });
            });
          };

          // --- localStorage price cache ---
          const MS_CACHE_KEY = 'cryptoro_ms_prices_v1';
          const MS_CACHE_TTL = 5 * 60 * 1000; // 5 минут

          function loadPriceCache() {
            try {
              const raw = window.localStorage.getItem(MS_CACHE_KEY);
              if (!raw) return null;
              const parsed = JSON.parse(raw);
              if (!parsed || typeof parsed.ts !== 'number') return null;
              if (Date.now() - parsed.ts > MS_CACHE_TTL) return null;
              return parsed.items || null;
            } catch { return null; }
          }

          function savePriceCache(items) {
            try {
              window.localStorage.setItem(MS_CACHE_KEY, JSON.stringify({ ts: Date.now(), items: items }));
            } catch {}
          }

          const request = async () => {
            try {
              const query = new URLSearchParams();
              query.set('slugs', slugs.join(','));
              if (skuPairs) query.set('skuMap', skuPairs);
              const response = await fetch(`/api/moysklad/prices?${query.toString()}`, {
                headers: { Accept: 'application/json' }
              });
              if (!response.ok) return;
              const payload = await response.json();
              if (!payload?.ok || !payload?.items) return;
              applyItems(payload.items);
              savePriceCache(payload.items);
            } catch {
              // Фолбэк на цены из контента, если API временно недоступен.
            } finally {
              revealPrices();
            }
          };

          // Если есть свежий кэш — показываем цены мгновенно, фоново обновляем.
          const cachedPrices = loadPriceCache();
          const hasServerPrefilledPrices = msSyncPricesEnabled && priceNodes.some((node) => {
            const value = Number(node.getAttribute('data-ms-price-value') || '');
            return Number.isFinite(value) && value > 0;
          });
          if (cachedPrices) {
            applyItems(cachedPrices);
            revealPrices();
            request(); // тихое фоновое обновление
          } else if (hasServerPrefilledPrices) {
            // Русский комментарий: если цена уже подставлена на edge, не прячем её повторно.
            revealPrices();
            request(); // фоновая сверка с актуальными ценами
          } else {
            hidePendingPrices();
            window.setTimeout(() => revealPrices(), 1800);
            request();
          }
          const _msIntervalId = window.setInterval(request, 15 * 60 * 1000);
          document.addEventListener('visibilitychange', () => {
            if (document.visibilityState === 'hidden') window.clearInterval(_msIntervalId);
          }, { once: true });
        }

        function runWhenIdle(callback, timeout = 1200) {
          if ('requestIdleCallback' in window) {
            window.requestIdleCallback(() => callback(), { timeout });
            return;
          }
          window.setTimeout(callback, Math.min(240, timeout));
        }

        document.addEventListener('DOMContentLoaded', () => {
          sync();
          bindCartButtons();
          syncMoysklad();
          setupMobileNav();
          let resizeTimer = 0;
          window.addEventListener('resize', () => {
            if (resizeTimer) window.clearTimeout(resizeTimer);
            resizeTimer = window.setTimeout(setupMobileNav, 140);
          }, { passive: true });
          setupConsultModal();
          setupFadeIn();
          runWhenIdle(setupAccessibilityLabels, 1800);
          runWhenIdle(normalizeExternalLinks, 1500);
          runWhenIdle(dedupeCatalogTabs, 900);
        });
      })();
    </script>
  </body>
</html>
