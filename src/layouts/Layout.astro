---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  globalCss?: string;
  headScripts?: string;
  withChrome?: boolean;
  includeNetlifyIdentity?: boolean;
  active?: 'home' | 'catalog' | 'about';
}

const {
  title = 'CRYPTORO',
  description = '',
  image,
  globalCss = '',
  headScripts = '',
  withChrome = false,
  // Русский комментарий: по умолчанию отключаем Netlify Identity, чтобы не получать CORS/ERR_FAILED на клиентских страницах.
  includeNetlifyIdentity = false,
  active
} = Astro.props;

const ogImage = image || '/images/og-default.jpg';
const ogUrl = Astro.url?.toString() || '';
const pathname = Astro.url?.pathname || '/';
const bodyClass = [
  'site-shell',
  pathname === '/' ? 'page-home' : '',
  pathname.startsWith('/catalog') ? 'page-catalog' : '',
  pathname.startsWith('/products/') ? 'page-pdp' : '',
  pathname === '/about' ? 'page-about' : '',
  pathname === '/cart' ? 'page-cart' : '',
  pathname === '/privacy' ? 'page-privacy' : '',
  pathname === '/terms' ? 'page-terms' : '',
  pathname === '/order-success' ? 'page-order-success' : ''
]
  .filter(Boolean)
  .join(' ');
// Русский комментарий: по умолчанию не синхронизируем цены с МойСклад в рантайме — используем фиксированные цены из контента.
const msSyncPricesEnabled = String(import.meta.env.PUBLIC_MS_SYNC_PRICES ?? '0').trim() === '1';
---
<!doctype html>
<html lang="ru">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:url" content={ogUrl} />
    <meta property="og:locale" content="ru_RU" />
    <meta property="og:site_name" content="CRYPTORO" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="keywords" content="AI диктофон, CRYPTORO, Plaud Note, транскрипция, запись встреч, диктофон с ChatGPT" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <script is:inline>
      // Русский комментарий: грузим внешние шрифты после первого кадра, чтобы не блокировать стартовый рендер.
      (() => {
        const href = 'https://fonts.googleapis.com/css2?family=Unbounded:wght@700;800;900&subset=latin,cyrillic&family=Inter:wght@300;400;500;600;700&display=swap';
        const applyFonts = () => {
          if (document.querySelector('link[data-fonts="cryptoro-main"]')) return;
          const link = document.createElement('link');
          link.rel = 'stylesheet';
          link.href = href;
          link.media = 'print';
          link.onload = () => {
            link.media = 'all';
          };
          link.setAttribute('data-fonts', 'cryptoro-main');
          document.head.appendChild(link);
        };

        if ('requestIdleCallback' in window) {
          window.requestIdleCallback(applyFonts, { timeout: 1200 });
          return;
        }
        window.addEventListener('load', applyFonts, { once: true });
      })();
    </script>
    <noscript>
      <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Unbounded:wght@700;800;900&subset=latin,cyrillic&family=Inter:wght@300;400;500;600;700&display=swap" />
    </noscript>
    {includeNetlifyIdentity && <script src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>}
    {globalCss && <style is:global set:html={globalCss} />}
    {headScripts && <Fragment set:html={headScripts} />}
    <style is:global>
      :root{
        --bg:#ffffff;
        --bg-2:#f9fafb;
        --surface:rgba(255,255,255,.9);
        --surface-2:rgba(255,255,255,.82);
        --text:#111111;
        --muted:#4b5563;
        --line:rgba(29,29,31,.08);
        --accent-a:#ff4500;
        --accent-b:#ffd700;
        --glass-shadow:0 16px 48px rgba(0,0,0,.06);
        --chrome-max-width:1120px;
        --chrome-edge-gap:24px;
        --chrome-pad-x:24px;
        --chrome-nav-width:540px;
      }
      html,body{
        background:var(--bg)!important;
        color:var(--text)!important;
        font-family:'Inter',-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif!important;
      }
      .wrap,.hero-inner,.nav-inner,.foot-grid,.foot-bot,.catalog-controls,.mx-auto.max-w-7xl,.hero-grid,.tabs-wrap,.related-wrap{
        max-width:80rem!important;
        margin-left:auto!important;
        margin-right:auto!important;
        padding-left:1rem!important;
        padding-right:1rem!important;
      }
      @media (min-width:768px){
        .wrap,.hero-inner,.nav-inner,.foot-grid,.foot-bot,.catalog-controls,.mx-auto.max-w-7xl,.hero-grid,.tabs-wrap,.related-wrap{padding-left:2rem!important;padding-right:2rem!important}
      }
      @media (min-width:1024px){
        .wrap,.hero-inner,.nav-inner,.foot-grid,.foot-bot,.catalog-controls,.mx-auto.max-w-7xl,.hero-grid,.tabs-wrap,.related-wrap{padding-left:3rem!important;padding-right:3rem!important}
      }
      /* Legacy headers only — smart pill (#smart-header[data-state]) manages itself */
      header:not(#smart-header){
        background:rgba(255,255,255,.85)!important;
        border:1px solid rgba(0,0,0,.08)!important;
        backdrop-filter:blur(24px)!important;
        -webkit-backdrop-filter:blur(24px)!important;
      }
      header a, nav a, .logo, .foot-logo, .foot-col h4, .sec-title, .ftitle, .stitle, .pname, .pname2, .rvname, .wname, .dname, .payname, .clabel, .cval, h1, h2, h3, h4{
        color:var(--text)!important;
      }
      p, span, li, .sec-sub, .hero-sub, .hero-label, .fdesc, .pdesc, .rvtext, .lprivacy, .citem, .ddesc, .wdesc, .paydesc, .foot-desc, .foot-col a, .foot-bot, .faqa, .md-body, .specs-table td{
        color:var(--muted)!important;
      }
      footer{
        background:rgba(255,255,255,.92)!important;
        border-top:1px solid rgba(0,0,0,.08)!important;
        backdrop-filter:blur(20px)!important;
      }
      section, .sec, main, body.bg-zinc-100{
        background:var(--bg)!important;
      }
      /* Preserve warm hero gradients for About and Catalog pages */
      .about-hero{
        background:linear-gradient(180deg,#f7f4ef 0%,#ede7dc 100%)!important;
        border-bottom:1px solid rgba(29,29,31,.08)!important;
      }
      .catalog-hero{
        background:linear-gradient(180deg,#f7f4ef 0%,#ede7dc 100%)!important;
        border-bottom:1px solid rgba(29,29,31,.08)!important;
      }
      .sec:nth-of-type(even), .tabs-section, .related-section, .sec-products, .sec-features, .sec-usecases, .sec-pricing, .sec-reviews, .sec-faq{
        background:var(--bg-2)!important;
      }
      /* Preserve dark section — do not override with white */
      .sec-how{
        background:#1d1d1f!important;
        color:#fff!important;
      }
      .sec-how .how-title,
      .sec-how .stitle,
      .sec-how h1, .sec-how h2, .sec-how h3, .sec-how h4{
        color:#fff!important;
      }
      .sec-how p, .sec-how span, .sec-how .how-sub, .sec-how .sdesc, .sec-how .snum, .sec-how .proc-label{
        color:#9ca3af!important;
      }
      .sec-how .snum, .sec-how .proc-label{
        color:#e88635!important;
      }
      .sec-how .smock{
        background:#2a2a2a!important;
        border-color:rgba(255,255,255,.08)!important;
      }
      .sec-how .btn-woutline{
        color:#fff!important;
        background:transparent!important;
        border-color:rgba(255,255,255,.3)!important;
      }
      .sec-how .chkicon{
        color:#30d158!important;
      }
      .sec-how .recl{
        color:#ff375f!important;
      }
      .pcard,.fcard,.rvcard,.uccard,.pricingcard,.dcard,.paycard,.wcard,.mstat,.contact-cta,.citem,.faqitem,.smock,.hitem,.abadge,.tab-content,.rcard,.delivery-mini,.main-img,.reveal.relative.mb-10 > div,.consult-modal-card{
        background:var(--surface)!important;
        border-color:var(--line)!important;
        border:1px solid var(--line)!important;
        backdrop-filter:blur(20px)!important;
        box-shadow:var(--glass-shadow)!important;
        border-radius:20px!important;
      }
      /* Preserve featured pricing card accent border */
      .pricingcard.feat{
        border:2px solid rgba(17,17,17,.18)!important;
        box-shadow:0 20px 36px rgba(0,0,0,.10),0 10px 24px rgba(0,0,0,.06)!important;
        transform:translateY(-2px);
      }
      /* Featured bento card left borders */
      .fcard{
        border-left:3px solid transparent!important;
      }
      .fcard--trans{border-left-color:#3b82f6!important}
      .fcard--integrations{border-left-color:#f59e0b!important}
      .fcard--assistant{border-left-color:#22c55e!important}
      .fcard--analytics{border-left-color:#8b5cf6!important}
      /* Use-case card left borders */
      .uccard{border-left:2px solid transparent!important}
      .uc-ceo{border-left-color:#2f6dff!important}
      .uc-b2b{border-left-color:#ff7a18!important}
      .uc-med{border-left-color:#22c55e!important}
      .uc-law{border-left-color:#8b5cf6!important}
      .uc-edu{border-left-color:#38bdf8!important}
      .uc-crea{border-left-color:#ec4899!important}
      .pimg-wrap,.catalog-media,.rcard img{
        background:transparent!important;
      }
      .btn-blue,.pbtn,.pbtn2.fil,.compare-btn,.lsubmit,.buy-btn,.sticky-btn,.pbtn-preorder,.filter-btn.active,.contact-cta a,.inline-flex.w-full,.consult-btn.primary{
        background:#111!important;
        color:#fff!important;
        border:none!important;
        border-radius:16px!important;
        box-shadow:0 0 0 rgba(255,69,0,0)!important;
      }
      .pbadge,.pbadge2,.card-badge{
        background:#111!important;
        color:#fff!important;
        border:1px solid #111!important;
        box-shadow:0 2px 8px rgba(0,0,0,.15)!important;
        border-radius:980px!important;
        font-size:10px!important;
        font-weight:700!important;
        letter-spacing:.06em!important;
        padding:5px 12px!important;
      }
      .btn-blue:hover,.pbtn:hover,.pbtn2.fil:hover,.compare-btn:hover,.lsubmit:hover,.buy-btn:hover,.sticky-btn:hover,.pbtn-preorder:hover,.filter-btn.active:hover,.contact-cta a:hover,.inline-flex.w-full:hover,.consult-btn.primary:hover{
        transform:scale(1.04)!important;
        box-shadow:0 12px 24px rgba(0,0,0,.16)!important;
      }
      .btn-ghost,.pbtn2.out,.btn-woutline,.filter-btn,.sort-select,.secondary-btn,.consult-btn{
        color:#111!important;
        background:rgba(255,255,255,.86)!important;
        border:1px solid rgba(0,0,0,.18)!important;
        backdrop-filter:blur(20px)!important;
      }
      .catalog-sort{display:none!important}
      .catalog-chips{
        background:rgba(243,244,246,.9)!important;
        border-color:rgba(0,0,0,.1)!important;
        border-radius:999px!important;
      }
      .filter-btn{
        color:#111!important;
        position:relative;
      }
      .catalog-chips .filter-btn::after{
        content:'';
        position:absolute;
        left:14px;
        right:14px;
        bottom:5px;
        height:2px;
        background:#111;
        transform:scaleX(0);
        transform-origin:left center;
        transition:transform .25s ease;
      }
      .catalog-chips .filter-btn:hover::after,
      .catalog-chips .filter-btn.active::after,
      .catalog-chips .filter-btn.bg-zinc-900::after{transform:scaleX(1)}
      .filter-btn:hover{
        transform:translateY(-1px) scale(1.02)!important;
        border-color:rgba(0,0,0,.32)!important;
      }
      .faqarr{background:rgba(0,0,0,.06)!important;color:#111!important}
      .faqitem.open .faqarr{background:linear-gradient(90deg,var(--accent-a),var(--accent-b))!important;color:#111!important}
      .faqa{padding-left:1rem!important;overflow:hidden!important}
      /* Прячем динамические цены до первой синхронизации с МойСклад, чтобы не мигала старая цена */
      [data-ms-price].ms-price-pending{
        visibility:hidden!important;
      }
      [data-ms-stock]{
        display:none;
      }
      [data-ms-variants]{
        display:none;
      }
      .ms-stock-badge{
        display:inline-flex!important;
        align-items:center;
        gap:6px;
        margin:8px 0 0;
        padding:6px 11px;
        border-radius:999px;
        font-size:12px;
        font-weight:600;
        line-height:1;
        border:1px solid transparent;
        white-space:nowrap;
      }
      .catalog-title-row{
        display:flex;
        align-items:center;
        justify-content:space-between;
        gap:10px;
        min-width:0;
      }
      .catalog-title-row h3{
        margin:0;
        min-width:0;
        flex:1;
      }
      .catalog-title-stock{
        margin:0 0 0 auto;
        flex-shrink:0;
      }
      .ms-stock-badge.ms-in-stock{
        color:#166534;
        background:#ecfdf3;
        border-color:#86efac;
      }
      .ms-stock-badge.ms-low-stock{
        color:#b45309;
        background:#fff7ed;
        border-color:#fdba74;
      }
      .ms-stock-badge.ms-preorder{
        color:#9a3412;
        background:#ffedd5;
        border-color:#fdba74;
      }
      .ms-variant-list{
        display:grid;
        gap:6px;
        margin-top:8px;
      }
      .ms-variant-item{
        display:flex;
        align-items:center;
        justify-content:space-between;
        gap:8px;
        padding:5px 8px;
        border-radius:8px;
        border:1px solid rgba(0,0,0,.06);
        background:#f9fafb;
        color:#374151;
        font-size:12px;
        line-height:1.3;
      }
      .ms-variant-item b{
        font-weight:500;
        color:#374151;
        flex:1;
      }
      .ms-variant-value{
        white-space:nowrap;
        font-size:11px;
        font-weight:500;
        color:#6b7280;
      }
      .ms-variant-value.is-preorder{color:#b45309}
      .ms-variant-value.is-low{color:#b45309}
      .ms-variant-value.is-empty{color:#b45309}
      .ms-dot{
        width:7px;
        height:7px;
        border-radius:50%;
        flex-shrink:0;
      }
      .dot-instock{background:#22c55e}
      .dot-low{background:#f59e0b}
      .dot-preorder{background:#d1d5db;border:1px solid #9ca3af}
      /* Improved focus states for form inputs across all pages */
      .linput:focus,.consult-input:focus,.field-grid input:focus{
        border-color:#111!important;
        box-shadow:0 0 0 3px rgba(17,17,17,.08)!important;
        outline:none!important;
      }
      .buy-btn.is-disabled,[data-ms-buy-btn].is-disabled{
        opacity:.58!important;
        cursor:not-allowed!important;
        box-shadow:none!important;
        transform:none!important;
      }
      .section-divider,.foot-div,hr{border-color:rgba(0,0,0,.12)!important}
      .reveal,.pcard,.rcard,.fcard,.dcard,.wcard,.paycard,.mstat,.faqitem{
        transition:transform .3s ease-out,box-shadow .3s ease-out,opacity .3s ease-out!important;
      }
      .pcard:hover,.rcard:hover,.fcard:hover,.dcard:hover,.wcard:hover,.paycard:hover,.mstat:hover{
        transform:translateY(-4px) scale(1.02)!important;
        box-shadow:0 18px 32px rgba(0,0,0,.14)!important;
      }
      .hero-title,.prod-name,.sec-title,.lead-title{
        font-family:'Unbounded','Inter',sans-serif!important;
      }
      .hero{
        /* Русский комментарий: убираем теплое glow-пятно в hero, оставляем чистый Apple-style фон */
        background:linear-gradient(180deg,#ffffff 0%,#f9fafb 100%)!important;
      }
      /* Русский комментарий: не перебиваем локальную hero-анимацию из index.html */
      .hero-product-image img{
        will-change:transform;
      }
      .hero-title{color:#111!important}
      .hero-sub,.hero-label{color:#4b5563!important}
      .hero .btn-ghost{border-color:rgba(0,0,0,.2)!important;color:#111!important}
      .hero .btn-ghost:hover{border-color:#111!important}
      .mobile-menu-toggle{
        display:none;
        align-items:center;
        justify-content:center;
        width:44px;
        height:44px;
        border:1px solid rgba(0,0,0,.14);
        border-radius:999px;
        background:#fff;
        color:#111;
        cursor:pointer;
      }
      .mobile-nav-panel{
        display:none;
        position:absolute;
        top:calc(100% + 8px);
        left:12px;
        right:12px;
        background:#fff;
        border:1px solid rgba(0,0,0,.1);
        border-radius:14px;
        box-shadow:0 14px 34px rgba(0,0,0,.12);
        padding:12px;
        z-index:120;
      }
      .mobile-nav-close{
        display:flex;
        align-items:center;
        justify-content:center;
        width:44px;
        height:44px;
        border:1px solid rgba(0,0,0,.14);
        border-radius:999px;
        background:#fff;
        color:#111;
        font-size:18px;
        line-height:1;
        margin:0 0 8px auto;
        cursor:pointer;
      }
      .mobile-nav-panel a{
        display:flex;
        align-items:center;
        min-height:44px;
        padding:10px 12px;
        border-radius:10px;
        color:#111;
        font-size:15px;
        text-decoration:none;
      }
      .mobile-nav-panel a:hover{background:#f3f4f6}
      .mobile-nav-open .mobile-nav-panel{display:block}
      .consult-modal{
        position:fixed;
        inset:0;
        display:flex;
        align-items:center;
        justify-content:center;
        z-index:140;
        background:rgba(17,24,39,.5);
        padding:16px;
        opacity:0;
        visibility:hidden;
        pointer-events:none;
        transition:opacity .18s ease, visibility .18s ease;
      }
      .consult-modal.open{
        opacity:1;
        visibility:visible;
        pointer-events:auto;
      }
      .consult-modal-card{
        width:min(560px,100%);
        background:#fff;
        color:#111;
        border-radius:18px;
        border:1px solid rgba(255,255,255,.3);
        box-shadow:0 4px 30px rgba(0,0,0,.1);
        backdrop-filter:blur(20px);
        padding:20px;
        position:relative;
        transform:translateY(14px);
        opacity:.98;
        transition:transform .18s ease, opacity .18s ease;
      }
      .consult-modal.open .consult-modal-card{transform:translateY(0);opacity:1}
      .consult-modal-head{display:flex;align-items:flex-start;justify-content:space-between;gap:10px;margin-bottom:8px}
      .consult-modal-title{
        font-family:'Unbounded',sans-serif;
        font-size:24px;
        line-height:1.15;
        margin:0;
      }
      .consult-modal-sub{color:#4b5563;font-size:14px;line-height:1.6;margin-bottom:14px}
      .consult-close{
        width:44px;
        height:44px;
        border-radius:999px;
        border:1px solid rgba(0,0,0,.14);
        background:rgba(255,255,255,.9);
        color:#111;
        display:inline-flex;
        align-items:center;
        justify-content:center;
        cursor:pointer;
        font-size:18px;
        line-height:1;
        flex-shrink:0;
        transition:box-shadow .18s ease, transform .18s ease, border-color .18s ease;
      }
      .consult-close:hover{transform:translateY(-1px);box-shadow:0 6px 16px rgba(0,0,0,.08)}
      .consult-close:focus-visible{
        outline:2px solid #111;
        outline-offset:2px;
      }
      .consult-grid{display:grid;gap:10px}
      .consult-input{
        width:100%;
        border:1px solid rgba(0,0,0,.14);
        border-radius:12px;
        padding:12px 14px;
        font-size:15px;
        font-family:'Inter',sans-serif;
        color:#111;
        background:#fff;
      }
      .consult-input:focus-visible{
        outline:2px solid rgba(17,17,17,.9);
        outline-offset:1px;
        border-color:rgba(17,17,17,.28);
      }
      .consult-help{
        margin:2px 0 0;
        font-size:12px;
        color:#6b7280;
        line-height:1.4;
      }
      .consult-status{
        min-height:20px;
        font-size:13px;
        line-height:1.4;
        color:#4b5563;
      }
      .consult-status.is-loading{color:#374151}
      .consult-status.is-success{color:#166534}
      .consult-status.is-error{color:#b91c1c}
      .consult-actions{
        display:flex;
        gap:10px;
        justify-content:flex-end;
        margin-top:12px;
      }
      .consult-btn{
        border:1px solid rgba(0,0,0,.2);
        border-radius:12px;
        padding:10px 14px;
        font-size:14px;
        font-weight:600;
        cursor:pointer;
        background:#fff;
        color:#111;
      }
      .consult-btn:focus-visible{
        outline:2px solid #111;
        outline-offset:2px;
      }
      .consult-btn[disabled]{opacity:.7;cursor:not-allowed}
      .consult-btn.primary{
        background:#111;
        border-color:#111;
        color:#fff;
      }
      body.consult-open{overflow:hidden}
      @media (prefers-reduced-motion: reduce){
        .consult-modal,.consult-modal-card,.consult-close{transition:none!important}
      }
      .fade-in{
        opacity:0;
        transform:translateY(16px);
        transition:opacity .52s ease, transform .52s ease;
      }
      .fade-in.in-view{
        opacity:1;
        transform:translateY(0);
      }
      /* Intermediate breakpoint for tablet: 2 columns for product/use-case grids */
      @media (max-width: 1024px){
        .products-grid{grid-template-columns:repeat(2,1fr)!important}
