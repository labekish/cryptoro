---
import Layout from '../layouts/Layout.astro';
import { optimizeLegacyImages, parseLegacyPage } from '../lib/legacy';
import catalogHtml from '../../catalog.html?raw';

const page = parseLegacyPage(catalogHtml);
type ProductFM = { slug: string; price: number; sku?: string; skus?: string[] };
const modules = import.meta.glob('../content/products/*.{md,mdx}', { eager: true }) as Record<
  string,
  { frontmatter: ProductFM }
>;
const prices = Object.values(modules).reduce<Record<string, number>>((acc, mod) => {
  if (mod.frontmatter?.slug) acc[mod.frontmatter.slug] = Number(mod.frontmatter.price || 0);
  return acc;
}, {});
const manualCatalogPrices: Record<string, number> = {
  // Русский комментарий: карточка чехлов без отдельного контент-файла, цена рассчитана из MS snapshot + доставка (группа аксессуаров) с округлением.
  'plaud-note-cases': 4550,
  // Русский комментарий: подписки AI без отдельного контент-файла, для них по правилам проекта надбавка доставки = 0.
  'plaud-ai-pro-12m': 12590,
  'plaud-ai-unlimited-12m': 26240
};
const catalogPrices: Record<string, number> = { ...manualCatalogPrices, ...prices };
const skus = Object.values(modules).reduce<Record<string, string[]>>((acc, mod) => {
  if (!mod.frontmatter?.slug) return acc;
  const nextSkus = [
    ...(Array.isArray(mod.frontmatter?.skus) ? mod.frontmatter.skus : []),
    ...(mod.frontmatter?.sku ? [mod.frontmatter.sku] : [])
  ].filter(Boolean);
  if (nextSkus.length) acc[mod.frontmatter.slug] = Array.from(new Set(nextSkus));
  return acc;
}, {});
const manualCatalogSkus: Record<string, string[]> = {
  // Русский комментарий: карточка чехлов пока без отдельной страницы товара, но с полной МойСклад-синхронизацией.
  'plaud-note-cases': ['AC-39', 'AC-38', 'AC-37', 'AC-36', 'AC-60'],
  // Русский комментарий: подписки PLAUD AI показываем в каталоге как аксессуары без отдельной карточки товара.
  'plaud-ai-pro-12m': ['AC-61'],
  'plaud-ai-unlimited-12m': ['AC-59']
};
const skuMap = { ...skus, ...manualCatalogSkus };
const formatPrice = (value: number) => `${Math.round(Number(value || 0)).toLocaleString('ru-RU')} ₽`;

let syncedBody = page.body;
const cardSlugs = [
  'vspomnit',
  // Русский комментарий: дополнительная карточка CR-227 ("Лови Момент" Pin) в общем списке каталога.
  'lovi-moment-pin',
  'plaud-note',
  'plaud-note-pro',
  'notepin',
  'accessories',
  'plaud-note-cases',
  'plaud-ai-pro-12m',
  'plaud-ai-unlimited-12m'
];
const catalogSeoTitle = 'AI диктофоны с автоматической расшифровкой речи | CRYPTORO';
const catalogSeoDescription =
  'AI диктофоны для записи разговоров, лекций и встреч с автоматической расшифровкой речи, транскрибацией и умными заметками.';
const catalogSeoTextSection = `
  <section class="px-6 pt-10 pb-16 md:pt-12" data-seo-block="catalog-ai-dictophones">
    <div class="mx-auto max-w-7xl rounded-2xl border border-zinc-200/90 bg-zinc-50/60 px-6 py-8 md:px-8 md:py-10">
      <div class="flex flex-col gap-3">
        <p class="text-sm font-semibold uppercase tracking-[0.12em] text-zinc-500">Подробнее об AI диктофонах</p>
        <h2 class="text-2xl font-semibold tracking-tight text-zinc-900 md:text-3xl">AI диктофоны для записи и расшифровки речи</h2>
      </div>
      <div class="mt-6 grid grid-cols-1 gap-4 md:grid-cols-3">
        <article class="rounded-2xl border border-zinc-200 bg-white p-4 shadow-[0_8px_26px_rgba(17,24,39,.05)]">
          <div class="flex h-28 w-full items-center justify-center rounded-xl bg-gradient-to-br from-zinc-100 to-zinc-50">
            <svg aria-hidden="true" viewBox="0 0 64 64" class="h-12 w-12 text-zinc-700">
              <rect x="24" y="12" width="16" height="24" rx="8" fill="none" stroke="currentColor" stroke-width="3"></rect>
              <path d="M16 28v2c0 8.8 7.2 16 16 16s16-7.2 16-16v-2" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round"></path>
              <line x1="32" y1="46" x2="32" y2="54" stroke="currentColor" stroke-width="3" stroke-linecap="round"></line>
              <line x1="24" y1="54" x2="40" y2="54" stroke="currentColor" stroke-width="3" stroke-linecap="round"></line>
            </svg>
          </div>
          <h3 class="mt-4 text-base font-semibold text-zinc-900">Запись разговоров и встреч</h3>
          <p class="mt-2 text-[15px] leading-7 text-zinc-600">AI диктофоны - это новое поколение устройств для записи разговоров, лекций и деловых встреч. Такие устройства используют технологии искусственного интеллекта для автоматической расшифровки речи, создания заметок и поиска информации в аудиозаписях.</p>
        </article>
        <article class="rounded-2xl border border-zinc-200 bg-white p-4 shadow-[0_8px_26px_rgba(17,24,39,.05)]">
          <div class="flex h-28 w-full items-center justify-center rounded-xl bg-gradient-to-br from-zinc-100 to-zinc-50">
            <svg aria-hidden="true" viewBox="0 0 64 64" class="h-12 w-12 text-zinc-700">
              <rect x="15" y="10" width="34" height="44" rx="6" fill="none" stroke="currentColor" stroke-width="3"></rect>
              <line x1="23" y1="23" x2="41" y2="23" stroke="currentColor" stroke-width="3" stroke-linecap="round"></line>
              <line x1="23" y1="31" x2="41" y2="31" stroke="currentColor" stroke-width="3" stroke-linecap="round"></line>
              <line x1="23" y1="39" x2="35" y2="39" stroke="currentColor" stroke-width="3" stroke-linecap="round"></line>
              <circle cx="50" cy="18" r="4" fill="none" stroke="currentColor" stroke-width="3"></circle>
            </svg>
          </div>
          <h3 class="mt-4 text-base font-semibold text-zinc-900">Транскрибация и конспекты</h3>
          <p class="mt-2 text-[15px] leading-7 text-zinc-600">Диктофоны Plaud позволяют быстро записывать разговоры и автоматически переводить аудио в текст. Благодаря интеграции с современными AI-алгоритмами записи можно структурировать, выделять ключевые моменты и получать краткие конспекты встреч.</p>
        </article>
        <article class="rounded-2xl border border-zinc-200 bg-white p-4 shadow-[0_8px_26px_rgba(17,24,39,.05)]">
          <div class="flex h-28 w-full items-center justify-center rounded-xl bg-gradient-to-br from-zinc-100 to-zinc-50">
            <svg aria-hidden="true" viewBox="0 0 64 64" class="h-12 w-12 text-zinc-700">
              <circle cx="12" cy="32" r="5" fill="none" stroke="currentColor" stroke-width="3"></circle>
              <circle cx="32" cy="14" r="5" fill="none" stroke="currentColor" stroke-width="3"></circle>
              <circle cx="52" cy="32" r="5" fill="none" stroke="currentColor" stroke-width="3"></circle>
              <circle cx="32" cy="50" r="5" fill="none" stroke="currentColor" stroke-width="3"></circle>
              <line x1="17" y1="30" x2="27" y2="18" stroke="currentColor" stroke-width="3" stroke-linecap="round"></line>
              <line x1="37" y1="18" x2="47" y2="30" stroke="currentColor" stroke-width="3" stroke-linecap="round"></line>
              <line x1="47" y1="34" x2="37" y2="46" stroke="currentColor" stroke-width="3" stroke-linecap="round"></line>
              <line x1="27" y1="46" x2="17" y2="34" stroke="currentColor" stroke-width="3" stroke-linecap="round"></line>
            </svg>
          </div>
          <h3 class="mt-4 text-base font-semibold text-zinc-900">Для учебы и бизнеса</h3>
          <p class="mt-2 text-[15px] leading-7 text-zinc-600">AI диктофоны подходят для студентов, предпринимателей, журналистов и всех, кому важно сохранять информацию из разговоров и встреч. Устройства помогают экономить время на расшифровке аудио и упрощают работу с голосовыми заметками.</p>
        </article>
      </div>
    </div>
  </section>
`;

function patchCard(slug: string, patcher: (cardHtml: string) => string) {
  const cardRegex = new RegExp(`(<a[^>]*data-card-id="${slug}"[^>]*>[\\s\\S]*?<\\/a>)`, 'i');
  syncedBody = syncedBody.replace(cardRegex, (cardHtml) => patcher(cardHtml));
}

cardSlugs.forEach((slug) => {
  const price = catalogPrices[slug];
  if (price == null) return;

  patchCard(slug, (cardHtml) => {
    let next = cardHtml;
    // Русский комментарий: нормализуем старую разметку цены (span -> div), чтобы не наследовался muted-цвет из глобальных правил.
    next = next.replace(
      /(<div class="catalog-price-row">\s*)<span class="text-2xl font-bold"([^>]*)>([^<]*)<\/span>(\s*<\/div>)/i,
      `$1<div class="text-2xl font-bold"$2>$3</div>$4`
    );
    next = next.replace(/(data-price=")([^"]*)(")/i, `$1${Math.round(price)}$3`);
    next = next.replace(/(<div class="text-2xl font-bold">)([^<]*)(<\/div>)/i, `$1${formatPrice(price)}$3`);
    next = next.replace(/(<span class="text-2xl font-bold">)([^<]*)(<\/span>)/i, `$1${formatPrice(price)}$3`);
    return next;
  });
});

Object.entries(skuMap).forEach(([slug, skuList]) => {
  const primarySku = skuList[0];
  if (!primarySku) return;
  const skuListCsv = skuList.join(',');
  patchCard(slug, (cardHtml) => {
    let next = cardHtml;

    if (!/data-ms-sku=/i.test(next)) {
      next = next.replace(/<a([^>]*?)>/i, `<a$1 data-ms-sku="${primarySku}" data-ms-skus="${skuListCsv}">`);
    } else if (!/data-ms-skus=/i.test(next)) {
      next = next.replace(/<a([^>]*?)data-ms-sku="[^"]*"([^>]*?)>/i, `<a$1data-ms-sku="${primarySku}" data-ms-skus="${skuListCsv}"$2>`);
    }

    next = next.replace(
      /(<div class="text-2xl font-bold")(?![^>]*data-ms-price)([^>]*>)/i,
      `$1 data-ms-price="${slug}"$2`
    );
    next = next.replace(
      /(<span class="text-2xl font-bold")(?![^>]*data-ms-price)([^>]*>)/i,
      `$1 data-ms-price="${slug}"$2`
    );
    // Русский комментарий: переносим плашку статуса в верхнюю строку карточки рядом с бейджем года.
    next = next.replace(new RegExp(`<(?:div|span)[^>]*data-ms-stock="${slug}"[^>]*>\\s*</(?:div|span)>`, 'ig'), '');
    if (!new RegExp(`data-ms-stock="${slug}"`, 'i').test(next)) {
      const withTopBadge = next.replace(
        /(<div class="catalog-card-top">[\s\S]*?<div class="catalog-card-tags">[\s\S]*?)(<\/div>)/i,
        `$1<div data-ms-stock="${slug}" class="ms-stock-badge catalog-top-stock"></div>$2`
      );
      if (withTopBadge !== next) {
        next = withTopBadge;
      } else {
        next = next.replace(
          /(<div class="catalog-card-top">)/i,
          `$1<div data-ms-stock="${slug}" class="ms-stock-badge catalog-top-stock"></div>`
        );
      }
    }
    return next;
  });
});

// Русский комментарий: фиксируем SEO H1 в hero-блоке каталога согласно ТЗ.
syncedBody = syncedBody.replace(
  /<h1 class="font-display text-4xl font-black tracking-tight md:text-6xl">[\s\S]*?<\/h1>/i,
  '<h1 class="font-display text-4xl font-black tracking-tight md:text-6xl">AI диктофоны с автоматической расшифровкой речи</h1>'
);

// Русский комментарий: добавляем SEO-текст перед футером, чтобы соблюсти структуру из ТЗ.
if (!syncedBody.includes('data-seo-block="catalog-ai-dictophones"')) {
  syncedBody = syncedBody.replace('</main>', `${catalogSeoTextSection}\n  </main>`);
}

// Русский комментарий: убираем внешний runtime иконок (unpkg) и заменяем на inline SVG.
syncedBody = syncedBody.replace(/<script\s+src="https:\/\/unpkg\.com\/lucide@latest"><\/script>\s*/i, '');
syncedBody = syncedBody.replace(/\s*lucide\.createIcons\(\);\s*/i, '\n');
syncedBody = syncedBody.replace(
  /<i data-lucide="sparkles" class="h-4 w-4"><\/i>/i,
  '<svg aria-hidden="true" viewBox="0 0 24 24" class="h-4 w-4" fill="none"><path d="M12 3l1.9 4.5L18 9.4l-4.1 1.9L12 16l-1.9-4.7L6 9.4l4.1-1.9L12 3z" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"></path></svg>'
);

// Русский комментарий: убираем принудительный reflow ради анимации фильтра, чтобы не ловить Forced reflow в Lighthouse.
syncedBody = syncedBody.replace(
  /void activeBtn\.offsetWidth;\s*activeBtn\.classList\.add\('is-activating'\);/i,
  "window.requestAnimationFrame(() => activeBtn.classList.add('is-activating'));"
);

// Русский комментарий: добавляем размеры/ленивую загрузку карточек каталога.
syncedBody = optimizeLegacyImages(syncedBody, {
  eagerFirstMatchSrc: ['/images/products/vspomnit-vse-cutout.png']
});
---
<Layout
  title={catalogSeoTitle}
  description={catalogSeoDescription}
  globalCss={page.css}
  headScripts={page.headScripts}
  withChrome={true}
  active="catalog"
>
  <Fragment set:html={syncedBody} />
</Layout>
