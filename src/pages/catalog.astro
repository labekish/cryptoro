---
import Layout from '../layouts/Layout.astro';
import { parseLegacyPage } from '../lib/legacy';
import catalogHtml from '../../catalog.html?raw';

const page = parseLegacyPage(catalogHtml);
type ProductFM = { slug: string; price: number; sku?: string; skus?: string[] };
const modules = import.meta.glob('../content/products/*.{md,mdx}', { eager: true }) as Record<
  string,
  { frontmatter: ProductFM }
>;
const prices = Object.values(modules).reduce<Record<string, number>>((acc, mod) => {
  if (mod.frontmatter?.slug) acc[mod.frontmatter.slug] = Number(mod.frontmatter.price || 0);
  return acc;
}, {});
const skus = Object.values(modules).reduce<Record<string, string[]>>((acc, mod) => {
  if (!mod.frontmatter?.slug) return acc;
  const nextSkus = [
    ...(Array.isArray(mod.frontmatter?.skus) ? mod.frontmatter.skus : []),
    ...(mod.frontmatter?.sku ? [mod.frontmatter.sku] : [])
  ].filter(Boolean);
  if (nextSkus.length) acc[mod.frontmatter.slug] = Array.from(new Set(nextSkus));
  return acc;
}, {});
const manualCatalogSkus: Record<string, string[]> = {
  // Русский комментарий: карточка чехлов пока без отдельной страницы товара, но с полной МойСклад-синхронизацией.
  'plaud-note-cases': ['AC-39', 'AC-38', 'AC-37', 'AC-36', 'AC-60']
};
const skuMap = { ...skus, ...manualCatalogSkus };
const formatPrice = (value: number) => `${Math.round(Number(value || 0)).toLocaleString('ru-RU')} ₽`;

let syncedBody = page.body;
const cardSlugs = ['vspomnit', 'plaud-note', 'plaud-note-pro', 'notepin', 'accessories', 'plaud-note-cases'];
const catalogSeoTitle = 'AI диктофоны с автоматической расшифровкой речи | CRYPTORO';
const catalogSeoDescription =
  'AI диктофоны для записи разговоров, лекций и встреч с автоматической расшифровкой речи, транскрибацией и умными заметками.';
const catalogSeoTextSection = `
  <section class="px-6 pb-16" data-seo-block="catalog-ai-dictophones">
    <div class="mx-auto max-w-7xl rounded-2xl border border-zinc-200/80 bg-white px-6 py-7 md:px-8 md:py-9">
      <h2 class="text-2xl font-semibold tracking-tight text-zinc-900 md:text-3xl">AI диктофоны для записи и расшифровки речи</h2>
      <div class="mt-5 space-y-4 text-[15px] leading-7 text-zinc-700 md:text-base">
        <p>AI диктофоны - это новое поколение устройств для записи разговоров, лекций и деловых встреч. Такие устройства используют технологии искусственного интеллекта для автоматической расшифровки речи, создания заметок и поиска информации в аудиозаписях.</p>
        <p>Диктофоны Plaud позволяют быстро записывать разговоры и автоматически переводить аудио в текст. Благодаря интеграции с современными AI-алгоритмами записи можно структурировать, выделять ключевые моменты и получать краткие конспекты встреч.</p>
        <p>AI диктофоны подходят для студентов, предпринимателей, журналистов и всех, кому важно сохранять информацию из разговоров и встреч. Устройства помогают экономить время на расшифровке аудио и упрощают работу с голосовыми заметками.</p>
      </div>
    </div>
  </section>
`;

function patchCard(slug: string, patcher: (cardHtml: string) => string) {
  const cardRegex = new RegExp(`(<a[^>]*data-card-id="${slug}"[^>]*>[\\s\\S]*?<\\/a>)`, 'i');
  syncedBody = syncedBody.replace(cardRegex, (cardHtml) => patcher(cardHtml));
}

cardSlugs.forEach((slug) => {
  const price = prices[slug];
  if (price == null) return;

  patchCard(slug, (cardHtml) => {
    let next = cardHtml;
    next = next.replace(/(data-price=")([^"]*)(")/i, `$1${Math.round(price)}$3`);
    next = next.replace(/(<div class="text-2xl font-bold">)([^<]*)(<\/div>)/i, `$1${formatPrice(price)}$3`);
    next = next.replace(/(<span class="text-2xl font-bold">)([^<]*)(<\/span>)/i, `$1${formatPrice(price)}$3`);
    return next;
  });
});

Object.entries(skuMap).forEach(([slug, skuList]) => {
  const primarySku = skuList[0];
  if (!primarySku) return;
  const skuListCsv = skuList.join(',');
  patchCard(slug, (cardHtml) => {
    let next = cardHtml;

    if (!/data-ms-sku=/i.test(next)) {
      next = next.replace(/<a([^>]*?)>/i, `<a$1 data-ms-sku="${primarySku}" data-ms-skus="${skuListCsv}">`);
    } else if (!/data-ms-skus=/i.test(next)) {
      next = next.replace(/<a([^>]*?)data-ms-sku="[^"]*"([^>]*?)>/i, `<a$1data-ms-sku="${primarySku}" data-ms-skus="${skuListCsv}"$2>`);
    }

    next = next.replace(
      /(<div class="text-2xl font-bold")(?![^>]*data-ms-price)([^>]*>)/i,
      `$1 data-ms-price="${slug}"$2`
    );
    next = next.replace(
      /(<span class="text-2xl font-bold")(?![^>]*data-ms-price)([^>]*>)/i,
      `$1 data-ms-price="${slug}"$2`
    );
    // Русский комментарий: переносим плашку статуса в верхнюю строку карточки рядом с бейджем года.
    next = next.replace(new RegExp(`<(?:div|span)[^>]*data-ms-stock="${slug}"[^>]*>\\s*</(?:div|span)>`, 'ig'), '');
    if (!new RegExp(`data-ms-stock="${slug}"`, 'i').test(next)) {
      const withTopBadge = next.replace(
        /(<div class="catalog-card-top">[\s\S]*?<div class="catalog-card-tags">[\s\S]*?)(<\/div>)/i,
        `$1<div data-ms-stock="${slug}" class="ms-stock-badge catalog-top-stock"></div>$2`
      );
      if (withTopBadge !== next) {
        next = withTopBadge;
      } else {
        next = next.replace(
          /(<div class="catalog-card-top">)/i,
          `$1<div data-ms-stock="${slug}" class="ms-stock-badge catalog-top-stock"></div>`
        );
      }
    }
    return next;
  });
});

// Русский комментарий: фиксируем SEO H1 в hero-блоке каталога согласно ТЗ.
syncedBody = syncedBody.replace(
  /<h1 class="font-display text-4xl font-black tracking-tight md:text-6xl">[\s\S]*?<\/h1>/i,
  '<h1 class="font-display text-4xl font-black tracking-tight md:text-6xl">AI диктофоны с автоматической расшифровкой речи</h1>'
);

// Русский комментарий: добавляем SEO-текст перед футером, чтобы соблюсти структуру из ТЗ.
if (!syncedBody.includes('data-seo-block="catalog-ai-dictophones"')) {
  syncedBody = syncedBody.replace('</main>', `${catalogSeoTextSection}\n  </main>`);
}
---
<Layout
  title={catalogSeoTitle}
  description={catalogSeoDescription}
  globalCss={page.css}
  headScripts={page.headScripts}
  withChrome={true}
  active="catalog"
>
  <Fragment set:html={syncedBody} />
</Layout>
