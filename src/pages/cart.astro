---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Корзина | CRYPTORO" description="Оформление заказа CRYPTORO" withChrome={true} active="catalog">
  <main class="cart-page">
    <section class="cart-wrap">
      <div class="cart-head">
        <h1>Корзина</h1>
        <p>Проверьте состав заказа, заполните данные для доставки и отправьте заявку.</p>
      </div>

      <div class="cart-grid">
        <div class="cart-panel">
          <div id="cartEmpty" class="empty-state" hidden>
            <p>Корзина пуста. Добавьте товар из каталога.</p>
            <a class="dark-btn" href="/catalog">Перейти в каталог</a>
          </div>
          <div id="cartList" class="items-list"></div>
        </div>

        <div class="checkout-panel" id="checkoutPanel">
          <h2>Оформление заказа</h2>
          <div class="summary-row">
            <span>Итоговая сумма</span>
            <strong id="cartTotal">0 ₽</strong>
          </div>
          <p id="checkoutHint" class="checkout-hint">Добавьте товар в корзину, чтобы заполнить форму заказа.</p>

          <form id="checkoutForm" class="checkout-form">
            <div class="field-grid">
              <label>Имя и фамилия
                <input name="fullName" type="text" placeholder="Иван Иванов" autocomplete="name" required />
              </label>
              <label>Телефон
                <input name="phone" type="tel" inputmode="tel" placeholder="+7 (___) ___-__-__" autocomplete="tel" data-mask="phone" required />
              </label>
              <label>Email
                <input name="email" type="email" placeholder="example@mail.ru" autocomplete="email" required />
              </label>
            </div>

            <div class="field-grid">
              <label>Город
                <input name="city" type="text" placeholder="Москва" autocomplete="address-level2" required />
              </label>
              <label>Улица, дом
                <input name="street" type="text" placeholder="Тверская, 10" autocomplete="street-address" required />
              </label>
              <label>Квартира / офис
                <input name="apartment" type="text" placeholder="Необязательно" />
              </label>
              <label>Индекс
                <input name="zip" type="text" inputmode="numeric" pattern="[0-9]{6}" maxlength="6" placeholder="123456" autocomplete="postal-code" data-mask="zip" required />
              </label>
            </div>

            <div class="delivery-group" role="radiogroup" aria-labelledby="deliveryGroupTitle">
              <div class="delivery-group-head">
                <h3 id="deliveryGroupTitle" class="delivery-group-title">Способ доставки</h3>
              </div>
              <div class="delivery-options">
                <label class="delivery-option">
                  <input type="radio" name="delivery" value="Ozon Доставка (расчёт на сайте)" />
                  <span class="delivery-option-body">
                    <span class="delivery-option-title">Ozon Доставка</span>
                    <span class="delivery-option-sub">Расчёт на сайте после заполнения адреса</span>
                  </span>
                </label>
                <label class="delivery-option">
                  <input type="radio" name="delivery" value="СДЭК (2–7 дней)" checked />
                  <span class="delivery-option-body">
                    <span class="delivery-option-title">СДЭК</span>
                    <span class="delivery-option-sub">Ориентировочно 2–7 дней</span>
                  </span>
                </label>
                <label class="delivery-option">
                  <input type="radio" name="delivery" value="Почта России (5–14 дней)" />
                  <span class="delivery-option-body">
                    <span class="delivery-option-title">Почта России</span>
                    <span class="delivery-option-sub">Ориентировочно 5–14 дней</span>
                  </span>
                </label>
                <label class="delivery-option">
                  <input type="radio" name="delivery" value="Яндекс Доставка (Москва, 1 день)" />
                  <span class="delivery-option-body">
                    <span class="delivery-option-title">Яндекс Доставка</span>
                    <span class="delivery-option-sub">Только Москва, обычно 1 день</span>
                  </span>
                </label>
              </div>
              <div id="deliveryQuote" class="delivery-quote" hidden>
                <strong id="deliveryQuoteTitle">Расчёт СДЭК</strong>
                <p id="deliveryQuoteMeta">Заполните адрес и выберите способ доставки</p>
              </div>
              <p id="deliveryQuoteHint" class="delivery-note">Точную стоимость доставки сообщим после оформления заказа</p>
            </div>

            <div class="actions">
              <button type="submit" id="submitBtn" class="dark-btn">Оформить заказ</button>
              <button type="button" id="cardPayBtn" class="ghost-btn" title="Оплата картой будет доступна в ближайшее время">Оплатить картой (скоро)</button>
            </div>
          </form>

          <p id="formMessage" class="form-message" aria-live="polite"></p>
        </div>
      </div>
    </section>
  </main>

  <script>
    import { clearCart, getCart, getCartCount, removeFromCart, updateCartQty } from '../utils/cart';

    const cartList = document.getElementById('cartList');
    const cartEmpty = document.getElementById('cartEmpty');
    const cartTotal = document.getElementById('cartTotal');
    const checkoutForm = document.getElementById('checkoutForm');
    const checkoutPanel = document.getElementById('checkoutPanel');
    const checkoutHint = document.getElementById('checkoutHint');
    const submitBtn = document.getElementById('submitBtn');
    const cardPayBtn = document.getElementById('cardPayBtn');
    const formMessage = document.getElementById('formMessage');
    const deliveryInputs = Array.from(document.querySelectorAll('input[name="delivery"]'));
    const phoneInput = checkoutForm?.querySelector('input[data-mask="phone"]');
    const zipInput = checkoutForm?.querySelector('input[data-mask="zip"]');
    const cityInput = checkoutForm?.querySelector('input[name="city"]');
    const streetInput = checkoutForm?.querySelector('input[name="street"]');
    const apartmentInput = checkoutForm?.querySelector('input[name="apartment"]');
    const deliveryQuote = document.getElementById('deliveryQuote');
    const deliveryQuoteTitle = document.getElementById('deliveryQuoteTitle');
    const deliveryQuoteMeta = document.getElementById('deliveryQuoteMeta');
    const deliveryQuoteHint = document.getElementById('deliveryQuoteHint');
    let cdekQuoteSummary = '';
    let cdekQuotePrice = 0;
    let cdekQuoteTimer: ReturnType<typeof setTimeout> | null = null;
    let cdekQuoteRequestId = 0;

    function money(value) {
      return `${new Intl.NumberFormat('ru-RU').format(value)} ₽`;
    }

    function updateDeliveryOptionState() {
      // Подсветка выбранного способа доставки, чтобы блок читался как карточки.
      deliveryInputs.forEach((input) => {
        const option = input.closest('.delivery-option');
        if (!(option instanceof HTMLElement)) return;
        option.classList.toggle('is-selected', input.checked);
      });
    }

    function isCdekSelected() {
      const selected = deliveryInputs.find((input) => input.checked);
      if (!selected) return false;
      return String(selected.value || '').toLowerCase().includes('сдэк');
    }

    function hideDeliveryQuote() {
      if (deliveryQuote instanceof HTMLElement) {
        deliveryQuote.hidden = true;
        deliveryQuote.classList.remove('is-idle');
        deliveryQuote.classList.remove('is-error');
      }
      cdekQuoteSummary = '';
      cdekQuotePrice = 0;
    }

    function setDeliveryQuoteIdle(message) {
      if (!(deliveryQuote instanceof HTMLElement)) return;
      if (!(deliveryQuoteTitle instanceof HTMLElement)) return;
      if (!(deliveryQuoteMeta instanceof HTMLElement)) return;
      deliveryQuote.hidden = false;
      deliveryQuote.classList.remove('is-error');
      deliveryQuote.classList.add('is-idle');
      deliveryQuoteTitle.textContent = 'Расчёт СДЭК';
      deliveryQuoteMeta.textContent = message;
      cdekQuoteSummary = '';
      cdekQuotePrice = 0;
    }

    function setDeliveryQuoteLoading() {
      if (!(deliveryQuote instanceof HTMLElement)) return;
      if (!(deliveryQuoteTitle instanceof HTMLElement)) return;
      if (!(deliveryQuoteMeta instanceof HTMLElement)) return;
      deliveryQuote.hidden = false;
      deliveryQuote.classList.remove('is-idle');
      deliveryQuote.classList.remove('is-error');
      deliveryQuoteTitle.textContent = 'Считаем доставку СДЭК...';
      deliveryQuoteMeta.textContent = 'Проверяем город и индекс';
      if (deliveryQuoteHint instanceof HTMLElement) {
        deliveryQuoteHint.textContent = 'Расчёт обновляется автоматически';
      }
    }

    function setDeliveryQuoteError() {
      if (!(deliveryQuote instanceof HTMLElement)) return;
      if (!(deliveryQuoteTitle instanceof HTMLElement)) return;
      if (!(deliveryQuoteMeta instanceof HTMLElement)) return;
      deliveryQuote.hidden = false;
      deliveryQuote.classList.remove('is-idle');
      deliveryQuote.classList.add('is-error');
      deliveryQuoteTitle.textContent = 'Не удалось получить расчёт СДЭК';
      deliveryQuoteMeta.textContent = 'Заказ можно оформить, менеджер уточнит стоимость вручную';
      if (deliveryQuoteHint instanceof HTMLElement) {
        deliveryQuoteHint.textContent = 'Точную стоимость доставки сообщим после оформления заказа';
      }
      cdekQuoteSummary = '';
      cdekQuotePrice = 0;
    }

    function setDeliveryQuoteData(quote, mode) {
      if (!(deliveryQuote instanceof HTMLElement)) return;
      if (!(deliveryQuoteTitle instanceof HTMLElement)) return;
      if (!(deliveryQuoteMeta instanceof HTMLElement)) return;

      const quoteTitle = String(quote?.title || 'СДЭК Доставка');
      const quotePrice = Math.max(0, Number(quote?.priceRub) || 0);
      const quoteEta = String(quote?.etaDays || 'срок уточняется');
      const quoteTariff = Number(quote?.tariffCode);
      const modeLabel = mode === 'live' ? 'боевой расчёт' : 'тестовый расчёт';
      const tariffText = Number.isFinite(quoteTariff) && quoteTariff > 0 ? ` • тариф ${quoteTariff}` : '';

      deliveryQuote.hidden = false;
      deliveryQuote.classList.remove('is-idle');
      deliveryQuote.classList.remove('is-error');
      deliveryQuoteTitle.textContent = `${quoteTitle}: ${money(quotePrice)}`;
      deliveryQuoteMeta.textContent = `${quoteEta}${tariffText} • ${modeLabel}`;
      if (deliveryQuoteHint instanceof HTMLElement) {
        deliveryQuoteHint.textContent = 'Стоимость доставки обновляется по адресу в форме';
      }

      cdekQuoteSummary = `${quoteTitle} ${money(quotePrice)}, ${quoteEta}${tariffText}`;
      cdekQuotePrice = quotePrice;
    }

    async function calculateCdekQuote() {
      if (!(cityInput instanceof HTMLInputElement)) return;
      if (!(streetInput instanceof HTMLInputElement)) return;
      if (!(zipInput instanceof HTMLInputElement)) return;

      if (!isCdekSelected()) {
        hideDeliveryQuote();
        return;
      }

      const items = getCart();
      if (!items.length) {
        setDeliveryQuoteIdle('Добавьте товар в корзину для расчёта доставки');
        return;
      }

      const city = String(cityInput.value || '').trim();
      const street = String(streetInput.value || '').trim();
      const zip = String(zipInput.value || '').trim();
      const apartment = apartmentInput instanceof HTMLInputElement ? String(apartmentInput.value || '').trim() : '';
      if (!city || !street || zip.length < 6) {
        setDeliveryQuoteIdle('Заполните город, улицу и 6-значный индекс');
        return;
      }

      const orderTotal = items.reduce((sum, item) => sum + item.price * Math.max(1, Number(item.qty) || 1), 0);
      const payload = {
        city,
        street,
        zip,
        apartment,
        orderTotal,
        items: items.map((item) => ({
          ...(item.sku ? { sku: item.sku } : {}),
          name: item.name,
          qty: Math.max(1, Number(item.qty) || 1),
          price: Math.max(0, Number(item.price) || 0),
        })),
      };

      const requestId = ++cdekQuoteRequestId;
      setDeliveryQuoteLoading();

      try {
        const response = await fetch('/api/cdek/calculate', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
        });
        const data = await response.json().catch(() => null);

        if (requestId !== cdekQuoteRequestId) return;
        if (!response.ok || !data?.ok || !data?.quote) {
          setDeliveryQuoteError();
          return;
        }

        setDeliveryQuoteData(data.quote, data.mode);
      } catch {
        if (requestId !== cdekQuoteRequestId) return;
        setDeliveryQuoteError();
      }
    }

    function scheduleCdekQuoteCalculation(delay = 350) {
      if (cdekQuoteTimer) clearTimeout(cdekQuoteTimer);
      cdekQuoteTimer = setTimeout(() => {
        void calculateCdekQuote();
      }, delay);
    }

    function formatPhone(value) {
      const digits = String(value || '').replace(/\D/g, '');
      const normalized = digits.startsWith('8') ? `7${digits.slice(1)}` : digits;
      const base = normalized.startsWith('7') ? normalized.slice(1) : normalized;
      const sliced = base.slice(0, 10);

      let out = '+7';
      if (sliced.length > 0) out += ` (${sliced.slice(0, 3)}`;
      if (sliced.length >= 4) out += `) ${sliced.slice(3, 6)}`;
      if (sliced.length >= 7) out += `-${sliced.slice(6, 8)}`;
      if (sliced.length >= 9) out += `-${sliced.slice(8, 10)}`;
      return out;
    }

    function setupInputMasks() {
      // Маски только визуальные: payload отправляем как обычно, логика API не меняется.
      if (phoneInput instanceof HTMLInputElement) {
        phoneInput.addEventListener('focus', () => {
          if (!phoneInput.value) phoneInput.value = '+7';
        });
        phoneInput.addEventListener('input', () => {
          phoneInput.value = formatPhone(phoneInput.value);
        });
        phoneInput.addEventListener('blur', () => {
          const digits = phoneInput.value.replace(/\D/g, '');
          if (digits.length < 11) phoneInput.value = '';
        });
      }

      if (zipInput instanceof HTMLInputElement) {
        zipInput.addEventListener('input', () => {
          zipInput.value = zipInput.value.replace(/\D/g, '').slice(0, 6);
        });
      }
    }

    function renderCart() {
      // Перерисовка всей корзины из localStorage.
      const items = getCart();
      const isEmpty = !items.length;
      if (cartEmpty) cartEmpty.hidden = !isEmpty;
      if (checkoutForm) checkoutForm.style.display = isEmpty ? 'none' : 'block';
      if (checkoutHint) checkoutHint.style.display = isEmpty ? 'block' : 'none';
      if (checkoutPanel) checkoutPanel.classList.toggle('is-empty', isEmpty);

      if (cartList) {
        if (isEmpty) {
          cartList.innerHTML = '';
        } else {
          cartList.innerHTML = items
            .map((item) => {
              const qty = Math.max(1, Number(item.qty) || 1);
              return `
                <article class="cart-item" data-item-id="${item.id}">
                  <img src="${item.image}" alt="Товар ${item.name}" />
                  <div class="cart-item-main">
                    <h3>${item.name}</h3>
                    ${item.color ? `<p class="cart-item-color">${item.color}</p>` : ''}
                    <p>${money(item.price)}</p>
                    <div class="qty-row">
                      <button type="button" class="qty-btn" data-action="minus" aria-label="Уменьшить количество">−</button>
                      <input type="number" min="1" value="${qty}" data-qty-input />
                      <button type="button" class="qty-btn" data-action="plus" aria-label="Увеличить количество">+</button>
                    </div>
                  </div>
                  <button class="remove-btn" type="button" data-action="remove" aria-label="Удалить товар из корзины">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                      <path d="M3 6h18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                      <path d="M8 6V4a1 1 0 0 1 1-1h6a1 1 0 0 1 1 1v2" stroke="currentColor" stroke-width="2"/>
                      <path d="M19 6l-1 14a1 1 0 0 1-1 1H7a1 1 0 0 1-1-1L5 6" stroke="currentColor" stroke-width="2"/>
                    </svg>
                    Удалить
                  </button>
                </article>
              `;
            })
            .join('');
        }
      }

      const total = items.reduce((sum, item) => sum + item.price * Math.max(1, Number(item.qty) || 1), 0);
      if (cartTotal) cartTotal.textContent = money(total);
      if (isEmpty) {
        setDeliveryQuoteIdle('Добавьте товар в корзину для расчёта доставки');
      } else {
        scheduleCdekQuoteCalculation(120);
      }
      window.dispatchEvent(new CustomEvent('cart:updated', { detail: { count: getCartCount() } }));
    }

    document.addEventListener('click', (event) => {
      const target = event.target;
      if (!(target instanceof HTMLElement)) return;
      const action = target.dataset.action;
      if (!action) return;
      const row = target.closest('[data-item-id]');
      if (!row) return;
      const id = row.getAttribute('data-item-id');
      if (!id) return;

      if (action === 'remove') {
        // Удаление позиции целиком.
        removeFromCart(id);
      }

      if (action === 'minus' || action === 'plus') {
        const input = row.querySelector('[data-qty-input]');
        if (!(input instanceof HTMLInputElement)) return;
        const current = Math.max(1, Number(input.value) || 1);
        const next = action === 'minus' ? Math.max(1, current - 1) : current + 1;
        updateCartQty(id, next);
      }

      renderCart();
    });

    document.addEventListener('change', (event) => {
      const target = event.target;
      if (!(target instanceof HTMLInputElement) || !target.hasAttribute('data-qty-input')) return;
      const row = target.closest('[data-item-id]');
      if (!row) return;
      const id = row.getAttribute('data-item-id');
      if (!id) return;
      updateCartQty(id, Math.max(1, Number(target.value) || 1));
      renderCart();
    });

    function generateOrderId() {
      const ts = Date.now().toString(36).toUpperCase();
      const rnd = Math.random().toString(36).slice(2, 6).toUpperCase();
      return `CRPT-${ts}-${rnd}`;
    }

    function buildPayload(formData: FormData, items: ReturnType<typeof getCart>, orderId: string) {
      const deliveryRaw = String(formData.get('delivery') || '');
      const isCdek = deliveryRaw.toLowerCase().includes('сдэк');
      const delivery =
        isCdek && cdekQuoteSummary
          ? `${deliveryRaw} | ${cdekQuoteSummary}`
          : deliveryRaw;

      return {
        type: 'order' as const,
        // Русский комментарий: источник лида, чтобы в CRM отличать поток корзины от других кнопок.
        entryPoint: 'cart_checkout_submit',
        sourcePage: '/cart',
        sourceButton: 'Оформить заказ',
        orderId,
        name: String(formData.get('fullName') || ''),
        phone: String(formData.get('phone') || ''),
        email: String(formData.get('email') || ''),
        city: String(formData.get('city') || ''),
        street: String(formData.get('street') || ''),
        apartment: String(formData.get('apartment') || '').trim() || undefined,
        zip: String(formData.get('zip') || ''),
        delivery,
        // Русский комментарий: стоимость доставки СДЭК как отдельное числовое поле для B24_LEAD_DELIVERY_COST_FIELD_CODE.
        ...(isCdek && cdekQuotePrice > 0 ? { deliveryCost: cdekQuotePrice } : {}),
        items: items.map((item) => ({
          ...(item.sku ? { sku: item.sku } : {}),
          name: item.name,
          qty: Math.max(1, Number(item.qty) || 1),
          price: item.price,
          ...(item.color ? { color: item.color } : {}),
        })),
        total: cartTotal?.textContent || '',
      };
    }

    if (cardPayBtn) {
      cardPayBtn.addEventListener('click', () => {
        if (formMessage) {
          formMessage.textContent = 'Оплата картой будет доступна в ближайшее время';
          formMessage.className = 'form-message warn';
        }
      });
    }

    if (checkoutForm && submitBtn && checkoutForm.dataset.checkoutBound !== '1') {
      checkoutForm.dataset.checkoutBound = '1';
      let isSubmitting = false;

      deliveryInputs.forEach((input) => {
        input.addEventListener('change', () => {
          updateDeliveryOptionState();
          scheduleCdekQuoteCalculation();
        });
      });

      [cityInput, streetInput, apartmentInput, zipInput].forEach((input) => {
        if (!(input instanceof HTMLInputElement)) return;
        input.addEventListener('input', () => {
          scheduleCdekQuoteCalculation();
        });
        input.addEventListener('blur', () => {
          scheduleCdekQuoteCalculation();
        });
      });

      checkoutForm.addEventListener('submit', async (event) => {
        event.preventDefault();
        if (isSubmitting) return;
        const items = getCart();
        if (!items.length) return;

        const formData = new FormData(checkoutForm);
        const orderId = generateOrderId();
        const payload = buildPayload(formData, items, orderId);

        const requiredOk = payload.name && payload.phone && payload.city && payload.street && payload.zip;
        if (!requiredOk) return;

        isSubmitting = true;
        submitBtn.disabled = true;
        submitBtn.textContent = 'Отправляем...';
        checkoutForm.setAttribute('aria-busy', 'true');
        try {
          const response = await fetch('/api/b24/lead', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload)
          });

          if (!response.ok) throw new Error('request_failed');

          clearCart();
          window.location.href = `/order-success?orderId=${encodeURIComponent(orderId)}`;
        } catch {
          isSubmitting = false;
          if (formMessage) {
            formMessage.textContent = 'Ошибка отправки. Попробуйте ещё раз.';
            formMessage.className = 'form-message err';
          }
          submitBtn.disabled = false;
          submitBtn.textContent = 'Оформить заказ';
          checkoutForm.removeAttribute('aria-busy');
        }
      });
    }

    setupInputMasks();
    updateDeliveryOptionState();
    renderCart();
    scheduleCdekQuoteCalculation(0);
  </script>

  <style is:global>
    .cart-page{padding:96px 0 80px;background:#f5f5f7;min-height:72vh}
    .cart-wrap{max-width:1280px;margin:0 auto;padding:0 24px}
    .cart-head{margin-bottom:20px}
    .cart-head h1{font-family:'Unbounded',sans-serif;font-size:clamp(34px,5vw,56px);line-height:1.04;letter-spacing:-.02em;color:#111;margin:0 0 12px}
    .cart-head p{font-size:17px;color:#4b5563;line-height:1.6;margin:0}
    .cart-grid{display:grid;grid-template-columns:1.2fr .9fr;gap:20px;align-items:start}
    .cart-panel,.checkout-panel{background:#fff;border:1px solid rgba(17,17,17,.08);border-radius:20px;box-shadow:0 10px 28px rgba(17,17,17,.04);padding:26px}
    .checkout-panel h2{font-family:'Unbounded',sans-serif;font-size:clamp(28px,2.2vw,36px);line-height:1.08;letter-spacing:-.02em;margin:0 0 16px}
    .checkout-hint{margin:12px 0 0;color:#6b7280;font-size:14px;line-height:1.5}
    .checkout-panel.is-empty .summary-row{margin-bottom:0}
    .items-list{display:grid;gap:14px}
    .cart-item{display:grid;grid-template-columns:96px 1fr auto;gap:14px;align-items:center;padding:16px;border:1px solid rgba(0,0,0,.08);border-radius:16px;background:#fff}
    .cart-item img{width:96px;height:96px;object-fit:contain;background:#fff}
    .cart-item-main h3{font-size:20px;line-height:1.15;margin:0 0 4px;color:#111;letter-spacing:-.01em}
    .cart-item-color{font-size:13px;color:#6b7280;margin:0 0 8px;font-weight:500}
    .cart-item-main p{font-size:18px;font-weight:700;margin:0 0 10px;color:#111;letter-spacing:-.01em}
