---
import Layout from '../layouts/Layout.astro';
import { loadLegacyPage, optimizeLegacyImages } from '../lib/legacy';

const page = loadLegacyPage('about.html');
const optimizedBody = optimizeLegacyImages(page.body);
---
<Layout
  title={page.title}
  description="О компании CRYPTORO — официальный дистрибьютор AI-диктофонов Plaud в России. Доставка, оплата, гарантия."
  globalCss={page.css}
  headScripts={page.headScripts}
  withChrome={true}
  active="about"
>
  <Fragment set:html={optimizedBody} />
</Layout>
